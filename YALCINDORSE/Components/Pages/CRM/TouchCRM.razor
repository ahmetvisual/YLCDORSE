@page "/crm/touch-crm"
@using YALCINDORSE.Services
@inject TouchService TouchSvc
@inject QuoteService QuoteSvc
@inject CustomerService CustomerSvc
@inject AuthService Auth

<div class="crm-shell" style="display:flex;flex-direction:column;height:100vh;padding:12px 14px;box-sizing:border-box;overflow:hidden;">
    @if (isLoading)
    {
        <div style="text-align:center;padding:40px;color:var(--yl-text-light)">Yukleniyor...</div>
    }
    else
    {
        <!-- Filtre Cubugu -->
        <div class="touch-filter-bar">
            <div class="touch-search-box">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input class="touch-search" type="text" placeholder="Teklif no, musteri ara..."
                       @bind="searchText" @bind:event="oninput" @bind:after="LoadQuotes" />
            </div>
            <div class="touch-filter-right">
                @foreach (var f in filters)
                {
                    <button class="touch-chip-btn @(puanFilter == f.Key ? f.Value : "")"
                            @onclick="() => SetPuanFilter(f.Key)">
                        @(f.Key == "ALL" ? "Tumu" : f.Key)
                    </button>
                }
                <select class="touch-filter-select" @onchange="OnKanalChanged">
                    <option value="">Tum Kanallar</option>
                    <option value="BAYI">Bayi</option>
                    <option value="ZIYARET">Ziyaret</option>
                    <option value="ONLINE">Online</option>
                    <option value="WHATSAPP">WhatsApp</option>
                    <option value="EMAIL">E-Mail</option>
                    <option value="WEB_SITESI">Web Sitesi</option>
                    <option value="FUAR">Fuar</option>
                </select>
            </div>
        </div>

        <!-- Ana Icerik: Liste + Detay -->
        <div class="touch-layout">
            <!-- Teklif Listesi -->
            <div class="touch-list-panel @(selectedQuoteId > 0 ? "with-detail" : "")">
                <div class="touch-grid-container">
                <div class="touch-table-wrap">
                    <table class="touch-table">
                        <thead>
                            <tr>
                                <th>Teklif No</th>
                                <th>Musteri</th>
                                <th style="text-align:center">Durum</th>
                                <th style="text-align:center">Puan</th>
                                <th style="text-align:center">Touch</th>
                                <th>Son Temas</th>
                                <th>Sonraki</th>
                                <th style="text-align:center">Yon.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (quotes.Count == 0)
                            {
                                <tr><td colspan="8" style="text-align:center;padding:36px;color:var(--yl-text-light)">Teklif bulunamadi.</td></tr>
                            }
                            @foreach (var q in quotes)
                            {
                                var touchInfo = quoteTouchInfo.GetValueOrDefault(q.Id);
                                var isActive = selectedQuoteId == q.Id;
                                <tr class="@(isActive ? "active-row" : "")" @onclick="() => SelectQuote(q.Id)">
                                    <td>
                                        <div style="font-weight:700;color:#185FA5">@q.TeklifNo</div>
                                        @if (q.Rev > 0)
                                        {
                                            <span style="font-size:0.65rem;background:#EEEDFE;color:#534AB7;padding:1px 5px;border-radius:8px">R@(q.Rev)</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="font-weight:600">@q.Musteri</div>
                                        @if (!string.IsNullOrEmpty(q.MusteriKodu))
                                        {
                                            <div style="font-size:0.7rem;color:var(--yl-text-light)">@q.MusteriKodu</div>
                                        }
                                    </td>
                                    <td style="text-align:center">
                                        <span class="yl-chip @GetDurumChipClass(q.Durum)">@q.Durum</span>
                                    </td>
                                    <td style="text-align:center">
                                        <span class="yl-chip @GetPuanChipClass(q.Puan)">@q.Puan</span>
                                    </td>
                                    <td style="text-align:center;font-weight:700;color:#185FA5">
                                        @(touchInfo?.TouchCount ?? 0)
                                    </td>
                                    <td style="font-size:0.72rem;color:var(--yl-text-light)">
                                        @(touchInfo?.LastTouchDate?.ToString("dd.MM.yyyy") ?? "—")
                                    </td>
                                    <td style="font-size:0.72rem">
                                        @if (touchInfo?.NextTouchDate != null)
                                        {
                                            var isOverdue = touchInfo.NextTouchDate < DateTime.Today;
                                            var isToday = touchInfo.NextTouchDate?.Date == DateTime.Today;
                                            if (isOverdue)
                                            {
                                                <span class="overdue-dot"></span>
                                            }
                                            else if (isToday)
                                            {
                                                <span class="today-dot"></span>
                                            }
                                            <span style="@(isOverdue ? "color:#A32D2D;font-weight:700" : isToday ? "color:#854F0B;font-weight:700" : "")">
                                                @touchInfo.NextTouchDate?.ToString("dd.MM.yyyy")
                                            </span>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td style="text-align:center">
                                        @if (touchInfo?.HasManagement == true)
                                        {
                                            <span style="color:#3B6D11;font-size:1rem">&#10003;</span>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </div>
            </div>

            <!-- Detay Paneli -->
            @if (selectedQuoteId > 0)
            {
                <div class="touch-detail-panel">
                    <TouchDetailPanel TeklifId="selectedQuoteId"
                                      OnClose="CloseDetail"
                                      OnDataChanged="OnDetailChanged" />
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<QuoteListItemModel> quotes = new();
    private Dictionary<int, QuoteTouchSummary> quoteTouchInfo = new();
    private int selectedQuoteId;
    private string puanFilter = "ALL";
    private string kanalFilter = "";
    private string searchText = "";

    private Dictionary<string, string> filters = new()
    {
        { "ALL", "active-all" },
        { "HOT", "active-hot" },
        { "WARM", "active-warm" },
        { "COLD", "active-cold" },
        { "OPEN", "active-open" },
        { "ORDER", "active-order" },
        { "CLOSED", "active-closed" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            await LoadQuotes();
        }
        catch { }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadQuotes()
    {
        var durumFilter = puanFilter == "ALL" ? "" : "";
        var puanParam = puanFilter == "ALL" ? "" : puanFilter;

        // Puan aslinda Durum yerine Puan filtresi olarak kullaniliyor
        // ama ORDER ve CLOSED durum filtresi
        if (puanFilter == "ORDER" || puanFilter == "CLOSED" || puanFilter == "OPEN")
        {
            durumFilter = puanFilter;
            puanParam = "";
        }

        quotes = await QuoteSvc.GetQuotesAsync(searchText, durumFilter);

        // Puan filtresi uygula (client-side)
        if (!string.IsNullOrEmpty(puanParam))
            quotes = quotes.Where(q => q.Puan == puanParam).ToList();

        // Kanal filtresi (client-side)
        if (!string.IsNullOrEmpty(kanalFilter))
            quotes = quotes.Where(q => q.TeklifKanali == kanalFilter).ToList();

        // Her teklif icin temas ozet bilgisini yukle
        quoteTouchInfo.Clear();
        foreach (var q in quotes)
        {
            try
            {
                var touches = await TouchSvc.GetTouchesForQuoteAsync(q.Id);
                var lastTouch = touches.LastOrDefault();
                quoteTouchInfo[q.Id] = new QuoteTouchSummary
                {
                    TouchCount = touches.Count,
                    LastTouchDate = lastTouch?.TemasTarihi,
                    NextTouchDate = lastTouch?.SonrakiTemasTarihi,
                    HasManagement = touches.Any(t => t.YonetimDahilMi)
                };
            }
            catch
            {
                quoteTouchInfo[q.Id] = new QuoteTouchSummary();
            }
        }

        StateHasChanged();
    }

    private void SetPuanFilter(string puan)
    {
        puanFilter = puan;
        _ = LoadQuotes();
    }

    private void OnKanalChanged(ChangeEventArgs e)
    {
        kanalFilter = e.Value?.ToString() ?? "";
        _ = LoadQuotes();
    }

    private async Task SelectQuote(int quoteId)
    {
        selectedQuoteId = quoteId;
        StateHasChanged();
    }

    private void CloseDetail()
    {
        selectedQuoteId = 0;
        StateHasChanged();
    }

    private async Task OnDetailChanged()
    {
        await LoadData();
    }

    private string GetDurumChipClass(string durum) => durum switch
    {
        "Draft" => "chip-draft",
        "Sent" => "chip-sent",
        "WaitingApproval" => "chip-waiting",
        "Approved" => "chip-approved",
        "Rejected" => "chip-rejected",
        "ORDER" => "chip-order",
        "CLOSED" => "chip-closed",
        "OPEN" => "chip-open",
        _ => "chip-draft"
    };

    private string GetPuanChipClass(string puan) => puan switch
    {
        "HOT" => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _ => "chip-draft"
    };

    private class QuoteTouchSummary
    {
        public int TouchCount { get; set; }
        public DateTime? LastTouchDate { get; set; }
        public DateTime? NextTouchDate { get; set; }
        public bool HasManagement { get; set; }
    }
}
