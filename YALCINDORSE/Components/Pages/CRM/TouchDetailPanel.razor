@using YALCINDORSE.Services
@inject TouchService TouchSvc
@inject QuoteService QuoteSvc
@inject AuthService Auth

<div class="touch-panel-body">
    @if (isLoading)
    {
        <div style="text-align:center;padding:30px;color:var(--yl-text-light)">Yukleniyor...</div>
    }
    else if (quote != null)
    {
        <!-- Gorusme Gecmisi -->
        <div style="margin-bottom:14px">
            <div class="touch-section-title">
                Gorusme Gecmisi
                <span style="font-weight:400">@timeline.Count gorusme</span>
            </div>

            <div class="touch-timeline">
                @if (timeline.Count == 0)
                {
                    <div style="font-size:0.78rem;color:var(--yl-text-light);padding:10px 0">Henuz gorusme kaydi yok.</div>
                }

                @{ int seq = 0; }
                @foreach (var entry in timeline)
                {
                    seq++;
                    var typeName = entry.Tipi switch {
                        "CALL"    => "Arama",
                        "MAIL"    => "Mail",
                        "VISIT"   => "Ziyaret",
                        "NOTE"    => "Not",
                        "MEETING" => "Toplanti",
                        _         => entry.Tipi ?? ""
                    };
                    var typeClass = "tl-type-" + (entry.Tipi?.ToLower() ?? "note");
                    var entryId = entry.Id;   // capture for lambda

                    <div class="tl-entry">
                        <div class="tl-line"></div>
                        <div class="tl-dot">@seq</div>
                        <div class="tl-card">
                            <div class="tl-card-header">
                                <span class="tl-date">@entry.Tarih.ToString("dd.MM.yyyy HH:mm")</span>
                                @if (!string.IsNullOrEmpty(entry.KisiAdi))
                                {
                                    <span class="tl-who">@entry.KisiAdi</span>
                                }
                                <span class="@typeClass">@typeName</span>
                                @if (entry.YonetimDahil)
                                {
                                    <span class="tl-mgmt-badge">Yonetim</span>
                                }
                                <!-- Duzenle butonu -->
                                <button class="tl-edit-btn" title="Duzenle"
                                        @onclick="() => OpenEditForm(entryId)"
                                        @onclick:stopPropagation="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(entry.Aciklama))
                            {
                                <div class="tl-note-text">@entry.Aciklama</div>
                            }
                            @if (entry.SonrakiTemas.HasValue)
                            {
                                <div class="tl-next-touch">Sonraki: @entry.SonrakiTemas?.ToString("dd.MM.yyyy")</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Aksiyon Butonlari -->
        @if (!showTouchForm && !showStatusModal && !showEditForm)
        {
            <div class="touch-actions">
                <button class="touch-btn touch-btn-primary" @onclick="ShowTouchForm">+ Gorusme Ekle</button>
                <button class="touch-btn" @onclick="ShowStatusUpdate">Durum Guncelle</button>
            </div>
        }

        <!-- Gorusme Ekleme Formu -->
        @if (showTouchForm)
        {
            <div class="touch-form" style="margin-top:12px">
                <div class="touch-form-title">Yeni Gorusme &mdash; @quote.TeklifNo</div>
                <div class="touch-form-grid3">
                    <div class="touch-form-row">
                        <label>Tarih</label>
                        <input type="date" @bind="newTouch.TemasTarihi" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="touch-form-row">
                        <label>Tur</label>
                        <select @bind="newTouch.TemasTipi">
                            <option value="CALL">Arama</option>
                            <option value="MAIL">Mail</option>
                            <option value="VISIT">Ziyaret</option>
                            <option value="NOTE">Not</option>
                            <option value="MEETING">Toplanti</option>
                        </select>
                    </div>
                    <div class="touch-form-row">
                        <label>Sonraki Temas</label>
                        <input type="date" @bind="newTouch.SonrakiTemasTarihi" @bind:format="yyyy-MM-dd" />
                    </div>
                </div>
                <div class="touch-form-grid2">
                    <div class="touch-form-row">
                        <label>Puan Guncelle</label>
                        <select @bind="newTouch.PuanGuncelleme">
                            <option value="">Degistirme</option>
                            <option value="HOT">HOT</option>
                            <option value="WARM">WARM</option>
                            <option value="COLD">COLD</option>
                        </select>
                    </div>
                    <div class="touch-form-row">
                        <label>Yonetim Dahil?</label>
                        <select @bind="newTouch.YonetimDahilMi">
                            <option value="false">Hayir</option>
                            <option value="true">Evet</option>
                        </select>
                    </div>
                </div>
                <div class="touch-form-row">
                    <label>Gorusme Notu *</label>
                    <textarea @bind="newTouch.Not" placeholder="Gorusme detaylari, musteri geri bildirimi, kararlar..."></textarea>
                </div>
                @if (!string.IsNullOrEmpty(touchError))
                {
                    <div style="color:#A32D2D;font-size:0.78rem;margin-bottom:8px">@touchError</div>
                }
                <div class="touch-form-actions">
                    <button class="touch-btn" @onclick="CancelTouchForm">Iptal</button>
                    <button class="touch-btn touch-btn-primary" @onclick="SaveTouch" disabled="@isSaving">
                        @(isSaving ? "Kaydediliyor..." : "Kaydet")
                    </button>
                </div>
            </div>
        }

        <!-- Gorusme Duzenleme Formu -->
        @if (showEditForm && editingTouch != null)
        {
            <div class="touch-form" style="margin-top:12px">
                <div class="touch-form-title">Gorusmeyi Duzenle</div>
                <div class="touch-form-grid3">
                    <div class="touch-form-row">
                        <label>Tarih</label>
                        <input type="date" @bind="editingTouch.TemasTarihi" @bind:format="yyyy-MM-dd" />
                    </div>
                    <div class="touch-form-row">
                        <label>Tur</label>
                        <select @bind="editingTouch.TemasTipi">
                            <option value="CALL">Arama</option>
                            <option value="MAIL">Mail</option>
                            <option value="VISIT">Ziyaret</option>
                            <option value="NOTE">Not</option>
                            <option value="MEETING">Toplanti</option>
                        </select>
                    </div>
                    <div class="touch-form-row">
                        <label>Sonraki Temas</label>
                        <input type="date" @bind="editingTouch.SonrakiTemasTarihi" @bind:format="yyyy-MM-dd" />
                    </div>
                </div>
                <div class="touch-form-grid2">
                    <div class="touch-form-row">
                        <label>Puan Guncelle</label>
                        <select @bind="editingTouch.PuanGuncelleme">
                            <option value="">Degistirme</option>
                            <option value="HOT">HOT</option>
                            <option value="WARM">WARM</option>
                            <option value="COLD">COLD</option>
                        </select>
                    </div>
                    <div class="touch-form-row">
                        <label>Yonetim Dahil?</label>
                        <select @bind="editingTouch.YonetimDahilMi">
                            <option value="false">Hayir</option>
                            <option value="true">Evet</option>
                        </select>
                    </div>
                </div>
                <div class="touch-form-row">
                    <label>Gorusme Notu *</label>
                    <textarea @bind="editingTouch.Not" placeholder="Gorusme detaylari, musteri geri bildirimi, kararlar..."></textarea>
                </div>
                @if (!string.IsNullOrEmpty(editError))
                {
                    <div style="color:#A32D2D;font-size:0.78rem;margin-bottom:8px">@editError</div>
                }
                <div class="touch-form-actions">
                    <button class="touch-btn" @onclick="CancelEditForm">Iptal</button>
                    <button class="touch-btn touch-btn-primary" @onclick="SaveEdit" disabled="@isSaving">
                        @(isSaving ? "Kaydediliyor..." : "Guncelle")
                    </button>
                </div>
            </div>
        }

        <!-- Durum Guncelleme -->
        @if (showStatusModal)
        {
            <div class="touch-form" style="margin-top:12px">
                <div class="touch-form-title">Durum Guncelle</div>
                <div class="touch-form-grid2">
                    <div class="touch-form-row">
                        <label>Yeni Durum</label>
                        <select @bind="newStatus">
                            <option value="Draft">Taslak</option>
                            <option value="Sent">Gonderildi</option>
                            <option value="OPEN">Acik</option>
                            <option value="ORDER">Siparis</option>
                            <option value="CLOSED">Kapali</option>
                        </select>
                    </div>
                    <div class="touch-form-row">
                        <label>Yeni Puan</label>
                        <select @bind="newPuan">
                            <option value="">Degistirme</option>
                            <option value="HOT">HOT</option>
                            <option value="WARM">WARM</option>
                            <option value="COLD">COLD</option>
                        </select>
                    </div>
                </div>
                <div class="touch-form-actions">
                    <button class="touch-btn" @onclick="() => showStatusModal = false">Iptal</button>
                    <button class="touch-btn touch-btn-primary" @onclick="SaveStatusUpdate" disabled="@isSaving">Guncelle</button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int TeklifId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private QuoteListItemModel? quote;
    private List<TimelineEntryModel> timeline = new();
    private List<TouchModel> touches = new();
    private DateTime? nextTouchDate;
    private bool isLoading = true;
    private bool isSaving;

    // Yeni gorusme formu
    private bool showTouchForm;
    private TouchModel newTouch = new();
    private string touchError = "";

    // Duzenle formu
    private bool showEditForm;
    private TouchModel? editingTouch;
    private string editError = "";

    // Durum guncelleme
    private bool showStatusModal;
    private string newStatus = "";
    private string newPuan = "";

    protected override async Task OnParametersSetAsync()
    {
        if (TeklifId > 0)
            await LoadDetail();
    }

    private async Task LoadDetail()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var allQuotes = await QuoteSvc.GetQuotesAsync();
            quote = allQuotes.FirstOrDefault(q => q.Id == TeklifId);

            timeline = await TouchSvc.GetTimelineAsync(TeklifId);

            touches = await TouchSvc.GetTouchesForQuoteAsync(TeklifId);
            var lastTouch = touches.LastOrDefault();
            nextTouchDate = lastTouch?.SonrakiTemasTarihi;
        }
        catch { }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ── Yeni Gorusme ──────────────────────────────────────────────

    private void ShowTouchForm()
    {
        showTouchForm = true;
        showStatusModal = false;
        showEditForm = false;
        newTouch = new TouchModel
        {
            TeklifId   = TeklifId,
            TemasTarihi = DateTime.Now,
            TemasTipi  = "CALL",
            RevizyonNo = quote?.Rev ?? 0,
            TemasEden  = Auth.CurrentUserId   // FIX: kullanici adi timeline'a yazilsin
        };
        touchError = "";
    }

    private void CancelTouchForm()
    {
        showTouchForm = false;
        touchError = "";
    }

    private async Task SaveTouch()
    {
        if (string.IsNullOrWhiteSpace(newTouch.Not))
        {
            touchError = "Gorusme notu zorunludur.";
            return;
        }

        isSaving = true;
        try
        {
            await TouchSvc.CreateTouchAsync(newTouch);
            showTouchForm = false;
            touchError = "";
            await LoadDetail();
            await OnDataChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            touchError = "Hata: " + ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Gorusme Duzenleme ─────────────────────────────────────────

    private void OpenEditForm(int touchId)
    {
        var touch = touches.FirstOrDefault(t => t.Id == touchId);
        if (touch == null) return;

        editingTouch = new TouchModel
        {
            Id                  = touch.Id,
            TeklifId            = touch.TeklifId,
            RevizyonNo          = touch.RevizyonNo,
            TemasTarihi         = touch.TemasTarihi,
            TemasEden           = touch.TemasEden,
            TemasTipi           = touch.TemasTipi,
            Not                 = touch.Not,
            SonrakiTemasTarihi  = touch.SonrakiTemasTarihi,
            YonetimDahilMi      = touch.YonetimDahilMi,
            DurumGuncelleme     = touch.DurumGuncelleme,
            PuanGuncelleme      = touch.PuanGuncelleme
        };

        showEditForm    = true;
        showTouchForm   = false;
        showStatusModal = false;
        editError       = "";
    }

    private void CancelEditForm()
    {
        showEditForm = false;
        editingTouch = null;
        editError = "";
    }

    private async Task SaveEdit()
    {
        if (editingTouch == null) return;
        if (string.IsNullOrWhiteSpace(editingTouch.Not))
        {
            editError = "Gorusme notu zorunludur.";
            return;
        }

        isSaving = true;
        try
        {
            await TouchSvc.UpdateTouchAsync(editingTouch);
            showEditForm = false;
            editingTouch = null;
            editError = "";
            await LoadDetail();
            await OnDataChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            editError = "Hata: " + ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Durum Guncelleme ──────────────────────────────────────────

    private void ShowStatusUpdate()
    {
        showStatusModal = true;
        showTouchForm   = false;
        showEditForm    = false;
        newStatus = quote?.Durum ?? "Draft";
        newPuan = "";
    }

    private async Task SaveStatusUpdate()
    {
        isSaving = true;
        try
        {
            await TouchSvc.UpdateQuoteStatusAsync(TeklifId, newStatus);
            if (!string.IsNullOrEmpty(newPuan))
                await TouchSvc.UpdateQuotePuanAsync(TeklifId, newPuan);

            showStatusModal = false;
            await LoadDetail();
            await OnDataChanged.InvokeAsync();
        }
        catch { }
        finally
        {
            isSaving = false;
        }
    }

    private string GetDurumChipClass(string durum) => durum switch
    {
        "Draft"           => "chip-draft",
        "Sent"            => "chip-sent",
        "WaitingApproval" => "chip-waiting",
        "Approved"        => "chip-approved",
        "Rejected"        => "chip-rejected",
        "ORDER"           => "chip-order",
        "CLOSED"          => "chip-closed",
        "OPEN"            => "chip-open",
        _                 => "chip-draft"
    };

    private string GetPuanChipClass(string puan) => puan switch
    {
        "HOT"  => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _      => "chip-draft"
    };
}
