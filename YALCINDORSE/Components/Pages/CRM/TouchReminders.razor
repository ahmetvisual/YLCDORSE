@page "/crm/hatirlatmalar"
@using YALCINDORSE.Services
@inject TouchService TouchSvc
@inject NavigationManager Nav

<div class="crm-shell">
    <div class="crm-header">
        <div>
            <h2 style="margin:0;font-size:1.3rem;font-weight:700;color:var(--yl-primary)">Hatirlatmalar</h2>
            <p style="margin:2px 0 0;font-size:0.8rem;color:var(--yl-text-light)">Temas planlari ve geciken takipler</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div style="text-align:center;padding:40px;color:var(--yl-text-light)">Yukleniyor...</div>
    }
    else
    {
        <div style="max-width:780px">
            @if (overdue.Count > 0)
            {
                <div style="background:#fff;border:1px solid #A32D2D;border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                    <div style="font-size:0.7rem;font-weight:700;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.6px;color:#A32D2D">
                        Geciken Temas (@overdue.Count)
                    </div>
                    @foreach (var r in overdue)
                    {
                        <div class="reminder-row" @onclick="() => GoToQuote(r.TeklifId)">
                            <div style="min-width:100px;font-size:0.72rem;font-weight:700;color:#A32D2D">@r.GecenGun gun gecikti</div>
                            <div style="flex:1">
                                <span style="font-weight:700;color:#185FA5">@r.TeklifNo</span>
                                <span style="color:var(--yl-text-light);margin-left:8px;font-size:0.72rem">@r.Musteri</span>
                            </div>
                            <span class="yl-chip @GetPuanChip(r.Puan)">@r.Puan</span>
                            <span style="font-size:0.72rem;color:var(--yl-text-light);margin-left:8px">@r.Satici</span>
                        </div>
                    }
                </div>
            }

            @if (today.Count > 0)
            {
                <div style="background:#fff;border:1px solid #854F0B;border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                    <div style="font-size:0.7rem;font-weight:700;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.6px;color:#854F0B">
                        Bugun (@today.Count)
                    </div>
                    @foreach (var r in today)
                    {
                        <div class="reminder-row" @onclick="() => GoToQuote(r.TeklifId)">
                            <div style="min-width:100px;font-size:0.72rem;font-weight:700;color:#854F0B">Bugun</div>
                            <div style="flex:1">
                                <span style="font-weight:700;color:#185FA5">@r.TeklifNo</span>
                                <span style="color:var(--yl-text-light);margin-left:8px;font-size:0.72rem">@r.Musteri</span>
                            </div>
                            <span class="yl-chip @GetPuanChip(r.Puan)">@r.Puan</span>
                            <span style="font-size:0.72rem;color:var(--yl-text-light);margin-left:8px">@r.Satici</span>
                        </div>
                    }
                </div>
            }

            @if (thisWeek.Count > 0)
            {
                <div style="background:#fff;border:1px solid var(--yl-border);border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                    <div style="font-size:0.7rem;font-weight:700;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.6px;color:#185FA5">
                        Bu Hafta (@thisWeek.Count)
                    </div>
                    @foreach (var r in thisWeek)
                    {
                        <div class="reminder-row" @onclick="() => GoToQuote(r.TeklifId)">
                            <div style="min-width:100px;font-size:0.72rem;font-weight:700;color:#185FA5">@r.PlanlananTarih.ToString("dd.MM.yyyy")</div>
                            <div style="flex:1">
                                <span style="font-weight:700;color:#185FA5">@r.TeklifNo</span>
                                <span style="color:var(--yl-text-light);margin-left:8px;font-size:0.72rem">@r.Musteri</span>
                            </div>
                            <span class="yl-chip @GetPuanChip(r.Puan)">@r.Puan</span>
                            <span style="font-size:0.72rem;color:var(--yl-text-light);margin-left:8px">@r.Satici</span>
                        </div>
                    }
                </div>
            }

            @if (stale.Count > 0)
            {
                <div style="background:#fff;border:1px solid var(--yl-border);border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                    <div style="font-size:0.7rem;font-weight:700;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.6px;color:#5F5E5A">
                        30+ Gun Sessiz (@stale.Count)
                    </div>
                    @foreach (var r in stale)
                    {
                        <div class="reminder-row" @onclick="() => GoToQuote(r.TeklifId)">
                            <div style="min-width:100px;font-size:0.72rem;font-weight:700;color:#5F5E5A">@r.GecenGun gun sessiz</div>
                            <div style="flex:1">
                                <span style="font-weight:700;color:#185FA5">@r.TeklifNo</span>
                                <span style="color:var(--yl-text-light);margin-left:8px;font-size:0.72rem">@r.Musteri</span>
                            </div>
                            <span class="yl-chip @GetPuanChip(r.Puan)">@r.Puan</span>
                            <span style="font-size:0.72rem;color:var(--yl-text-light);margin-left:8px">@r.Satici</span>
                        </div>
                    }
                </div>
            }

            @if (overdue.Count == 0 && today.Count == 0 && thisWeek.Count == 0 && stale.Count == 0)
            {
                <div style="text-align:center;padding:48px 20px;color:var(--yl-text-light)">
                    <div style="font-size:2.5rem;margin-bottom:12px">&#10003;</div>
                    <div>Bekleyen hatirlatma yok.</div>
                </div>
            }
        </div>
    }
</div>

<style>
    .reminder-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid var(--yl-border);
        cursor: pointer;
    }
    .reminder-row:hover {
        background: #f5f8ff;
        margin: 0 -6px;
        padding: 9px 6px;
        border-radius: 6px;
    }
    .reminder-row:last-child {
        border-bottom: none;
    }
</style>

@code {
    private bool isLoading = true;
    private List<TouchReminderModel> overdue = new();
    private List<TouchReminderModel> today = new();
    private List<TouchReminderModel> thisWeek = new();
    private List<TouchReminderModel> stale = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            overdue = await TouchSvc.GetOverdueTouchesAsync();
            today = await TouchSvc.GetTodayTouchesAsync();
            thisWeek = await TouchSvc.GetWeekTouchesAsync();
            stale = await TouchSvc.GetStaleTouchesAsync(30);
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToQuote(int teklifId)
    {
        Nav.NavigateTo($"/crm/touch-crm");
    }

    private string GetPuanChip(string puan) => puan switch
    {
        "HOT" => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _ => "chip-draft"
    };
}
