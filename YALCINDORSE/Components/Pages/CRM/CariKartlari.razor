@page "/crm/cari-kartlar"
@using YALCINDORSE.Services
@inject CustomerService CustomerSvc
@inject IJSRuntime JS

<div class="rc-shell @(StandaloneWindow ? "standalone-window" : "")">
    <!-- ═══ MAIN TABS ═══ -->
    <div class="rc-main-tabs">
        <button class="rc-main-tab @(_mainTab == "cariler" ? "active" : "")"
                @onclick='() => _mainTab = "cariler"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:18px;height:18px;">
                <rect x="3" y="4" width="18" height="16" rx="2"/><line x1="7" y1="8" x2="17" y2="8"/>
                <line x1="7" y1="12" x2="17" y2="12"/><line x1="7" y1="16" x2="13" y2="16"/>
            </svg>
            Cariler
        </button>
        <button class="rc-main-tab @(_mainTab == "resmi" ? "active" : "")"
                @onclick='() => _mainTab = "resmi"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:18px;height:18px;">
                <path d="M3 7h18"/><path d="M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/>
                <path d="M9 12l2 2 4-4"/>
            </svg>
            Resmi Cariler
            <span class="rc-main-tab-badge">Zirve</span>
        </button>
    </div>

    @if (_mainTab == "cariler")
    {
        <!-- ═══ CARİLER HEADER ═══ -->
        <div class="rc-header">
            <div class="rc-header-left">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="rc-header-icon">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                </svg>
                <div>
                    <h3>Cari Kartlar</h3>
                    <p class="rc-header-sub">@customers.Count kayit</p>
                </div>
            </div>
            <div class="rc-header-actions">
                <button class="rc-btn rc-btn-ghost" @onclick="ReloadAsync" disabled="@isLoadingList">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="rc-btn-icon">
                        <path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
                        <path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>
                    </svg>
                    Yenile
                </button>
                <button class="rc-btn rc-btn-danger-sm" @onclick="OpenDeleteConfirm"
                        disabled="@(currentCustomer.Id == 0 || isDeleting)">Sil</button>
                <button class="rc-btn rc-btn-primary" @onclick="CreateNewCustomer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="rc-btn-icon">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Yeni Cari
                </button>
            </div>
        </div>

        @if (!messageSuccess && message != null)
        {
            <div class="rc-toast is-err">
                @message
                <button class="rc-toast-close" @onclick='() => message = null'>&times;</button>
            </div>
        }

        <!-- ═══ MASTER-DETAIL ═══ -->
        <div class="rc-layout">
            <!-- SOL: MÜŞTERİ LİSTESİ -->
            <aside class="rc-list-panel" @onkeydown="HandleListKeyDown">
                <div class="rc-search-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="rc-search-icon">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" class="rc-search-input" placeholder="Musteri ara..."
                           @bind="searchTerm" @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="rc-search-clear" @onclick='() => searchTerm = ""'>&times;</button>
                    }
                </div>
                <div class="rc-list-count">@FilteredCustomers.Count() kayit</div>
                <div class="rc-list-scroll">
                    @if (isLoadingList)
                    {
                        @for (int i = 0; i < 8; i++)
                        {
                            <div class="rc-skel-item"><div class="rc-skel-line w60"></div><div class="rc-skel-line w40"></div></div>
                        }
                    }
                    else
                    {
                        @foreach (var item in FilteredCustomers)
                        {
                            <button type="button" id="cari-@item.Id"
                                    class="rc-list-item @(selectedCustomerId == item.Id ? "active" : "")"
                                    @onclick="() => SelectCustomerAsync(item.Id)">
                                <div class="rc-item-top">
                                    <span class="rc-item-code">@item.CustomerCode</span>
                                    <span class="rc-item-badge @(item.IsActive ? "rc-badge-ok" : "rc-badge-warn")">
                                        @(item.IsActive ? "✓" : "✗")
                                    </span>
                                </div>
                                <div class="rc-item-name">@item.Title</div>
                                <div class="rc-item-sub">@item.CurrentBalance.ToString("N2") EUR @(item.SalesRepName != null ? $"· {item.SalesRepName}" : "")</div>
                            </button>
                        }
                    }
                </div>
            </aside>

            <!-- SAĞ: MÜŞTERİ FORMU -->
            <section class="rc-detail-panel">
                @if (isLoadingDetail)
                {
                    <div class="rc-detail-empty">
                        <p>Musteri detaylari yukleniyor...</p>
                    </div>
                }
                else
                {
                    <div class="rc-detail-scroll">
                        <!-- DETAIL HEADER -->
                        <div class="rc-detail-header">
                            <div>
                                <div class="rc-detail-code">@(string.IsNullOrWhiteSpace(currentCustomer.CustomerCode) ? "YENI" : currentCustomer.CustomerCode)</div>
                                <div class="rc-detail-name">@(string.IsNullOrWhiteSpace(currentCustomer.Title) ? "Yeni musteri" : currentCustomer.Title)</div>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="rc-detail-summary-item">
                                    <span class="rc-lbl">Bakiye</span>
                                    <strong>@currentCustomer.CurrentBalance.ToString("N2") EUR</strong>
                                </div>
                                <div class="rc-detail-summary-item">
                                    <span class="rc-lbl">Risk</span>
                                    <strong>@currentCustomer.RiskLimit.ToString("N2") EUR</strong>
                                </div>
                                <span class="rc-match-chip @(currentCustomer.IsActive ? "is-ok" : "is-warn")">
                                    @(currentCustomer.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </div>
                        </div>

                        <!-- INNER TABS -->
                        <div class="rc-filter-bar" style="padding:0;margin-bottom:16px;">
                            <button class="rc-tab @(activeTab == "general" ? "active" : "")" @onclick='() => activeTab = "general"'>Genel Bilgiler</button>
                            <button class="rc-tab @(activeTab == "contacts" ? "active" : "")" @onclick='() => activeTab = "contacts"'>Ilgili Kisiler</button>
                            <button class="rc-tab @(activeTab == "notes" ? "active" : "")" @onclick='() => activeTab = "notes"'>Notlar</button>
                        </div>

                        @if (activeTab == "general")
                        {
                            <div class="rc-info-grid">
                                <div class="rc-info-group">
                                    <h4>Firma Bilgileri</h4>
                                    <div class="rc-form-grid">
                                        <div class="rc-form-field">
                                            <label>Musteri Kodu</label>
                                            <input class="rc-form-input" readonly value="@(string.IsNullOrWhiteSpace(currentCustomer.CustomerCode) ? "Kayit sonrasi olusur" : currentCustomer.CustomerCode)" />
                                        </div>
                                        <div class="rc-form-field rc-span-2">
                                            <label>Unvan *</label>
                                            <input class="rc-form-input" @bind="currentCustomer.Title" placeholder="Firma unvani" />
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Vergi No</label>
                                            <input class="rc-form-input" @bind="currentCustomer.TaxNumber" placeholder="Vergi numarasi" />
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Vergi Dairesi</label>
                                            <input class="rc-form-input" @bind="currentCustomer.TaxOffice" placeholder="Vergi dairesi" />
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Ulke</label>
                                            <select class="rc-form-input" @bind="currentCustomer.Country">
                                                @foreach (var country in CountryOptions)
                                                {
                                                    <option value="@country">@country</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="rc-info-group">
                                    <h4>Adres ve Finans</h4>
                                    <div class="rc-form-grid">
                                        <div class="rc-form-field rc-span-2">
                                            <label>Adres</label>
                                            <textarea class="rc-form-input rc-textarea" @bind="currentCustomer.Address" rows="3" placeholder="Adres bilgisi"></textarea>
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Risk Limiti (EUR)</label>
                                            <input type="number" class="rc-form-input" @bind="currentCustomer.RiskLimit" step="0.01" />
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Cari Bakiye (EUR)</label>
                                            <input type="number" class="rc-form-input" readonly @bind="currentCustomer.CurrentBalance" step="0.01" />
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Satis Temsilcisi</label>
                                            <select class="rc-form-input" @bind="currentCustomer.SalesRepId">
                                                <option value="">Seciniz</option>
                                                @foreach (var rep in salesReps)
                                                {
                                                    <option value="@rep.Id">@rep.FullName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="rc-form-field">
                                            <label>Durum</label>
                                            <div class="rc-toggle-wrap">
                                                <label class="rc-toggle">
                                                    <input type="checkbox" @bind="currentCustomer.IsActive" />
                                                    <span class="rc-toggle-slider"></span>
                                                </label>
                                                <span class="rc-toggle-label">@(currentCustomer.IsActive ? "Aktif" : "Pasif")</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (activeTab == "contacts")
                        {
                            <div class="rc-info-group">
                                <h4 style="display:flex;align-items:center;justify-content:space-between;">
                                    Ilgili Kisiler
                                    <button class="rc-btn rc-btn-primary" style="font-size:0.72rem;padding:4px 10px;" @onclick="AddContact">+ Yeni Kisi</button>
                                </h4>

                                @if (currentCustomer.Contacts.Count == 0)
                                {
                                    <p style="color:var(--yl-text-light);font-size:0.82rem;padding:12px 0;">Henuz ilgili kisi eklenmedi.</p>
                                }
                                else
                                {
                                    @for (var i = 0; i < currentCustomer.Contacts.Count; i++)
                                    {
                                        var contact = currentCustomer.Contacts[i];
                                        <div class="rc-contact-card @(i % 2 == 0 ? "even" : "odd")">
                                            <div class="rc-form-grid rc-grid-3">
                                                <div class="rc-form-field">
                                                    <label>Ad Soyad *</label>
                                                    <input class="rc-form-input" @bind="contact.ContactName" placeholder="Ad soyad" />
                                                </div>
                                                <div class="rc-form-field">
                                                    <label>E-posta</label>
                                                    <input class="rc-form-input" @bind="contact.Email" placeholder="E-posta" />
                                                </div>
                                                <div class="rc-form-field">
                                                    <label>Mobil</label>
                                                    <input class="rc-form-input" @bind="contact.Mobile" placeholder="Mobil" />
                                                </div>
                                                <div class="rc-form-field">
                                                    <label>Unvan</label>
                                                    <input class="rc-form-input" @bind="contact.ContactTitle" placeholder="Unvan" />
                                                </div>
                                                <div class="rc-form-field">
                                                    <label>Telefon</label>
                                                    <input class="rc-form-input" @bind="contact.Phone" placeholder="Telefon" />
                                                </div>
                                                <div class="rc-form-field">
                                                    <label>Departman</label>
                                                    <input class="rc-form-input" @bind="contact.Department" placeholder="Departman" />
                                                </div>
                                            </div>
                                            <div class="rc-contact-footer">
                                                <input class="rc-form-input" style="flex:1;" @bind="contact.Notes" placeholder="Not (opsiyonel)" />
                                                <label class="rc-inline-check">
                                                    <input type="checkbox" checked="@contact.IsPrimary" @onchange="args => TogglePrimaryContact(contact, args)" />
                                                    <span>Primary</span>
                                                </label>
                                                <button class="rc-btn rc-btn-danger-sm" @onclick="() => RemoveContact(contact)">Kaldir</button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rc-info-group">
                                <h4>Kart Notlari</h4>
                                <textarea class="rc-form-input rc-textarea" @bind="currentCustomer.Notes" rows="12"
                                          placeholder="Musteri ile ilgili genel notlar, odeme davranisi, operasyon aciklamalari vb."></textarea>
                            </div>
                        }

                        <!-- FOOTER -->
                        <div class="rc-form-footer">
                            <div class="rc-form-audit">
                                @if (currentCustomer.Id > 0)
                                {
                                    <span>Olusturan: @currentCustomer.CreatedBy</span>
                                    <span>Kod: @currentCustomer.CustomerCode</span>
                                }
                            </div>
                            <div class="rc-form-actions">
                                <button class="rc-btn rc-btn-ghost" @onclick="ResetCurrentAsync" disabled="@isSaving">Vazgec</button>
                                <button class="rc-btn rc-btn-primary" @onclick="OpenSaveConfirm" disabled="@isSaving">
                                    @(isSaving ? "Kaydediliyor..." : "Kaydet")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </section>
        </div>
    }
    else
    {
        <!-- ═══ RESMİ CARİLER SEKMESİ ═══ -->
        <ResmiCariler />
    }
</div>

@* ═══ TOAST ═══ *@
@if (showToast)
{
    <div class="rc-toast-overlay">
        <div class="rc-toast-card @(toastIsSuccess ? "is-ok" : "is-err")">
            <strong>@(toastIsSuccess ? "Basarili!" : "Hata!")</strong>
            <span>@toastMessage</span>
        </div>
    </div>
}

@* ═══ ONAY MODALLARI ═══ *@
@if (showSaveConfirm)
{
    <div class="rc-modal-overlay" @onclick="CloseSaveConfirm">
        <div class="rc-modal" @onclick:stopPropagation="true">
            <div class="rc-modal-header">Kaydet</div>
            <div class="rc-modal-body">
                @if (currentCustomer.Id == 0)
                {
                    <p>Yeni cari kart kaydedilecek. Onayliyor musunuz?</p>
                }
                else
                {
                    <p><strong>@currentCustomer.Title</strong> kartindaki degisiklikler kaydedilecek.</p>
                }
            </div>
            <div class="rc-modal-footer">
                <button class="rc-btn rc-btn-ghost" @onclick="CloseSaveConfirm" disabled="@isSaving">Iptal</button>
                <button class="rc-btn rc-btn-primary" @onclick="ConfirmSaveAsync" disabled="@isSaving">Evet, Kaydet</button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="rc-modal-overlay" @onclick="CloseDeleteConfirm">
        <div class="rc-modal" @onclick:stopPropagation="true">
            <div class="rc-modal-header">Cari Kart Sil</div>
            <div class="rc-modal-body">
                <p><strong>@currentCustomer.Title</strong> kaydini silmek istediginize emin misiniz?</p>
            </div>
            <div class="rc-modal-footer">
                <button class="rc-btn rc-btn-ghost" @onclick="CloseDeleteConfirm">Iptal</button>
                <button class="rc-btn rc-btn-danger-sm" style="padding:7px 14px;font-size:0.8rem;" @onclick="DeleteCurrentAsync" disabled="@isDeleting">
                    @(isDeleting ? "Siliniyor..." : "Sil")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool StandaloneWindow { get; set; }

    private string _mainTab = "cariler";

    private static readonly string[] CountryOptions = new[]
    {
        "TR", "DE", "FR", "IT", "ES", "NL", "BE", "GB", "US", "AE", "SA"
    };

    private List<CustomerListItemModel> customers = new();
    private List<SalesRepOption> salesReps = new();
    private CustomerModel currentCustomer = new();
    private bool isLoadingList = true;
    private bool isLoadingDetail;
    private bool isSaving;
    private bool isDeleting;
    private bool showDeleteConfirm;
    private bool showSaveConfirm;
    private bool showToast;
    private bool toastIsSuccess;
    private string toastMessage = "";
    private string searchTerm = "";
    private string activeTab = "general";
    private string? message;
    private bool messageSuccess;
    private int? selectedCustomerId;

    private IEnumerable<CustomerListItemModel> FilteredCustomers =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? customers
            : customers.Where(x =>
                x.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                x.CustomerCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (x.TaxNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.SalesRepName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        currentCustomer = CustomerSvc.CreateDraft();
        try
        {
            await LoadSalesRepsAsync();
            await LoadCustomersAsync(true);
        }
        catch (Exception ex)
        {
            isLoadingList = false;
            isLoadingDetail = false;
            message = $"Veritabani hatasi: {ex.Message}";
            messageSuccess = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    var panel = document.querySelector('.rc-list-panel');
                    if (!panel || panel._arrowNavReady) return;
                    panel._arrowNavReady = true;
                    panel.addEventListener('keydown', function(e) {
                        if (e.key === 'ArrowDown' || e.key === 'ArrowUp') e.preventDefault();
                    }, { passive: false, capture: true });
                })();
            ");
        }
    }

    private async Task HandleListKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "ArrowDown" && e.Key != "ArrowUp") return;
        var list = FilteredCustomers.ToList();
        if (list.Count == 0) return;
        var idx = selectedCustomerId.HasValue ? list.FindIndex(x => x.Id == selectedCustomerId.Value) : -1;
        var next = e.Key == "ArrowDown" ? Math.Min(idx + 1, list.Count - 1) : Math.Max(idx - 1, 0);
        if (next == idx && idx != -1) return;
        var targetId = list[Math.Max(next, 0)].Id;
        await SelectCustomerAsync(targetId);
        await JS.InvokeVoidAsync("eval",
            $"document.getElementById('cari-{targetId}')?.scrollIntoView({{block:'nearest',behavior:'smooth'}});");
    }

    private async Task LoadSalesRepsAsync() => salesReps = await CustomerSvc.GetSalesRepsAsync();

    private async Task LoadCustomersAsync(bool autoSelect)
    {
        isLoadingList = true;
        StateHasChanged();
        customers = await CustomerSvc.GetCustomersAsync();
        isLoadingList = false;

        if (selectedCustomerId.HasValue && customers.Any(x => x.Id == selectedCustomerId.Value))
        { await SelectCustomerAsync(selectedCustomerId.Value); return; }

        if (autoSelect && customers.Count > 0)
        { await SelectCustomerAsync(customers[0].Id); return; }

        if (!selectedCustomerId.HasValue)
            currentCustomer = CustomerSvc.CreateDraft();
    }

    private async Task ReloadAsync()
    {
        try { await LoadSalesRepsAsync(); await LoadCustomersAsync(selectedCustomerId == null); }
        catch (Exception ex) { isLoadingList = false; message = $"Yenileme hatasi: {ex.Message}"; messageSuccess = false; }
    }

    private void CreateNewCustomer()
    {
        selectedCustomerId = null; activeTab = "general";
        currentCustomer = CustomerSvc.CreateDraft(); message = null;
    }

    private async Task SelectCustomerAsync(int id)
    {
        if (selectedCustomerId == id && currentCustomer.Id == id) return;
        isLoadingDetail = true; StateHasChanged();
        var customer = await CustomerSvc.GetCustomerByIdAsync(id);
        if (customer != null) { currentCustomer = customer; selectedCustomerId = id; activeTab = "general"; message = null; }
        isLoadingDetail = false;
    }

    private async Task ResetCurrentAsync()
    {
        message = null;
        if (currentCustomer.Id == 0) { CreateNewCustomer(); return; }
        await SelectCustomerAsync(currentCustomer.Id);
    }

    private void OpenSaveConfirm() => showSaveConfirm = true;
    private void CloseSaveConfirm() => showSaveConfirm = false;
    private async Task ConfirmSaveAsync() { showSaveConfirm = false; await SaveCurrentAsync(); }

    private async Task SaveCurrentAsync()
    {
        isSaving = true; message = null;
        var (success, resultMessage, customerId) = await CustomerSvc.SaveCustomerAsync(currentCustomer);
        isSaving = false;

        if (success)
        {
            toastIsSuccess = true; toastMessage = resultMessage; showToast = true;
            StateHasChanged(); await Task.Delay(1800); showToast = false; StateHasChanged();
            await LoadCustomersAsync(false);
            if (customerId > 0) await SelectCustomerAsync(customerId);
        }
        else { message = resultMessage; messageSuccess = false; }
    }

    private void OpenDeleteConfirm() { if (currentCustomer.Id > 0) showDeleteConfirm = true; }
    private void CloseDeleteConfirm() => showDeleteConfirm = false;

    private async Task DeleteCurrentAsync()
    {
        if (currentCustomer.Id == 0) return;
        isDeleting = true;
        var (success, resultMessage) = await CustomerSvc.DeleteCustomerAsync(currentCustomer.Id);
        isDeleting = false; showDeleteConfirm = false;
        message = resultMessage; messageSuccess = success;
        if (!success) return;
        selectedCustomerId = null; currentCustomer = CustomerSvc.CreateDraft();
        await LoadCustomersAsync(true);
    }

    private void AddContact()
    {
        currentCustomer.Contacts.Add(new CustomerContactModel { IsActive = true });
        activeTab = "contacts";
    }

    private void RemoveContact(CustomerContactModel contact) => currentCustomer.Contacts.Remove(contact);

    private void TogglePrimaryContact(CustomerContactModel target, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool v && v;
        foreach (var c in currentCustomer.Contacts) c.IsPrimary = false;
        target.IsPrimary = isChecked;
    }
}
