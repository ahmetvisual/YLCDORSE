@page "/crm/dashboard"
@using YALCINDORSE.Services
@inject TouchService TouchSvc

<div class="crm-shell">
    <div class="crm-header">
        <div>
            <h2 style="margin:0;font-size:1.3rem;font-weight:700;color:var(--yl-primary)">Dashboard & KPI</h2>
            <p style="margin:2px 0 0;font-size:0.8rem;color:var(--yl-text-light)">Satis performansi ve teklif analizi</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div style="text-align:center;padding:40px;color:var(--yl-text-light)">Yukleniyor...</div>
    }
    else
    {
        <!-- KPI Kartlari -->
        <div class="touch-kpi-row">
            <div class="touch-kpi">
                <div class="touch-kpi-label">Toplam Teklif</div>
                <div class="touch-kpi-value">@kpi.ToplamTeklif</div>
            </div>
            <div class="touch-kpi">
                <div class="touch-kpi-label">Aktif</div>
                <div class="touch-kpi-value kv-blue">@(kpi.ToplamTeklif - kpi.ClosedSayisi)</div>
            </div>
            <div class="touch-kpi">
                <div class="touch-kpi-label">Donusum</div>
                <div class="touch-kpi-value kv-green">@(kpi.ToplamTeklif > 0 ? Math.Round((decimal)kpi.OrderSayisi / kpi.ToplamTeklif * 100) : 0)%</div>
                <div class="touch-kpi-sub">@kpi.OrderSayisi siparis</div>
            </div>
            <div class="touch-kpi">
                <div class="touch-kpi-label">Toplam Temas</div>
                <div class="touch-kpi-value kv-blue">@kpi.ToplamTemas</div>
            </div>
            <div class="touch-kpi">
                <div class="touch-kpi-label">Geciken</div>
                <div class="touch-kpi-value kv-red">@kpi.GecikenTemasSayisi</div>
            </div>
            <div class="touch-kpi">
                <div class="touch-kpi-label">Hareketsiz</div>
                <div class="touch-kpi-value kv-red">@kpi.HareketsizSayisi</div>
                <div class="touch-kpi-sub">30+ gun</div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px">
            <!-- Kisi Performansi -->
            <div style="background:#fff;border:1px solid var(--yl-border);border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                <div style="font-size:0.7rem;font-weight:700;color:var(--yl-text-light);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.6px">
                    Kisi Bazinda Performans
                </div>
                @if (performances.Count == 0)
                {
                    <div style="font-size:0.78rem;color:var(--yl-text-light)">Veri yok.</div>
                }
                @foreach (var p in performances)
                {
                    var maxTemas = performances.Max(x => x.TemasSayisi);
                    var barWidth = maxTemas > 0 ? Math.Round((decimal)p.TemasSayisi / maxTemas * 100) : 0;
                    <div style="display:flex;align-items:center;gap:9px;margin-bottom:8px;padding:9px 10px;background:#f8f9fa;border-radius:8px;border:1px solid var(--yl-border)">
                        <div style="width:30px;height:30px;border-radius:50%;background:#E6F1FB;color:#185FA5;font-size:0.7rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            @GetInitials(p.FullName)
                        </div>
                        <div style="flex:1">
                            <div style="font-size:0.78rem;font-weight:600">@p.FullName</div>
                            <div style="font-size:0.7rem;color:var(--yl-text-light)">@p.TeklifSayisi teklif &middot; @p.SiparisSayisi siparis &middot; @p.TemasSayisi temas</div>
                            <div style="margin-top:5px;height:5px;background:#f0f2f5;border-radius:3px;overflow:hidden">
                                <div style="height:100%;width:@(barWidth)%;background:#185FA5;border-radius:3px"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Durum Dagilimi -->
            <div style="background:#fff;border:1px solid var(--yl-border);border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
                <div style="font-size:0.7rem;font-weight:700;color:var(--yl-text-light);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.6px">
                    Durum Dagilimi
                </div>
                @foreach (var s in statusDist)
                {
                    var maxCount = statusDist.Max(x => x.Value);
                    var barW = maxCount > 0 ? Math.Round((decimal)s.Value / maxCount * 100) : 0;
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                        <div style="font-size:0.72rem;color:var(--yl-text-light);width:65px;flex-shrink:0;text-align:right">@s.Key</div>
                        <div style="flex:1;height:8px;background:#f0f2f5;border-radius:4px;overflow:hidden">
                            <div style="height:100%;border-radius:4px;width:@(barW)%;background:@GetStatusColor(s.Key)"></div>
                        </div>
                        <div style="font-size:0.72rem;font-weight:700;min-width:28px;color:@GetStatusColor(s.Key)">@s.Value</div>
                    </div>
                }
            </div>
        </div>

        <!-- Hareketsiz Teklifler -->
        <div style="background:#fff;border:1px solid var(--yl-border);border-radius:10px;padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.04)">
            <div style="font-size:0.7rem;font-weight:700;color:var(--yl-text-light);margin-bottom:12px;text-transform:uppercase;letter-spacing:0.6px">
                Hareketsiz Teklifler (30+ Gun)
            </div>
            @if (staleQuotes.Count == 0)
            {
                <div style="font-size:0.78rem;color:var(--yl-text-light)">Hareketsiz teklif yok.</div>
            }
            @foreach (var sq in staleQuotes.Take(10))
            {
                <div style="display:flex;align-items:center;gap:9px;padding:8px 0;border-bottom:1px solid var(--yl-border)">
                    <div style="font-size:0.72rem;font-weight:700;color:#A32D2D;min-width:70px">@sq.GecenGun gun</div>
                    <div style="flex:1">
                        <span style="font-weight:700;color:#185FA5">@sq.TeklifNo</span>
                        <span style="color:var(--yl-text-light);margin-left:8px;font-size:0.72rem">@sq.Musteri</span>
                    </div>
                    <span class="yl-chip @GetPuanChip(sq.Puan)">@sq.Puan</span>
                    <span style="font-size:0.72rem;color:var(--yl-text-light);margin-left:8px">@sq.Satici</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private DashboardKpiModel kpi = new();
    private List<PersonPerformanceModel> performances = new();
    private List<TouchReminderModel> staleQuotes = new();
    private Dictionary<string, int> statusDist = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            kpi = await TouchSvc.GetDashboardKpisAsync();
            performances = await TouchSvc.GetPersonPerformanceAsync();
            staleQuotes = await TouchSvc.GetStaleTouchesAsync(30);

            statusDist = new Dictionary<string, int>
            {
                { "HOT", kpi.HotSayisi },
                { "WARM", kpi.WarmSayisi },
                { "COLD", kpi.ColdSayisi },
                { "ORDER", kpi.OrderSayisi },
                { "CLOSED", kpi.ClosedSayisi }
            };
            statusDist = statusDist.Where(x => x.Value > 0).ToDictionary(x => x.Key, x => x.Value);
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}";
        return parts.Length > 0 ? parts[0][..Math.Min(2, parts[0].Length)] : "?";
    }

    private string GetStatusColor(string status) => status switch
    {
        "HOT" => "#A32D2D",
        "WARM" => "#854F0B",
        "COLD" => "#185FA5",
        "ORDER" => "#3B6D11",
        "CLOSED" => "#D3D1C7",
        _ => "#5F5E5A"
    };

    private string GetPuanChip(string puan) => puan switch
    {
        "HOT" => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _ => "chip-draft"
    };
}
