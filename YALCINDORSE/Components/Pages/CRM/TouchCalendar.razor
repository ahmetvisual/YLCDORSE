@page "/crm/takvim"
@using YALCINDORSE.Services
@inject TouchService TouchSvc
@inject NavigationManager Nav

<div class="cal-shell">
    <!-- Toolbar -->
    <div class="cal-toolbar">
        <div class="cal-nav">
            <button class="cal-nav-btn" @onclick="PrevMonth">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:15px;height:15px;"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <h2 class="cal-month-label">@months[currentMonth] @currentYear</h2>
            <button class="cal-nav-btn" @onclick="NextMonth">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:15px;height:15px;"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <button class="cal-today-btn" @onclick="GoToday">Bugun</button>
        </div>
        <div class="cal-legend">
            <span class="cal-lg"><span class="cal-lg-dot cal-lg-touch"></span>Gorusme</span>
            <span class="cal-lg"><span class="cal-lg-dot cal-lg-planned"></span>Planli</span>
            <span class="cal-lg"><span class="cal-lg-dot cal-lg-overdue"></span>Geciken</span>
            <span class="cal-lg"><span class="cal-lg-dot cal-lg-default"></span>Gonderim</span>
        </div>
    </div>

    <!-- Calendar -->
    <div class="cal-container">
        <!-- Day Headers -->
        <div class="cal-head-row">
            @foreach (var day in dayNames)
            {
                <div class="cal-head">@day</div>
            }
        </div>

        <!-- Cells -->
        <div class="cal-body @(isLoading ? "cal-loading" : "")">
            @foreach (var cell in calendarCells)
            {
                var isToday = cell.Date == DateTime.Today;
                var isOtherMonth = cell.Date.Month != currentMonth + 1;
                var isWeekend = cell.Date.DayOfWeek == DayOfWeek.Saturday || cell.Date.DayOfWeek == DayOfWeek.Sunday;
                var cellEvents = entries.Where(e => e.Tarih.Date == cell.Date).ToList();

                <div class="cal-cell @(isOtherMonth ? "cal-other" : "") @(isToday ? "cal-today" : "") @(isWeekend && !isOtherMonth ? "cal-weekend" : "")">
                    <div class="cal-day @(isToday ? "cal-day-now" : "")">@cell.Date.Day</div>

                    <div class="cal-events">
                        @foreach (var ev in cellEvents.Take(3))
                        {
                            var cls = ev.Tip switch {
                                "OVERDUE" => "cal-ev cal-ev-overdue",
                                "PLANNED" => "cal-ev cal-ev-planned",
                                "TOUCH" => "cal-ev cal-ev-touch",
                                _ => "cal-ev cal-ev-default"
                            };
                            <div class="@cls" title="@(ev.Musteri ?? "") @(ev.TeklifNo != null ? $"({ev.TeklifNo})" : "")">
                                @ev.Baslik
                            </div>
                        }
                        @if (cellEvents.Count > 3)
                        {
                            <div class="cal-more">+@(cellEvents.Count - 3) daha</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int currentYear;
    private int currentMonth; // 0-indexed
    private bool isLoading;
    private List<CalendarEntryModel> entries = new();
    private List<CalendarCell> calendarCells = new();

    private string[] months = { "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" };
    private string[] dayNames = { "Pzt", "Sal", "Car", "Per", "Cum", "Cmt", "Paz" };

    protected override async Task OnInitializedAsync()
    {
        currentYear = DateTime.Today.Year;
        currentMonth = DateTime.Today.Month - 1;
        await LoadCalendar();
    }

    private async Task LoadCalendar()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            entries = await TouchSvc.GetCalendarEntriesAsync(currentYear, currentMonth + 1);
        }
        catch { entries = new(); }
        finally
        {
            isLoading = false;
        }
        BuildCalendarGrid();
        StateHasChanged();
    }

    private void BuildCalendarGrid()
    {
        calendarCells = new List<CalendarCell>();
        var firstDay = new DateTime(currentYear, currentMonth + 1, 1);
        var lastDay = new DateTime(currentYear, currentMonth + 1, DateTime.DaysInMonth(currentYear, currentMonth + 1));
        var startDow = ((int)firstDay.DayOfWeek + 6) % 7;

        for (int i = startDow - 1; i >= 0; i--)
            calendarCells.Add(new CalendarCell { Date = firstDay.AddDays(-(i + 1)) });

        for (int d = 1; d <= lastDay.Day; d++)
            calendarCells.Add(new CalendarCell { Date = new DateTime(currentYear, currentMonth + 1, d) });

        var totalCells = calendarCells.Count;
        var trailing = (7 - (totalCells % 7)) % 7;
        for (int t = 1; t <= trailing; t++)
            calendarCells.Add(new CalendarCell { Date = lastDay.AddDays(t) });
    }

    private async Task PrevMonth()
    {
        currentMonth--;
        if (currentMonth < 0) { currentMonth = 11; currentYear--; }
        await LoadCalendar();
    }

    private async Task NextMonth()
    {
        currentMonth++;
        if (currentMonth > 11) { currentMonth = 0; currentYear++; }
        await LoadCalendar();
    }

    private async Task GoToday()
    {
        currentYear = DateTime.Today.Year;
        currentMonth = DateTime.Today.Month - 1;
        await LoadCalendar();
    }

    private class CalendarCell
    {
        public DateTime Date { get; set; }
    }
}
