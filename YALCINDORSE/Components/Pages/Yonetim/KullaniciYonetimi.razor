@page "/yonetim/kullanicilar"
@using YALCINDORSE.Services
@inject UserService UserSvc

<div class="page-panel">
    <div class="panel-header">
        <div class="panel-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="panel-icon">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <h3>Kullanici Yonetimi</h3>
        </div>
        <button class="btn-add" @onclick="OpenAddModal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            <span>Yeni Kullanici</span>
        </button>
    </div>

    @if (message != null)
    {
        <div class="alert @(messageSuccess ? "alert-success" : "alert-danger")">
            @message
            <button class="alert-close" @onclick='() => message = null'>X</button>
        </div>
    }

    @if (isLoading)
    {
        <div class="loading-state">Yukleniyor...</div>
    }
    else if (users.Count == 0)
    {
        <div class="empty-state">Henuz kullanici bulunmuyor.</div>
    }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Kullanici Adi</th>
                        <th class="hide-mobile">E-posta</th>
                        <th class="hide-mobile">Telefon</th>
                        <th>Durum</th>
                        <th>Islemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td class="td-name">@user.FullName</td>
                            <td><code>@user.Username</code></td>
                            <td class="hide-mobile">@(user.Email ?? "-")</td>
                            <td class="hide-mobile">@(user.Phone ?? "-")</td>
                            <td>
                                <span class="badge @(user.IsActive ? "badge-active" : "badge-inactive")">
                                    @(user.IsActive ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="td-actions">
                                <button class="btn-icon btn-edit" title="Duzenle" @onclick="() => OpenEditModal(user)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </button>
                                <button class="btn-icon btn-delete" title="Sil" @onclick="() => ConfirmDelete(user)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>@(isEditing ? "Kullanici Duzenle" : "Yeni Kullanici")</h4>
                <button class="modal-close" @onclick="CloseModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-col">
                        <label>Ad Soyad *</label>
                        <input type="text" class="form-input" @bind="editUser.FullName" placeholder="Ad Soyad" />
                    </div>
                    <div class="form-col">
                        <label>Kullanici Adi *</label>
                        <input type="text" class="form-input" @bind="editUser.Username" placeholder="Kullanici adi" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-col">
                        <label>@(isEditing ? "Sifre (bos birakirsaniz degismez)" : "Sifre *")</label>
                        <input type="password" class="form-input" @bind="editUser.Password" placeholder="Sifre" />
                    </div>
                    <div class="form-col">
                        <label>E-posta</label>
                        <input type="email" class="form-input" @bind="editUser.Email" placeholder="E-posta" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-col">
                        <label>Telefon</label>
                        <input type="tel" class="form-input" @bind="editUser.Phone" placeholder="Telefon" />
                    </div>
                    <div class="form-col">
                        <label>Durum</label>
                        <div class="toggle-wrapper">
                            <label class="toggle">
                                <input type="checkbox" @bind="editUser.IsActive" />
                                <span class="toggle-slider"></span>
                            </label>
                            <span class="toggle-label">@(editUser.IsActive ? "Aktif" : "Pasif")</span>
                        </div>
                    </div>
                </div>

                @if (modalError != null)
                {
                    <div class="alert alert-danger" style="margin-top:12px;">@modalError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Iptal</button>
                <button class="btn-primary-action" @onclick="SaveUser" disabled="@isSaving">
                    @(isSaving ? "Kaydediliyor..." : "Kaydet")
                </button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirm -->
@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-panel modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>Kullanici Sil</h4>
            </div>
            <div class="modal-body">
                <p><strong>@deleteTarget?.FullName</strong> adli kullaniciyi silmek istediginize emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => showDeleteConfirm = false">Iptal</button>
                <button class="btn-danger-action" @onclick="DoDelete">Sil</button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserModel> users = new();
    private UserModel editUser = new();
    private UserModel? deleteTarget;
    private bool showModal, showDeleteConfirm, isEditing, isLoading, isSaving;
    private string? message, modalError;
    private bool messageSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try { users = await UserSvc.GetAllUsersAsync(); }
        catch (Exception ex) { message = $"Yuklenirken hata: {ex.Message}"; messageSuccess = false; }
        isLoading = false;
    }

    private void OpenAddModal()
    {
        editUser = new UserModel { IsActive = true };
        isEditing = false;
        modalError = null;
        showModal = true;
    }

    private void OpenEditModal(UserModel user)
    {
        editUser = new UserModel
        {
            Id = user.Id,
            Username = user.Username,
            FullName = user.FullName,
            Email = user.Email,
            Phone = user.Phone,
            IsActive = user.IsActive
        };
        isEditing = true;
        modalError = null;
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(editUser.FullName) || string.IsNullOrWhiteSpace(editUser.Username))
        {
            modalError = "Ad Soyad ve Kullanici Adi zorunludur";
            return;
        }
        if (!isEditing && string.IsNullOrWhiteSpace(editUser.Password))
        {
            modalError = "Sifre zorunludur";
            return;
        }

        isSaving = true;
        modalError = null;

        var (success, msg) = isEditing
            ? await UserSvc.UpdateUserAsync(editUser)
            : await UserSvc.CreateUserAsync(editUser);

        if (success)
        {
            showModal = false;
            message = msg;
            messageSuccess = true;
            await LoadUsers();
        }
        else
        {
            modalError = msg;
        }
        isSaving = false;
    }

    private void ConfirmDelete(UserModel user)
    {
        deleteTarget = user;
        showDeleteConfirm = true;
    }

    private async Task DoDelete()
    {
        if (deleteTarget == null) return;
        var (success, msg) = await UserSvc.DeleteUserAsync(deleteTarget.Id);
        showDeleteConfirm = false;
        message = msg;
        messageSuccess = success;
        if (success) await LoadUsers();
    }
}
