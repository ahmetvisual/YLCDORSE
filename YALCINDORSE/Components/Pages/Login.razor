@using YALCINDORSE.Services
@inject AuthService Auth

<div class="login-container">
    <div class="login-left">
        <div class="login-left-content">
            <img src="images/logo.svg" alt="Yalcin Trailer" class="login-hero-logo" />
            <p class="login-hero-text">Kurumsal Kaynak Planlama Sistemi</p>
        </div>
    </div>

    <div class="login-right">
        <div class="login-card">
            <h2 class="login-title">Giriş Yap</h2>
            <p class="login-subtitle">Hesabınıza giriş yaparak devam edin</p>

            <div class="login-form">
                <div class="form-group">
                    <label>Kullanıcı Adı</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <input type="text" class="form-control" @bind="username" @onkeydown="HandleKeyDown" placeholder="Kullanıcı adınızı girin" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Şifre</label>
                    <div class="input-wrapper">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input type="password" class="form-control" @bind="password" @onkeydown="HandleKeyDown" placeholder="Şifrenizi girin" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        @errorMessage
                    </div>
                }

                <button class="btn-login" @onclick="DoLogin" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Giriş yapılıyor...</span>
                    }
                    else
                    {
                        <span>Giriş Yap</span>
                    }
                </button>
            </div>

            <div class="login-footer">
                <span>YALCIN TRAILER &copy; @DateTime.Now.Year</span>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string? errorMessage;
    private bool isLoading;

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await DoLogin();
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Kullanıcı adı ve şifre gereklidir";
            return;
        }

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        var (success, message) = await Auth.LoginAsync(username, password);

        if (!success)
        {
            errorMessage = message;
        }

        isLoading = false;
    }
}
