@page "/"
@using YALCINDORSE.Services
@using Microsoft.JSInterop
@inject TouchService TouchSvc
@inject DesktopWindowService WindowService
@inject IJSRuntime JS

<div class="dash-shell">

    <div class="dash-header">
        <div></div>
        <div class="dash-header-actions">
            @{ var remindCount = (_overdue?.Count ?? 0) + (_today?.Count ?? 0); }
            <button class="dash-remind-btn" @onclick="ScrollToTimelineAsync" title="Hatirlatmalar">
                <svg class="dash-remind-bell" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                <span>HATIRLATMALAR</span>
                @if (remindCount > 0)
                {
                    <span class="dash-remind-badge is-pulse">@remindCount</span>
                }
            </button>
            <button class="dash-refresh-btn" @onclick="LoadAsync" disabled="@_loading">
                @if (_loading)
                {
                    <span>Yukleniyor...</span>
                }
                else
                {
                    <span>Yenile</span>
                }
            </button>
        </div>
    </div>

    @* === TOAST: Geciken hatirlatma uyarisi === *@
    @if (_showToast && (_overdue?.Count ?? 0) > 0)
    {
        <div class="dash-toast">
            <button class="dash-toast-close" @onclick="() => _showToast = false">&times;</button>
            <div class="dash-toast-icon">!</div>
            <div class="dash-toast-body">
                <div class="dash-toast-title">@_overdue!.Count geciken gorusme</div>
                <div class="dash-toast-text">
                    @(_overdue.First().Musteri) ve @(_overdue.Count - 1) diger teklif icin temas bekleniyor.
                </div>
                <div class="dash-toast-actions">
                    <button class="dash-toast-btn" @onclick="ScrollToTimelineAsync">GORUNTULE</button>
                    <button class="dash-toast-btn is-ghost" @onclick="() => _showToast = false">KAPAT</button>
                </div>
            </div>
        </div>
    }

    @if (_loading && _kpi is null)
    {
        <div class="dash-loading">Veriler yukleniyor...</div>
    }
    else
    {
    <div class="dash-layout">
    <div class="dash-main">
        <!-- === KPI ROW === -->
        <div class="dash-kpi-row">

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Toplam Musteri</div>
                <div class="dash-kpi-value kv-blue">@(_kpi?.MusteriSayisi ?? 0)</div>
                <div class="dash-kpi-sub">aktif kayit</div>
            </div>

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Aktif Teklif</div>
                <div class="dash-kpi-value">@AktifTeklif</div>
                <div class="dash-kpi-sub">toplam @(_kpi?.ToplamTeklif ?? 0)</div>
            </div>

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Donusum Orani</div>
                <div class="dash-kpi-value kv-green">@DonusumOraniText</div>
                <div class="dash-kpi-sub">siparis / teklif</div>
            </div>

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Onay Orani</div>
                <div class="dash-kpi-value kv-green">@OnayOraniText</div>
                <div class="dash-kpi-sub">onaylanan / cevaplanan</div>
            </div>

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Ort. Cevap Suresi</div>
                <div class="dash-kpi-value kv-orange">@OrtCevapText</div>
                <div class="dash-kpi-sub">ilk temasa kadar</div>
            </div>

            <div class="dash-kpi-card">
                <div class="dash-kpi-label">Geciken Temas</div>
                <div class="dash-kpi-value kv-red">@(_kpi?.GecikenTemasSayisi ?? 0)</div>
                <div class="dash-kpi-sub">hareketsiz @(_kpi?.HareketsizSayisi ?? 0)</div>
            </div>

        </div>

        <!-- === PIE ROW === -->
        <div class="dash-pie-row">
            @RenderPie("Durum Dagilimi", BuildDurumSlices(), _kpi?.ToplamTeklif ?? 0, "Teklif")
            @RenderPie("Puan Dagilimi", BuildPuanSlices(), PuanToplam, "Sicak/Ilik/Soguk")
            @RenderPie("Onaylatma Performansi", BuildOnaySlices(), OnayToplam, "Cevap")
        </div>

        <!-- === PANEL ROW === -->
        <div class="dash-panel-row">

            <div class="dash-panel">
                <div class="dash-panel-title">Kisi Performansi</div>
                @if (_performance is null || _performance.Count == 0)
                {
                    <div class="dash-panel-empty">Kayit bulunamadi</div>
                }
                else
                {
                    var maxTeklif = _performance.Max(p => p.TeklifSayisi);
                    if (maxTeklif == 0) maxTeklif = 1;
                    @foreach (var p in _performance.Take(6))
                    {
                        var pct = (int)Math.Round(100.0 * p.TeklifSayisi / maxTeklif);
                        <div class="dash-perf-row">
                            <div class="dash-perf-initials">@GetInitials(p.FullName)</div>
                            <div class="dash-perf-body">
                                <div class="dash-perf-name">@p.FullName</div>
                                <div class="dash-perf-meta">
                                    @p.TeklifSayisi teklif &middot; @p.TemasSayisi temas &middot; @p.SiparisSayisi siparis
                                </div>
                                <div class="dash-perf-bar">
                                    <div class="dash-perf-bar-fill" style="width:@(pct)%"></div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="dash-panel">
                <div class="dash-panel-title">Hareketsiz Teklifler (30+ gun)</div>
                @if (_stale is null || _stale.Count == 0)
                {
                    <div class="dash-panel-empty">Hareketsiz teklif yok</div>
                }
                else
                {
                    @foreach (var s in _stale.Take(10))
                    {
                        <div class="dash-stale-row">
                            <div class="dash-stale-days">@s.GecenGun gun</div>
                            <div class="dash-stale-no">@s.TeklifNo</div>
                            <div class="dash-stale-customer">@s.Musteri</div>
                            <div class="dash-stale-satici">@s.Satici</div>
                        </div>
                    }
                }
            </div>

        </div>
    </div>

    <!-- === SIDE TIMELINE === -->
    <aside class="dash-side">
        <div class="dash-timeline" id="dash-timeline">

            <div class="dash-tl-today">
                <span class="dash-tl-today-dot"></span>
                BUGUN &mdash; @DateTime.Today.ToString("d MMMM", new System.Globalization.CultureInfo("tr-TR"))
            </div>

            @* GECIKEN GORUSMELER *@
            @if (_overdue is not null && _overdue.Count > 0)
            {
                @foreach (var o in _overdue.Take(6))
                {
                    <div class="dash-tl-item dash-tl-overdue">
                        <div class="dash-tl-item-head">
                            <span class="dash-tl-icon">!</span>
                            <span class="dash-tl-title">@o.GecenGun GUN GECIKTI</span>
                        </div>
                        <div class="dash-tl-item-body">
                            <span class="dash-tl-no">@o.TeklifNo</span>
                            <span class="dash-tl-musteri">@o.Musteri</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(o.SonTemasNotu))
                        {
                            <div class="dash-tl-note">@o.SonTemasNotu</div>
                        }
                        @RenderItemActions(o.TeklifId)
                        @RenderQuickForm(o.TeklifId)
                    </div>
                }
            }

            @* BUGUNUN PLANLARI *@
            @if (_today is not null && _today.Count > 0)
            {
                @foreach (var t in _today.Take(5))
                {
                    <div class="dash-tl-item dash-tl-planned">
                        <div class="dash-tl-item-head">
                            <span class="dash-tl-icon">&#128337;</span>
                            <span class="dash-tl-title">BUGUN GORUSME</span>
                        </div>
                        <div class="dash-tl-item-body">
                            <span class="dash-tl-no">@t.TeklifNo</span>
                            <span class="dash-tl-musteri">@t.Musteri</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(t.SonTemasNotu))
                        {
                            <div class="dash-tl-note">@t.SonTemasNotu</div>
                        }
                        @RenderItemActions(t.TeklifId)
                        @RenderQuickForm(t.TeklifId)
                    </div>
                }
            }

            @* HAFTANIN PLANLARI *@
            @if (_week is not null && _week.Count > 0)
            {
                @foreach (var w in _week.Take(4))
                {
                    <div class="dash-tl-item dash-tl-upcoming">
                        <div class="dash-tl-item-head">
                            <span class="dash-tl-icon">&#9745;</span>
                            <span class="dash-tl-title">@w.PlanlananTarih.ToString("d MMMM", new System.Globalization.CultureInfo("tr-TR"))</span>
                        </div>
                        <div class="dash-tl-item-body">
                            <span class="dash-tl-no">@w.TeklifNo</span>
                            <span class="dash-tl-musteri">@w.Musteri</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(w.SonTemasNotu))
                        {
                            <div class="dash-tl-note">@w.SonTemasNotu</div>
                        }
                        @RenderItemActions(w.TeklifId)
                        @RenderQuickForm(w.TeklifId)
                    </div>
                }
            }

            @* YAPILMIS SON GORUSMELER *@
            @if (_recent is not null && _recent.Count > 0)
            {
                @foreach (var r in _recent.Take(12))
                {
                    <div class="dash-tl-item dash-tl-done">
                        <div class="dash-tl-item-head">
                            <span class="dash-tl-check">&#10003;</span>
                            <span class="dash-tl-date">@r.TemasTarihi.ToString("d MMMM", new System.Globalization.CultureInfo("tr-TR"))</span>
                            <span class="dash-tl-badge">@TemasTipiText(r.TemasTipi)</span>
                        </div>
                        <div class="dash-tl-item-body">
                            <span class="dash-tl-no">@r.TeklifNo</span>
                            <span class="dash-tl-musteri">@r.Musteri</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(r.Not))
                        {
                            <div class="dash-tl-note">@r.Not</div>
                        }
                    </div>
                }
            }

            @if ((_overdue?.Count ?? 0) == 0 && (_today?.Count ?? 0) == 0
                 && (_week?.Count ?? 0) == 0 && (_recent?.Count ?? 0) == 0)
            {
                <div class="dash-tl-empty">Kayit yok</div>
            }

        </div>
    </aside>

    </div>
    }

</div>

@code {

    // ── State ─────────────────────────────────────
    private DashboardKpiModel? _kpi;
    private List<PersonPerformanceModel>? _performance;
    private List<TouchReminderModel>? _stale;
    private List<TouchReminderModel>? _overdue;
    private List<TouchReminderModel>? _today;
    private List<TouchReminderModel>? _week;
    private List<TouchActivityModel>? _recent;
    private bool _loading;

    // Toast + quick form state
    private bool _showToast = false;
    private int? _quickFormFor = null;   // Hangi teklifId'de form acik
    private string _qfTipi = "CALL";
    private string _qfNot  = "";
    private DateTime? _qfSonraki = null;
    private bool _qfSaving = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        // Ilk yuklemede geciken varsa toast goster
        if ((_overdue?.Count ?? 0) > 0)
            _showToast = true;
    }

    // Timeline paneline scroll (header butonundan + toast'tan cagrilir)
    private async Task ScrollToTimelineAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.getElementById('dash-timeline')?.scrollIntoView({behavior:'smooth',block:'start'});");
        }
        catch { }
        _showToast = false;
    }

    // ── HIZLI AKSIYONLAR ──────────────────────────

    private void OpenQuickForm(int teklifId)
    {
        _quickFormFor = teklifId;
        _qfTipi    = "CALL";
        _qfNot     = "";
        _qfSonraki = DateTime.Today.AddDays(3);
    }

    private void CloseQuickForm()
    {
        _quickFormFor = null;
        _qfNot = "";
    }

    private async Task SaveQuickTouchAsync(int teklifId)
    {
        if (_qfSaving) return;
        _qfSaving = true;
        try
        {
            await TouchSvc.CreateTouchAsync(new TouchModel
            {
                TeklifId            = teklifId,
                RevizyonNo          = 0,
                TemasTarihi         = DateTime.Now,
                TemasTipi           = _qfTipi,
                Not                 = string.IsNullOrWhiteSpace(_qfNot) ? null : _qfNot.Trim(),
                SonrakiTemasTarihi  = _qfSonraki,
                YonetimDahilMi      = false,
            });
            CloseQuickForm();
            await LoadAsync();
        }
        catch { }
        finally { _qfSaving = false; }
    }

    private async Task<bool> ConfirmAsync(string message)
    {
        try { return await JS.InvokeAsync<bool>("confirm", message); }
        catch { return false; }
    }

    private async Task PostponeAsync(int teklifId, int days)
    {
        if (!await ConfirmAsync($"Bir sonraki temas tarihi {days} gun ertelensin mi?")) return;
        try
        {
            await TouchSvc.PostponeTouchAsync(teklifId, days);
            await LoadAsync();
        }
        catch { }
    }

    private async Task SetStatusAsync(int teklifId, string durum)
    {
        var label = durum switch
        {
            "Approved" => "ONAYLANDI",
            "Rejected" => "REDDEDILDI",
            "CLOSED"   => "KAPATILDI (listeden kalkacak)",
            _          => durum
        };
        if (!await ConfirmAsync($"Teklif durumu '{label}' olarak degistirilsin mi?")) return;
        try
        {
            await TouchSvc.UpdateQuoteStatusAsync(teklifId, durum);
            await LoadAsync();
        }
        catch { }
    }

    private async Task SetPuanAsync(int teklifId, string puan)
    {
        if (!await ConfirmAsync($"Teklif puani '{puan}' olarak degistirilsin mi?")) return;
        try
        {
            await TouchSvc.UpdateQuotePuanAsync(teklifId, puan);
            await LoadAsync();
        }
        catch { }
    }

    private void OpenQuoteDetail(int teklifId)
    {
        var p = new Dictionary<string, object> { { "QuoteId", teklifId } };
        WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.QuoteWizard>(
            "Teklif Duzenle", 860, 870, p);
    }

    // ── RENDER FRAGMENTS ──────────────────────────

    private RenderFragment RenderItemActions(int teklifId) => __builder =>
    {
        <div class="dash-tl-actions">
            <button class="dash-tl-btn is-primary" @onclick="() => OpenQuoteDetail(teklifId)">DETAY</button>
            <button class="dash-tl-btn is-success" @onclick="() => OpenQuickForm(teklifId)">+ TEMAS</button>
            <button class="dash-tl-btn" @onclick="() => PostponeAsync(teklifId, 1)">+1G</button>
        </div>
        <div class="dash-tl-actions dash-tl-actions-status">
            <button class="dash-tl-btn is-success" @onclick='() => SetStatusAsync(teklifId, "Approved")' title="Onaylandi olarak isaretle">ONAY</button>
            <button class="dash-tl-btn is-danger" @onclick='() => SetStatusAsync(teklifId, "Rejected")' title="Reddedildi olarak isaretle">RED</button>
            <button class="dash-tl-btn is-muted" @onclick='() => SetStatusAsync(teklifId, "CLOSED")' title="Kapat ve listeden kaldir">KAPAT</button>
        </div>
        <div class="dash-tl-actions dash-tl-actions-puan">
            <span class="dash-tl-puan-label">Puan:</span>
            <button class="dash-tl-puan is-puan-hot"  @onclick='() => SetPuanAsync(teklifId, "HOT")'  title="Sicak">HOT</button>
            <button class="dash-tl-puan is-puan-warm" @onclick='() => SetPuanAsync(teklifId, "WARM")' title="Ilik">WARM</button>
            <button class="dash-tl-puan is-puan-cold" @onclick='() => SetPuanAsync(teklifId, "COLD")' title="Soguk">COLD</button>
        </div>
    };

    private RenderFragment RenderQuickForm(int teklifId) => __builder =>
    {
        if (_quickFormFor != teklifId) return;

        <div class="dash-tl-quickform">
            <div class="dash-tl-quickform-row">
                <select @bind="_qfTipi">
                    <option value="CALL">Arama</option>
                    <option value="MAIL">Mail</option>
                    <option value="VISIT">Ziyaret</option>
                    <option value="MEETING">Toplanti</option>
                    <option value="NOTE">Not</option>
                </select>
                <input type="date" @bind="_qfSonraki" />
            </div>
            <textarea placeholder="Gorusme notu..." @bind="_qfNot" rows="2"></textarea>
            <div class="dash-tl-quickform-buttons">
                <button class="dash-tl-btn" @onclick="CloseQuickForm" disabled="@_qfSaving">IPTAL</button>
                <button class="dash-tl-btn is-success" @onclick="() => SaveQuickTouchAsync(teklifId)" disabled="@_qfSaving">
                    @(_qfSaving ? "KAYDEDILIYOR..." : "KAYDET")
                </button>
            </div>
        </div>
    };

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        // Her veri kaynagini izole et - biri patlasa digerleri calissin
        try { _kpi         = await TouchSvc.GetDashboardKpisAsync();     } catch { _kpi         = new DashboardKpiModel(); }
        try { _performance = await TouchSvc.GetPersonPerformanceAsync(); } catch { _performance = new List<PersonPerformanceModel>(); }
        try { _stale       = await TouchSvc.GetStaleTouchesAsync(30);    } catch { _stale       = new List<TouchReminderModel>(); }
        try { _overdue     = await TouchSvc.GetOverdueTouchesAsync();    } catch { _overdue     = new List<TouchReminderModel>(); }
        try { _today       = await TouchSvc.GetTodayTouchesAsync();      } catch { _today       = new List<TouchReminderModel>(); }
        try { _week        = await TouchSvc.GetWeekTouchesAsync();       } catch { _week        = new List<TouchReminderModel>(); }
        try { _recent      = await TouchSvc.GetRecentTouchesAsync(12);   } catch { _recent      = new List<TouchActivityModel>(); }

        _loading = false;
        StateHasChanged();
    }

    // ── Computed KPI values ───────────────────────
    private int AktifTeklif => (_kpi?.ToplamTeklif ?? 0) - (_kpi?.ClosedSayisi ?? 0) - (_kpi?.OrderSayisi ?? 0);

    private string DonusumOraniText
    {
        get
        {
            if (_kpi is null || _kpi.ToplamTeklif == 0) return "—";
            var pct = 100.0 * _kpi.OrderSayisi / _kpi.ToplamTeklif;
            return $"%{pct:F1}";
        }
    }

    private string OnayOraniText
    {
        get
        {
            if (_kpi is null) return "—";
            var toplam = _kpi.ApprovedSayisi + _kpi.RejectedSayisi;
            if (toplam == 0) return "—";
            var pct = 100.0 * _kpi.ApprovedSayisi / toplam;
            return $"%{pct:F1}";
        }
    }

    private string OrtCevapText
    {
        get
        {
            if (_kpi is null || _kpi.OrtCevapSuresiGun <= 0) return "—";
            return $"{_kpi.OrtCevapSuresiGun:F1} gun";
        }
    }

    // ── Slice data builders ───────────────────────
    private record PieSlice(string Label, int Value, string Color);

    private List<PieSlice> BuildDurumSlices()
    {
        var list = new List<PieSlice>();
        if (_kpi is null) return list;
        if (_kpi.DraftSayisi           > 0) list.Add(new("Taslak",        _kpi.DraftSayisi,           "#9CA3AF"));
        if (_kpi.SentSayisi            > 0) list.Add(new("Gonderilen",    _kpi.SentSayisi,            "#3B82F6"));
        if (_kpi.WaitingApprovalSayisi > 0) list.Add(new("Onay Bekliyor", _kpi.WaitingApprovalSayisi, "#F59E0B"));
        if (_kpi.ApprovedSayisi        > 0) list.Add(new("Onaylandi",     _kpi.ApprovedSayisi,        "#10B981"));
        if (_kpi.RejectedSayisi        > 0) list.Add(new("Reddedildi",    _kpi.RejectedSayisi,        "#EF4444"));
        if (_kpi.OrderSayisi           > 0) list.Add(new("Siparis",       _kpi.OrderSayisi,           "#059669"));
        if (_kpi.OpenSayisi            > 0) list.Add(new("Acik",          _kpi.OpenSayisi,            "#8B5CF6"));
        if (_kpi.ClosedSayisi          > 0) list.Add(new("Kapali",        _kpi.ClosedSayisi,          "#6B7280"));
        return list;
    }

    private List<PieSlice> BuildPuanSlices()
    {
        var list = new List<PieSlice>();
        if (_kpi is null) return list;
        if (_kpi.HotSayisi  > 0) list.Add(new("HOT",  _kpi.HotSayisi,  "#DC2626"));
        if (_kpi.WarmSayisi > 0) list.Add(new("WARM", _kpi.WarmSayisi, "#D97706"));
        if (_kpi.ColdSayisi > 0) list.Add(new("COLD", _kpi.ColdSayisi, "#2563EB"));
        return list;
    }

    private List<PieSlice> BuildOnaySlices()
    {
        var list = new List<PieSlice>();
        if (_kpi is null) return list;
        var onay = _kpi.ApprovedSayisi + _kpi.OrderSayisi;
        var red  = _kpi.RejectedSayisi + _kpi.ClosedSayisi;
        var bek  = _kpi.SentSayisi + _kpi.WaitingApprovalSayisi + _kpi.OpenSayisi;
        if (onay > 0) list.Add(new("Onaylandi",  onay, "#10B981"));
        if (red  > 0) list.Add(new("Reddedildi", red,  "#EF4444"));
        if (bek  > 0) list.Add(new("Beklemede",  bek,  "#F59E0B"));
        return list;
    }

    private int PuanToplam => (_kpi?.HotSayisi ?? 0) + (_kpi?.WarmSayisi ?? 0) + (_kpi?.ColdSayisi ?? 0);

    private int OnayToplam
    {
        get
        {
            if (_kpi is null) return 0;
            return (_kpi.ApprovedSayisi + _kpi.OrderSayisi)
                 + (_kpi.RejectedSayisi + _kpi.ClosedSayisi)
                 + (_kpi.SentSayisi + _kpi.WaitingApprovalSayisi + _kpi.OpenSayisi);
        }
    }

    // ── SVG Pie/Donut render ──────────────────────
    private record PieRendered(string Label, int Value, double Pct, string Color, string? Path);

    private List<PieRendered> PrepPie(List<PieSlice> slices)
    {
        var list = new List<PieRendered>();
        if (slices.Count == 0) return list;
        var total = slices.Sum(s => s.Value);
        if (total <= 0) return list;

        if (slices.Count == 1)
        {
            var s = slices[0];
            list.Add(new PieRendered(s.Label, s.Value, 100.0, s.Color, null));
            return list;
        }

        double acc = 0;
        foreach (var s in slices)
        {
            var pctDeg = 360.0 * s.Value / total;
            var pct    = 100.0 * s.Value / total;
            var path   = ArcPath(100, 100, 90, acc, acc + pctDeg);
            acc += pctDeg;
            list.Add(new PieRendered(s.Label, s.Value, pct, s.Color, path));
        }
        return list;
    }

    private RenderFragment RenderPie(string title, List<PieSlice> slices, int centerValue, string centerLabel) => __builder =>
    {
        var rendered = PrepPie(slices);

        <div class="dash-pie-card">
            <div class="dash-pie-title">@title</div>
            <div class="dash-pie-body">
                @if (rendered.Count == 0)
                {
                    <div class="dash-pie-empty">Veri yok</div>
                }
                else
                {
                    <div class="dash-pie-svg-wrap">
                        <svg class="dash-pie-svg" viewBox="0 0 200 200">
                            <defs>
                                <filter id="pieGlow-@title.GetHashCode()" x="-20%" y="-20%" width="140%" height="140%">
                                    <feGaussianBlur stdDeviation="3" result="blur" />
                                    <feMerge>
                                        <feMergeNode in="blur" />
                                        <feMergeNode in="SourceGraphic" />
                                    </feMerge>
                                </filter>
                            </defs>
                            <g class="dash-pie-group" filter="url(#pieGlow-@title.GetHashCode())">
                                @if (rendered.Count == 1)
                                {
                                    <circle cx="100" cy="100" r="90" fill="@rendered[0].Color" class="dash-pie-slice" style="--slice-delay: 0ms" />
                                }
                                else
                                {
                                    var idx = 0;
                                    @foreach (var r in rendered)
                                    {
                                        <path d="@r.Path" fill="@r.Color" stroke="#fff" stroke-width="2"
                                              class="dash-pie-slice"
                                              style="--slice-delay: @(idx * 90)ms" />
                                        idx++;
                                    }
                                }
                            </g>
                            <circle cx="100" cy="100" r="55" fill="#fff" class="dash-pie-hole" />
                        </svg>
                        <div class="dash-pie-center-text">
                            <div class="dash-pie-center-value">@centerValue</div>
                            <div class="dash-pie-center-label">@centerLabel</div>
                        </div>
                    </div>

                    <div class="dash-pie-legend">
                        @foreach (var r in rendered)
                        {
                            <div class="dash-pie-legend-item">
                                <div class="dash-pie-legend-swatch" style="background:@r.Color"></div>
                                <div class="dash-pie-legend-label">@r.Label</div>
                                <div class="dash-pie-legend-count">@r.Value</div>
                                <div class="dash-pie-legend-pct">%@r.Pct.ToString("F0")</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    };

    // ── Helpers ───────────────────────────────────
    private static string ArcPath(double cx, double cy, double r, double startDeg, double endDeg)
    {
        double s = (startDeg - 90) * Math.PI / 180.0;
        double e = (endDeg   - 90) * Math.PI / 180.0;
        double x1 = cx + r * Math.Cos(s), y1 = cy + r * Math.Sin(s);
        double x2 = cx + r * Math.Cos(e), y2 = cy + r * Math.Sin(e);
        int largeArc = (endDeg - startDeg) > 180 ? 1 : 0;
        return string.Format(System.Globalization.CultureInfo.InvariantCulture,
            "M {0} {1} L {2} {3} A {4} {4} 0 {5} 1 {6} {7} Z",
            cx, cy, x1, y1, r, largeArc, x2, y2);
    }

    private static string TemasTipiText(string tip) => tip switch
    {
        "CALL"    => "Arama",
        "MAIL"    => "Mail",
        "VISIT"   => "Ziyaret",
        "NOTE"    => "Not",
        "MEETING" => "Toplanti",
        _         => tip
    };

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}
