@page "/satis/teklif-olustur"
@using YALCINDORSE.Services
@inject QuoteService QuoteSvc
@inject QuoteAttachmentService AttachSvc
@inject QuoteDocumentService DocSvc
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject AuthService Auth
@inject DesktopWindowService WindowSvc
@inject QuoteLookupService LookupSvc
@inject ZirveService ZirveSvc
@inject ArabaslikService ArabaslikSvc
@inject LastikService LastikSvc
@implements IDisposable

<div style="display:flex;flex-direction:column;height:100vh;padding:8px 12px;box-sizing:border-box;overflow:hidden;"
     @oninput="MarkDirty" @onchange="MarkDirty">

    @* Global backdrop — herhangi bir dropdown açıkken dışarı tıklanınca kapatır.
       @onfocusout kullanmıyoruz: search input'a tıklanınca focusout dropdown'ı öldürüyordu. *@
    @if (openDropdown != null)
    {
        <div style="position:fixed;inset:0;z-index:499"
             @onclick="() => { openDropdown = null; dropdownSearchText = string.Empty; }"></div>
    }

    <div class="wizard-container">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;flex-shrink:0;">
            <h3 style="margin:0;font-size:1.05rem;font-weight:700;color:var(--yl-primary)">@(isEditMode ? $"Teklif Duzenle - {quote.TeklifNo}" : isCopyMode ? "Teklif Kopyala" : "Teklif Olustur")</h3>
            <span style="font-size:0.78rem;color:var(--yl-text-light)">@(isEditMode ? "Teklif detaylarini duzenleyin" : isCopyMode ? "Kaynak tekliften kopyalandi, degisiklikleri yapin" : "3 adimda teklif olusturun")</span>
        </div>

        <!-- Adim Gostergesi -->
        <div class="wizard-steps">
            <div class="wizard-step" @onclick="() => GoToStep(1)" style="cursor:pointer;user-select:none" title="Ana Basliklar">
                <div class="wizard-step-circle @(currentStep == 1 ? "active" : currentStep > 1 ? "completed" : "")">
                    @(currentStep > 1 ? "\u2713" : "1")
                </div>
                <span class="wizard-step-label @(currentStep == 1 ? "active" : currentStep > 1 ? "completed" : "")">Ana Basliklar</span>
            </div>
            <div class="wizard-step-line @(currentStep > 1 ? "completed" : "")"></div>
            <div class="wizard-step" @onclick="() => GoToStep(2)" style="cursor:pointer;user-select:none" title="Detay Kalemler">
                <div class="wizard-step-circle @(currentStep == 2 ? "active" : currentStep > 2 ? "completed" : "")">
                    @(currentStep > 2 ? "\u2713" : "2")
                </div>
                <span class="wizard-step-label @(currentStep == 2 ? "active" : currentStep > 2 ? "completed" : "")">Detay Kalemler</span>
            </div>
            <div class="wizard-step-line @(currentStep > 2 ? "completed" : "")"></div>
            <div class="wizard-step" @onclick="() => GoToStep(3)" style="cursor:pointer;user-select:none" title="Teslimat & Fiyat">
                <div class="wizard-step-circle @(currentStep == 3 ? "active" : currentStep > 3 ? "completed" : "")">
                    @(currentStep > 3 ? "\u2713" : "3")
                </div>
                <span class="wizard-step-label @(currentStep == 3 ? "active" : currentStep > 3 ? "completed" : "")">Teslimat & Fiyat</span>
            </div>
            <div class="wizard-step-line @(currentStep > 3 ? "completed" : "")"></div>
            <div class="wizard-step" @onclick="() => GoToStep(4)" style="cursor:pointer;user-select:none" title="Ekler & Belgeler">
                <div class="wizard-step-circle @(currentStep == 4 ? "active" : "")">4</div>
                <span class="wizard-step-label @(currentStep == 4 ? "active" : "")">Ekler & Belgeler</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="padding:10px 16px;background:#fff5f5;border:1px solid #fed7d7;border-radius:6px;color:#c53030;margin-bottom:12px;font-size:0.82rem;display:flex;align-items:center;gap:8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                @errorMessage
            </div>
        }

        <!-- ADIM 1: Ana Basliklar -->
        @if (currentStep == 1)
        {
            <div class="wizard-content fill">
                <div class="wizard-section-title tight">Teklif Bilgileri</div>
                @{
                    var satisTipiOpts = new[] { ("NewProduction","Yeni Uretim"), ("Stock","Stok"), ("SecondHand","Ikinci El") };
                    var teklifKanaliOpts = new[] { ("","— Seciniz —"), ("BAYI","Bayi"), ("ZIYARET","Ziyaret"), ("ONLINE","Online"), ("WHATSAPP","WhatsApp"), ("EMAIL","E-Mail"), ("WEB_SITESI","Web Sitesi"), ("FUAR","Fuar") };
                    var puanOpts = new[] { ("WARM","WARM"), ("HOT","HOT"), ("COLD","COLD"), ("ORDER","ORDER"), ("CLOSED","CLOSED") };
                    var dilOpts = new[] { ("TR","Turkce"), ("EN","English"), ("DE","Deutsch"), ("FR","Francais"), ("RU","Russian") };
                    var paraBirimiOpts = new[] { ("EUR","EUR"), ("USD","USD"), ("TRY","TRY"), ("GBP","GBP") };
                }
                <div class="wizard-grid2">
                    <div class="wizard-field compact">
                        <label>Teklif No</label>
                        <input type="text" placeholder="Otomatik (kaydedince)" disabled />
                    </div>
                    <div class="wizard-field compact">
                        <label>Satis Tipi</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("satisTipi")'>
                                <span>@(satisTipiOpts.FirstOrDefault(o => o.Item1 == quote.SatisTipi).Item2 ?? "Seciniz")</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "satisTipi")
                            {
                                <div class="custom-select-dropdown">
                                    @foreach (var (val, label) in satisTipiOpts)
                                    {
                                        <button class="custom-select-option @(quote.SatisTipi == val ? "selected" : "")"
                                                @onmousedown="() => { quote.SatisTipi = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    @* ── Stok / İkinci El seçilince çıkan 3 alan — tek satır, tam genişlik ── *@
                    @if (quote.SatisTipi == "Stock" || quote.SatisTipi == "SecondHand")
                    {
                        <div style="grid-column: 1 / -1; display:flex; gap:12px; align-items:flex-start; padding:4px 0 0 0; border-left:3px solid #1D4ED8; padding-left:10px; background:#f0f4ff; margin-bottom:2px;">
                            <div class="wizard-field compact" style="flex:1.3; margin-bottom:0">
                                <label style="color:#1D4ED8">Stok Kodu</label>
                                <input type="text" @bind="quote.StokKodu" placeholder="örn: ACF0047..." style="border-color:rgba(29,78,216,0.35)" />
                            </div>
                            <div class="wizard-field compact" style="flex:1.5; margin-bottom:0">
                                <label style="color:#1D4ED8">Şasi No</label>
                                <input type="text" @bind="quote.SasiNo" placeholder="Şasi numarası giriniz" style="border-color:rgba(29,78,216,0.35)" />
                            </div>
                            <div class="wizard-field compact" style="flex:0.8; margin-bottom:0">
                                <label style="color:#1D4ED8">Model Yılı</label>
                                <input type="number" @bind="quote.ModelYili" min="1990" max="2030" placeholder="2024" style="border-color:rgba(29,78,216,0.35)" />
                            </div>
                        </div>
                    }
                    <div class="wizard-field compact">
                        <label>Musteri <span class="required">*</span></label>
                        <div style="display:flex;gap:6px">
                            <div class="searchable-select" style="flex:1">
                                <input type="text" @bind="customerSearchText" @bind:event="oninput"
                                       @onfocus="OpenCustomerDropdown"
                                       placeholder="Musteri ara..." autocomplete="off" />
                                @if (showCustomerDropdown)
                                {
                                    <div class="searchable-select-dropdown">
                                        @{ var combined = GetCombinedSearch(); }
                                        @if (!combined.Any())
                                        {
                                            <div class="searchable-select-empty">Sonuc bulunamadi</div>
                                        }
                                        else
                                        {
                                            @foreach (var item in combined)
                                            {
                                                @if (!item.IsSelectable)
                                                {
                                                    <div class="searchable-select-item qw-cari-unmatched"
                                                         title="Bu resmi cari ic sistemde eslesmemis. Cari Kartlar > Resmi Cariler sekmesinden eslestirin.">
                                                        <span class="qw-badge-zrv">ZRV</span>
                                                        <span class="searchable-select-code">@item.Kod</span>
                                                        <span class="qw-cari-name">@item.Ad</span>
                                                        <span class="qw-cari-warn">eslesmemis</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button class="searchable-select-item @(quote.MusteriId == item.MusteriId ? "selected" : "")"
                                                            @onmousedown="() => SelectCariItem(item)"
                                                            @onmousedown:preventDefault>
                                                        @if (item.IsResmi)
                                                        {
                                                            <span class="qw-badge-zrv">ZRV</span>
                                                        }
                                                        <span class="searchable-select-code">@item.Kod</span>
                                                        <span class="qw-cari-name">@item.Ad</span>
                                                        @if (item.IsResmi && item.EslesmisBilgi != null)
                                                        {
                                                            <span class="qw-cari-linked">&#8594; @item.EslesmisBilgi</span>
                                                        }
                                                    </button>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn wizard-btn-primary" style="padding:5px 12px;font-size:0.8rem" @onclick="() => showQuickAdd = true">+ Yeni</button>
                            @if (quote.MusteriId > 0)
                            {
                                <button class="wizard-btn" style="padding:5px 12px;font-size:0.8rem;background:#f0f5ff;color:var(--yl-primary);border-color:rgba(59,125,221,0.35);"
                                        @onclick="OpenAddContact" title="Bu musteriye ilgili kisi ekle">+ Kisi</button>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Teklif Kanali</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("teklifKanali")'>
                                <span>@(teklifKanaliOpts.FirstOrDefault(o => o.Item1 == quote.TeklifKanali).Item2 ?? "— Seciniz —")</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "teklifKanali")
                            {
                                <div class="custom-select-dropdown">
                                    @foreach (var (val, label) in teklifKanaliOpts)
                                    {
                                        <button class="custom-select-option @(quote.TeklifKanali == val ? "selected" : "")"
                                                @onmousedown="() => { quote.TeklifKanali = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Teklif Tipi</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("teklifTipi")'>
                                    <span>@(string.IsNullOrEmpty(quote.TeklifTipi) ? "— Seciniz —" : quote.TeklifTipi)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "teklifTipi")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.TeklifTipi) ? "selected" : "")"
                                                @onmousedown="() => { quote.TeklifTipi = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in teklifTipiValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.TeklifTipi == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.TeklifTipi = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("TEKLIF_TIPI")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "TEKLIF_TIPI")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in teklifTipiValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("TEKLIF_TIPI", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("TEKLIF_TIPI")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Tip Adi</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("tipadi")'>
                                    <span>@(string.IsNullOrEmpty(quote.TipAdi) ? "— Seciniz —" : quote.TipAdi)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "tipadi")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.TipAdi) ? "selected" : "")"
                                                @onmousedown="() => { quote.TipAdi = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in tipAdiValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.TipAdi == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.TipAdi = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("TIP_ADI")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "TIP_ADI")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in tipAdiValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("TIP_ADI", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("TIP_ADI")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Aks Sayisi</label>
                        <input type="number" @bind="quote.AksSayisi" min="1" max="10" />
                    </div>
                    @* ── Lastik: TYPE + DRUM yan yana ── *@
                    <div class="wizard-field compact">
                        <label>Lastik Type</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("lastikType")'>
                                    <span>@(string.IsNullOrEmpty(quote.LastikType) ? "— Seciniz —" : quote.LastikType)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "lastikType")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.LastikType) ? "selected" : "")"
                                                @onmousedown="() => { quote.LastikType = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in lastikTypeValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.LastikType == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.LastikType = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("LASTIK_TYPE")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "LASTIK_TYPE")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in lastikTypeValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("LASTIK_TYPE", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("LASTIK_TYPE")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Lastik Drum</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("lastikDrum")'>
                                    <span>@(string.IsNullOrEmpty(quote.LastikDrum) ? "— Seciniz —" : quote.LastikDrum)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "lastikDrum")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.LastikDrum) ? "selected" : "")"
                                                @onmousedown="() => { quote.LastikDrum = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in lastikDrumValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.LastikDrum == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.LastikDrum = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("LASTIK_DRUM")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "LASTIK_DRUM")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in lastikDrumValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("LASTIK_DRUM", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("LASTIK_DRUM")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Suspansiyon</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("suspansiyon")'>
                                    <span>@(string.IsNullOrEmpty(quote.Suspansiyon) ? "— Seciniz —" : quote.Suspansiyon)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "suspansiyon")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.Suspansiyon) ? "selected" : "")"
                                                @onmousedown="() => { quote.Suspansiyon = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in suspansiyonValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.Suspansiyon == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.Suspansiyon = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("SUSPANSIYON")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "SUSPANSIYON")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in suspansiyonValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("SUSPANSIYON", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("SUSPANSIYON")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Extension</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("extension")'>
                                    <span>@(string.IsNullOrEmpty(quote.Extension) ? "— Seciniz —" : quote.Extension)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "extension")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.Extension) ? "selected" : "")"
                                                @onmousedown="() => { quote.Extension = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in extensionValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.Extension == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.Extension = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("EXTENSION")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "EXTENSION")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in extensionValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("EXTENSION", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("EXTENSION")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Gooseneck</label>
                        <div style="display:flex;gap:4px;align-items:flex-start">
                            <div class="custom-select" style="flex:1">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("gooseneck")'>
                                    <span>@(string.IsNullOrEmpty(quote.Gooseneck) ? "— Seciniz —" : quote.Gooseneck)</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "gooseneck")
                                {
                                    <div class="custom-select-dropdown">
                                        <div class="dropdown-search-wrap">
                                            <input class="dropdown-search-input" type="text" placeholder="Ara..." autocomplete="off"
                                                   value="@dropdownSearchText"
                                                   @oninput="(e) => dropdownSearchText = e.Value?.ToString() ?? string.Empty"
                                                   @onmousedown:stopPropagation @onclick:stopPropagation @onfocusout:stopPropagation />
                                        </div>
                                        <button class="custom-select-option @(string.IsNullOrEmpty(quote.Gooseneck) ? "selected" : "")"
                                                @onmousedown="() => { quote.Gooseneck = null; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>— Seciniz —</button>
                                        @foreach (var val in gooseneckValues.Where(v => string.IsNullOrEmpty(dropdownSearchText) || v.Contains(dropdownSearchText, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <button class="custom-select-option @(quote.Gooseneck == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.Gooseneck = val; openDropdown = null; dropdownSearchText = string.Empty; }" @onmousedown:preventDefault>@val</button>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="wizard-btn lookup-mgr-btn" title="Secenekleri yonet" @onclick='() => ToggleLookupManager("GOOSENECK")'>&#x229E;</button>
                        </div>
                        @if (openLookupManager == "GOOSENECK")
                        {
                            <div class="lookup-manager-panel">
                                @foreach (var v in gooseneckValues)
                                {
                                    <div class="lookup-mgr-row">
                                        <span>@v</span>
                                        <button @onclick='async () => await DeleteLookupValueAsync("GOOSENECK", v)'>&#xD7;</button>
                                    </div>
                                }
                                <div class="lookup-mgr-add">
                                    <input type="text" @bind="newLookupValue" placeholder="Yeni deger..." @bind:event="oninput" />
                                    <button @onclick='async () => await AddLookupValueAsync("GOOSENECK")'>+</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Puan</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("puan")'>
                                <span>@(string.IsNullOrEmpty(quote.Puan) ? "Seciniz" : quote.Puan)</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "puan")
                            {
                                <div class="custom-select-dropdown">
                                    @foreach (var (val, label) in puanOpts)
                                    {
                                        <button class="custom-select-option @(quote.Puan == val ? "selected" : "")"
                                                @onmousedown="() => { quote.Puan = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Temsilci</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("satici")'>
                                <span>@(salesReps.FirstOrDefault(s => s.Id == quote.SaticiId)?.FullName ?? "— Seciniz —")</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "satici")
                            {
                                <div class="custom-select-dropdown">
                                    <button class="custom-select-option @(quote.SaticiId == null ? "selected" : "")"
                                            @onmousedown="() => { quote.SaticiId = null; openDropdown = null; }" @onmousedown:preventDefault>— Seciniz —</button>
                                    @foreach (var sr in salesReps)
                                    {
                                        <button class="custom-select-option @(quote.SaticiId == sr.Id ? "selected" : "")"
                                                @onmousedown="() => { quote.SaticiId = sr.Id; openDropdown = null; }" @onmousedown:preventDefault>@sr.FullName</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Dil</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("dil")'>
                                <span>@(dilOpts.FirstOrDefault(o => o.Item1 == quote.Dil).Item2 ?? "Turkce")</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "dil")
                            {
                                <div class="custom-select-dropdown">
                                    @foreach (var (val, label) in dilOpts)
                                    {
                                        <button class="custom-select-option @(quote.Dil == val ? "selected" : "")"
                                                @onmousedown="() => { quote.Dil = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Para Birimi</label>
                        <div class="custom-select">
                            <button class="custom-select-trigger" @onclick='() => ToggleDropdown("paraBirimi")'>
                                <span>@(paraBirimiOpts.FirstOrDefault(o => o.Item1 == quote.ParaBirimi).Item2 ?? "EUR")</span>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            @if (openDropdown == "paraBirimi")
                            {
                                <div class="custom-select-dropdown">
                                    @foreach (var (val, label) in paraBirimiOpts)
                                    {
                                        <button class="custom-select-option @(quote.ParaBirimi == val ? "selected" : "")"
                                                @onmousedown="() => { quote.ParaBirimi = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="wizard-field compact">
                        <label>Talep Tarihi</label>
                        <TrDateInput Value="@quote.TalepTarihi" ValueChanged="(d) => quote.TalepTarihi = d ?? DateTime.Today" />
                    </div>
                    <div class="wizard-field compact">
                        <label>Gecerlilik Tarihi</label>
                        <TrDateInput Value="@quote.GecerlilikTarihi" ValueChanged="(d) => quote.GecerlilikTarihi = d ?? DateTime.Today.AddDays(15)" />
                    </div>
                    <div class="wizard-field compact">
                        <label>Ilgili Kisiler</label>
                        @if (contacts.Count > 0)
                        {
                            <div class="wizard-checkbox-row">
                                @foreach (var c in contacts)
                                {
                                    <label class="wizard-checkbox">
                                        <input type="checkbox" checked="@selectedContacts.Contains(c.Id)"
                                               @onchange="(e) => ToggleContact(c.Id, (bool)(e.Value ?? false))" />
                                        @c.ContactName
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="font-size:0.85rem;color:var(--yl-text-light)">Musteri secilmedi veya ilgili kisi yok</span>
                        }
                    </div>
                    <div class="wizard-field compact">
                        <label>Notlar</label>
                        <textarea @bind="quote.Notlar" placeholder="Teklif notlari..." style="min-height:36px"></textarea>
                    </div>
                </div>

            </div>
        }

        <!-- ADIM 2: Detay Kalemler -->
        @if (currentStep == 2)
        {
            <div class="wizard-content fill step2-fill">
                <div class="wizard-section-title">Teklif Kalemleri</div>
                <p style="font-size:0.8rem;color:var(--yl-text-light);margin:0 0 10px">
                    Baslik ekleyip altina kalemler ekleyin veya "Arabasliktan Ekle" ile hazir sablonlari aktarin.
                </p>
                <QuoteItemsEditor Items="quoteItems" ItemsChanged="OnQuoteItemsChanged" Dil="@quote.Dil" ParaBirimi="@quote.ParaBirimi" />
            </div>
        }

        <!-- ADIM 3: Teslimat & Fiyatlandirma -->
        @if (currentStep == 3)
        {
            <div class="wizard-content fill step3-grid">

                @* === SOL: Teslimat + Fiyat & Odeme === *@
                <div class="step3-main">

                    <!-- A. TESLIMAT BILGILERI -->
                    <div class="wizard-section-title">Teslimat</div>
                    <div class="wizard-grid3">
                        <div class="wizard-field">
                            <label>Teslimat Süresi (Hafta)</label>
                            <input type="text" @bind="quote.TeslimatHaftasi" placeholder="örn: 12-14" />
                        </div>
                        <div class="wizard-field">
                            <label>Incoterms (Teslimat Tipi)</label>
                            <select @bind="quote.TeslimatTipiKodu">
                                <option value="">— Seçiniz —</option>
                                <option value="EXW">EXW — Ex Works</option>
                                <option value="FCA">FCA — Free Carrier</option>
                                <option value="FOB">FOB — Free On Board</option>
                                <option value="CIF">CIF — Cost Insurance Freight</option>
                                <option value="CFR">CFR — Cost and Freight</option>
                                <option value="DAP">DAP — Delivered At Place</option>
                                <option value="DDP">DDP — Delivered Duty Paid</option>
                            </select>
                        </div>
                        <div class="wizard-field">
                            <label>Teslimat Yeri</label>
                            <input type="text" @bind="quote.TeslimatYeri" placeholder="örn: Adapazarı fabrika" />
                        </div>
                    </div>

                    <!-- B. TESLIMAT SARTLARI / NOTLARI -->
                    <div class="wizard-section-title" style="margin-top:10px;display:flex;align-items:center;justify-content:space-between">
                        <span>Teslimat Şartları & Notları</span>
                        <button type="button" class="wizard-btn" style="padding:4px 10px;font-size:0.74rem"
                                @onclick="ToggleTeslimatPicker">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;margin-right:3px;vertical-align:text-bottom">
                                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                            </svg>
                            TESLİMAT Şablonundan Ekle
                        </button>
                    </div>
                    <textarea class="teslimat-notlari-area" @bind="quote.TeslimatNotlari"
                              placeholder="Teslimat şartlarınızı satır satır yazın. Sağdaki butonla TESLİMAT şablonundaki hazır maddeleri buraya ekleyebilirsiniz." />

                    <!-- TESLIMAT sablon picker (overlay) -->
                    @if (showTeslimatPicker)
                    {
                        <div class="modal-overlay">
                            <div class="quick-modal-content tlpick" @onclick:stopPropagation="true">
                                <div class="modal-header">
                                    <h4>TESLİMAT Şablonu</h4>
                                    <button class="btn-close" @onclick="() => showTeslimatPicker = false">&#10005;</button>
                                </div>
                                <div class="modal-body tlpick-body">
                                    @if (teslimatTemplateItems == null)
                                    {
                                        <p style="font-size:0.85rem;color:var(--yl-text-light)">Yükleniyor...</p>
                                    }
                                    else
                                    {
                                        <input type="text" placeholder="Madde ara..." @bind="teslimatPickerSearch" @bind:event="oninput"
                                               class="tlpick-search" />
                                        @if (!FilteredTeslimatItems.Any())
                                        {
                                            <p style="font-size:0.85rem;color:var(--yl-text-light);margin:8px 0">
                                                @(string.IsNullOrEmpty(teslimatPickerSearch) ? "Henüz madde yok. Aşağıdan ekleyin." : "Eşleşen madde yok.")
                                            </p>
                                        }
                                        <div class="tlpick-list">
                                            @foreach (var dt in FilteredTeslimatItems)
                                            {
                                                <div class="tlpick-row">
                                                    <button type="button" class="tlpick-text"
                                                            @onclick="() => AppendTeslimatLine(GetDetayLocalizedText(dt))"
                                                            title="Notlara ekle">
                                                        <span class="tlpick-plus">+</span>@GetDetayLocalizedText(dt)
                                                    </button>
                                                    <button type="button" class="tlpick-tool" title="Düzenle (diller)"
                                                            @onclick="() => StartEditTeslimat(dt)">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px">
                                                            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/>
                                                        </svg>
                                                    </button>
                                                    <button type="button" class="tlpick-tool delete" title="Sil"
                                                            @onclick="() => confirmDeleteTeslimatId = dt.Id">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px">
                                                            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 01-2 2H9a2 2 0 01-2-2L5 6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                                        </svg>
                                                    </button>
                                                </div>
                                            }
                                        </div>

                                        @* + Yeni madde inline form *@
                                        <div class="tlpick-add">
                                            <span class="tlpick-add-bullet">+</span>
                                            <input type="text" placeholder="Yeni madde yaz ve Enter'a bas..."
                                                   @bind="newTeslimatText" @bind:event="oninput"
                                                   @onkeydown="OnNewTeslimatKey" />
                                            <button class="tlpick-add-confirm" type="button"
                                                    disabled="@string.IsNullOrWhiteSpace(newTeslimatText)"
                                                    @onclick="AddNewTeslimatAsync">Ekle</button>
                                        </div>
                                    }
                                </div>
                                <div style="padding:10px 14px;border-top:1px solid var(--yl-border);display:flex;justify-content:flex-end">
                                    <button class="wizard-btn" @onclick="() => showTeslimatPicker = false">Kapat</button>
                                </div>
                            </div>
                        </div>
                    }

                    @* TESLIMAT madde duzenleme popup *@
                    @if (editingTeslimatItem != null)
                    {
                        <div class="modal-overlay">
                            <div class="quick-modal-content" style="max-width:560px" @onclick:stopPropagation="true">
                                <div class="modal-header">
                                    <h4>Madde Düzenle</h4>
                                    <button class="btn-close" @onclick="() => editingTeslimatItem = null">&#10005;</button>
                                </div>
                                <div class="modal-body" style="padding:14px 16px">
                                    <div class="lang-grid wide">
                                        <label>TR <input type="text" @bind="editingTeslimatItem.SatirMetni" /></label>
                                        <label>EN <input type="text" @bind="editingTeslimatItem.SatirMetni_EN" /></label>
                                        <label>DE <input type="text" @bind="editingTeslimatItem.SatirMetni_DE" /></label>
                                        <label>FR <input type="text" @bind="editingTeslimatItem.SatirMetni_FR" /></label>
                                        <label>RO <input type="text" @bind="editingTeslimatItem.SatirMetni_RO" /></label>
                                        <label>RU <input type="text" @bind="editingTeslimatItem.SatirMetni_RU" /></label>
                                        <label>AR <input type="text" @bind="editingTeslimatItem.SatirMetni_AR" dir="rtl" /></label>
                                    </div>
                                </div>
                                <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                                    <button class="wizard-btn" @onclick="() => editingTeslimatItem = null">İptal</button>
                                    <button class="wizard-btn wizard-btn-primary" @onclick="SaveEditTeslimatAsync"
                                            disabled="@string.IsNullOrWhiteSpace(editingTeslimatItem.SatirMetni)">Kaydet</button>
                                </div>
                            </div>
                        </div>
                    }

                    @* TESLIMAT madde silme onay *@
                    @if (confirmDeleteTeslimatId.HasValue)
                    {
                        <div class="modal-overlay" @onclick="() => confirmDeleteTeslimatId = null">
                            <div class="quick-modal-content" style="max-width:380px" @onclick:stopPropagation="true">
                                <div class="modal-header"><h4>Maddeyi Sil</h4><button class="btn-close" @onclick="() => confirmDeleteTeslimatId = null">&#10005;</button></div>
                                <div class="modal-body" style="padding:16px"><p>Bu madde TESLİMAT şablonundan silinecek. Emin misiniz?</p></div>
                                <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                                    <button class="wizard-btn" @onclick="() => confirmDeleteTeslimatId = null">Vazgeç</button>
                                    <button class="wizard-btn" style="background:#fee2e2;color:#991b1b;border-color:#fecaca" @onclick="() => DeleteTeslimatAsync(confirmDeleteTeslimatId.Value)">Sil</button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- C. FIYATLANDIRMA -->
                    <div class="wizard-section-title" style="margin-top:10px">Fiyatlandırma</div>
                    <div class="wizard-grid3">
                        <div class="wizard-field">
                            <label>Toplam Tutar (@quote.ParaBirimi)</label>
                            <input type="number" step="0.01" @bind="quote.ToplamTutar" @bind:after="RecalcAll" />
                        </div>
                        <div class="wizard-field">
                            <label>İndirim %</label>
                            <input type="number" step="0.01" @bind="quote.IndirimYuzde" @bind:after="OnIndirimYuzdeChanged" />
                        </div>
                        <div class="wizard-field">
                            <label>İndirim Tutar (@quote.ParaBirimi)</label>
                            <input type="number" step="0.01" @bind="quote.IndirimTutar" @bind:after="OnIndirimTutarChanged" />
                        </div>
                    </div>

                    <!-- D. ODEME PLANI -->
                    <div class="wizard-section-title" style="margin-top:10px">Ödeme Planı</div>
                    <div class="wizard-grid3">
                        <div class="wizard-field">
                            <label>Ödeme Sistemi</label>
                            <div class="custom-select">
                                <button class="custom-select-trigger" @onclick='() => ToggleDropdown("odemeSistemi")'>
                                    <span>@(odemeSistemiOpts.FirstOrDefault(o => o.Item1 == quote.OdemeSistemi).Item2 ?? "— Seciniz —")</span>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                @if (openDropdown == "odemeSistemi")
                                {
                                    <div class="custom-select-dropdown">
                                        @foreach (var (val, label) in odemeSistemiOpts)
                                        {
                                            <button class="custom-select-option @(quote.OdemeSistemi == val ? "selected" : "")"
                                                    @onmousedown="() => { quote.OdemeSistemi = val; openDropdown = null; }" @onmousedown:preventDefault>@label</button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="wizard-field">
                            <label>Ön Ödeme %</label>
                            <input type="number" step="0.01" @bind="quote.OnOdemeYuzdesi" @bind:after="OnOnOdemeYuzdeChanged" />
                        </div>
                        <div class="wizard-field">
                            <label>Ön Ödeme Tutar (@quote.ParaBirimi)</label>
                            <input type="number" step="0.01" @bind="quote.OnOdemeTutari" @bind:after="OnOnOdemeTutarChanged" />
                        </div>
                        <div class="wizard-field">
                            <label>Bakiye Tutar (@quote.ParaBirimi)</label>
                            <input type="number" @bind="quote.BakiyeTutari" disabled style="background:#f4f6fa" />
                        </div>
                        <div class="wizard-field">
                            <label>Vade (Gün)</label>
                            <input type="number" @bind="quote.VadeGun" placeholder="örn: 30" />
                        </div>
                        <div class="wizard-field">
                            <label>İskonto Açıklama</label>
                            <input type="text" @bind="quote.IskontoAciklama" placeholder="İskonto detayları" />
                        </div>
                    </div>

                    <!-- E. VERGI -->
                    <div class="wizard-section-title" style="margin-top:10px">Vergi & Diğer</div>
                    <div class="wizard-checkbox-row">
                        <label class="wizard-checkbox"><input type="checkbox" @bind="quote.KdvDahilMi" /> KDV Dahil</label>
                        <label class="wizard-checkbox"><input type="checkbox" @bind="quote.IhracatMi" /> İhracat</label>
                        <label class="wizard-checkbox"><input type="checkbox" @bind="quote.IhracKayitliMi" /> İhraç Kayıtlı</label>
                    </div>
                </div>

                @* === SAG: Ozet karti === *@
                <aside class="step3-summary">
                    <div class="step3-summary-title">ÖZET</div>
                    <div class="summary-block">
                        <div class="summary-row">
                            <span>Toplam Tutar</span>
                            <span>@quote.ToplamTutar.ToString("N2") @quote.ParaBirimi</span>
                        </div>
                        <div class="summary-row">
                            <span>İndirim (@quote.IndirimYuzde.ToString("0.##")%)</span>
                            <span>-@quote.IndirimTutar.ToString("N2") @quote.ParaBirimi</span>
                        </div>
                        <div class="summary-row total">
                            <span>Net Tutar</span>
                            <span>@quote.NetTutar.ToString("N2") @quote.ParaBirimi</span>
                        </div>
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-block">
                        <div class="summary-row">
                            <span>Ön Ödeme (@quote.OnOdemeYuzdesi.ToString("0.##")%)</span>
                            <span>@quote.OnOdemeTutari.ToString("N2") @quote.ParaBirimi</span>
                        </div>
                        <div class="summary-row">
                            <span>Bakiye</span>
                            <span>@quote.BakiyeTutari.ToString("N2") @quote.ParaBirimi</span>
                        </div>
                        @if (quote.VadeGun.HasValue && quote.VadeGun.Value > 0)
                        {
                            <div class="summary-row" style="font-size:0.78rem;color:var(--yl-text-light)">
                                <span>Vade</span>
                                <span>@quote.VadeGun gün</span>
                            </div>
                        }
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-block">
                        <div class="summary-row" style="font-size:0.8rem;color:var(--yl-text-light)">
                            <span>Kalem Toplamı</span>
                            <span>@(quoteItems.Where(i => i.KalemTipi != "HEADER").Sum(i => i.Tutar ?? 0).ToString("N2")) @quote.ParaBirimi</span>
                        </div>
                    </div>
                </aside>
            </div>
        }

        <!-- ADIM 4: Ekler & Belgeler -->
        @if (currentStep == 4)
        {
            <div class="wizard-content fill">
                <!-- Fotograf & Teknik Cizim -->
                @if (isEditMode && quote.Id > 0)
                {
                    <div class="wizard-section-title" style="margin-top:16px">Fotograf & Teknik Cizimler</div>
                    <EklerEditor QuoteId="@quote.Id" AttachSvc="@AttachSvc" />
                }
                else
                {
                    <div style="margin-top:16px;padding:10px 14px;background:#fef9e7;border:1px solid #f9d71c;border-radius:6px;font-size:0.78rem;color:#856404;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;margin-right:6px;vertical-align:middle;">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        Fotograf ve teknik cizim yüklemek icin teklifi once kaydedin, ardindan duzenle modunda ekleyebilirsiniz.
                    </div>
                }

            </div>
        }

        <!-- Footer Navigation -->
        <div class="wizard-footer">
            <div class="wizard-footer-left">
                <button class="wizard-btn" @onclick="Cancel">Iptal</button>
            </div>
            <div class="wizard-footer-right">
                @if (currentStep < 4)
                {
                    <button class="wizard-btn wizard-btn-save-progress" @onclick="SaveProgress" disabled="@isSaving"
                            title="Suankini kaydet, pencerede kalmaya devam et">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             style="width:13px;height:13px;margin-right:4px;vertical-align:text-bottom;">
                            <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                        </svg>
                        @(isSaving && !showConfirmDialog ? "Kaydediliyor..." : "Kaydet")
                    </button>
                }
                @if (currentStep > 1)
                {
                    <button class="wizard-btn" @onclick="PrevStep">Geri</button>
                }
                @if (currentStep < 4)
                {
                    <button class="wizard-btn wizard-btn-primary" @onclick="NextStep">Ileri</button>
                }
                @if (currentStep == 4)
                {
                    <button class="wizard-btn" @onclick="SaveDraftConfirm" disabled="@isSaving">@(isEditMode ? "Guncelle" : "Taslak Kaydet")</button>
                    <button class="wizard-btn wizard-btn-success" @onclick="SaveAndSendConfirm" disabled="@isSaving">
                        @(isSaving ? "Kaydediliyor..." : isEditMode ? "Guncelle ve Gonder" : "Kaydet ve Gonder")
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Kaydedilmemis Degisiklik Uyarisi -->
    @if (showUnsavedDialog)
    {
        <div class="modal-overlay" @onclick="() => showUnsavedDialog = false">
            <div class="quick-modal-content" style="max-width:440px" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4 style="display:flex;align-items:center;gap:6px;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;">
                            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                        Kaydedilmemis Degisiklikler
                    </h4>
                    <button class="btn-close" @onclick="() => showUnsavedDialog = false">&#10005;</button>
                </div>
                <div class="modal-body" style="padding:16px">
                    <p style="margin:0 0 6px;font-size:0.88rem">
                        Bu teklif uzerinde henuz kaydedilmemis degisiklikler var.
                    </p>
                    <p style="margin:0;font-size:0.8rem;color:var(--yl-text-light)">
                        Cikmadan once kaydetmek ister misiniz?
                    </p>
                </div>
                <div style="display:flex;justify-content:flex-end;gap:8px;padding:12px 16px;border-top:1px solid var(--yl-border)">
                    <button class="wizard-btn" @onclick="() => showUnsavedDialog = false" disabled="@isSaving">Vazgec</button>
                    <button class="wizard-btn" style="background:#fee2e2;color:#991b1b;border-color:#fecaca" @onclick="DiscardAndClose" disabled="@isSaving">
                        Kaydetmeden Cik
                    </button>
                    <button class="wizard-btn wizard-btn-success" @onclick="SaveAndCloseFromDialog" disabled="@isSaving">
                        @(isSaving ? "Kaydediliyor..." : "Kaydet ve Cik")
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Onay Dialogu -->
    @if (showConfirmDialog)
    {
        <div class="modal-overlay" @onclick="() => showConfirmDialog = false">
            <div class="quick-modal-content" style="max-width:400px" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>@(pendingDurum == "Sent" ? (isEditMode ? "Guncelle ve Gonder" : "Kaydet ve Gonder") : (isEditMode ? "Guncelle" : "Taslak Kaydet"))</h4>
                    <button class="btn-close" @onclick="() => showConfirmDialog = false">&#10005;</button>
                </div>
                <div class="modal-body" style="padding:16px">
                    <p style="margin:0 0 6px;font-size:0.88rem">
                        @(pendingDurum == "Sent"
                            ? "Teklif kaydedilip gonderildi olarak isaretlenecek."
                            : "Teklif taslak olarak kaydedilecek.")
                    </p>
                    <p style="margin:0;font-size:0.8rem;color:var(--yl-text-light)">Onayliyor musunuz?</p>
                </div>
                <div style="display:flex;justify-content:flex-end;gap:8px;padding:12px 16px;border-top:1px solid var(--yl-border)">
                    <button class="wizard-btn" @onclick="() => showConfirmDialog = false">Vazgec</button>
                    <button class="wizard-btn wizard-btn-success" @onclick="ConfirmSaveAsync" disabled="@isSaving">
                        @(isSaving ? "Kaydediliyor..." : "Evet, Kaydet")
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Quick Add Modal -->
    @if (showQuickAdd)
    {
        <div class="modal-overlay">
            <div class="quick-modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Hizli Musteri Ekle</h4>
                    <button class="btn-close" @onclick="() => showQuickAdd = false">&#10005;</button>
                </div>
                <div class="modal-body">
                    <div class="wizard-field">
                        <label>Musteri Unvani <span class="required">*</span></label>
                        <input type="text" @bind="quickAddTitle" placeholder="Firma adi" />
                    </div>
                    <div class="wizard-field">
                        <label>Ulke</label>
                        <input type="text" @bind="quickAddCountry" placeholder="TR" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="wizard-btn" @onclick="() => showQuickAdd = false">Iptal</button>
                    <button class="wizard-btn wizard-btn-primary" @onclick="QuickAddCustomer">Kaydet</button>
                </div>
            </div>
        </div>
    }

    <!-- Quick Add Ilgili Kisi Modal -->
    @if (showQuickAddContact)
    {
        <div class="modal-overlay">
            <div class="quick-modal-content" style="max-width:520px" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Ilgili Kisi Ekle</h4>
                    <button class="btn-close" @onclick="CloseAddContact">&#10005;</button>
                </div>
                <div class="modal-body" style="padding:14px 16px">
                    <div class="wizard-grid2">
                        <div class="wizard-field compact">
                            <label>Ad Soyad <span class="required">*</span></label>
                            <input type="text" @bind="quickContact.ContactName" placeholder="Ornek: Ahmet Yilmaz" />
                        </div>
                        <div class="wizard-field compact">
                            <label>Unvan / Pozisyon</label>
                            <input type="text" @bind="quickContact.ContactTitle" placeholder="Satin Alma Mudur" />
                        </div>
                        <div class="wizard-field compact">
                            <label>Telefon</label>
                            <input type="text" @bind="quickContact.Phone" placeholder="+90 ..." />
                        </div>
                        <div class="wizard-field compact">
                            <label>Cep</label>
                            <input type="text" @bind="quickContact.Mobile" placeholder="+90 5xx ..." />
                        </div>
                        <div class="wizard-field compact">
                            <label>E-posta</label>
                            <input type="email" @bind="quickContact.Email" placeholder="ad@firma.com" />
                        </div>
                        <div class="wizard-field compact">
                            <label>Departman</label>
                            <input type="text" @bind="quickContact.Department" placeholder="Satin Alma" />
                        </div>
                    </div>
                    <label style="display:flex;align-items:center;gap:6px;font-size:0.82rem;margin-top:6px;cursor:pointer">
                        <input type="checkbox" @bind="quickContact.IsPrimary" />
                        <span>Birincil ilgili kisi olarak isaretle</span>
                    </label>
                </div>
                <div class="modal-footer">
                    <button class="wizard-btn" @onclick="CloseAddContact" disabled="@savingQuickContact">Iptal</button>
                    <button class="wizard-btn wizard-btn-primary" @onclick="SaveQuickContact"
                            disabled="@(savingQuickContact || string.IsNullOrWhiteSpace(quickContact.ContactName))">
                        @(savingQuickContact ? "Kaydediliyor..." : "Kaydet")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@* === TOAST OVERLAY === *@
@if (showToast)
{
    <div class="toast-overlay">
        <div class="toast-card">
            @if (toastIsSuccess)
            {
                <div class="toast-icon-success">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" opacity="0.15" fill="#059669" stroke="none"/><path class="check-path" d="M7 13l3 3 7-7"/></svg>
                </div>
                <div class="toast-title success">Basarili!</div>
            }
            else
            {
                <div class="toast-icon-error">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <div class="toast-title error">Hata!</div>
            }
            <div class="toast-message">@toastMessage</div>
        </div>
    </div>
}

@code {
    private int currentStep = 1;
    private QuoteModel quote = new();
    private List<QuoteItemModel> quoteItems = new();
    private List<CustomerListItemModel> customers = new();
    private List<CustomerContactModel> contacts = new();
    private List<SalesRepOption> salesReps = new();
    private List<int> selectedContacts = new();
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private bool showToast;
    private bool toastIsSuccess;
    private string toastMessage = "";

    // Customer search
    private string customerSearchText = "";
    private bool showCustomerDropdown = false;
    private List<ResmiCariListItemModel> resmiCariler = new();

    // Edit mode
    [Parameter] public int QuoteId { get; set; }
    [Parameter] public int CopyFromQuoteId { get; set; }
    // QuoteId parametresi 0 olsa bile ara-kaydetten sonra quote.Id > 0 olur:
    // sonraki kayitlar dogru sekilde guncelleme olarak gitsin
    private bool isEditMode => QuoteId > 0 || quote.Id > 0;
    private bool isCopyMode => CopyFromQuoteId > 0 && QuoteId == 0 && quote.Id == 0;

    // Sabit secim listesi (birden fazla adimda kullanilir)
    private static readonly (string, string)[] odemeSistemiOpts =
        { ("", "— Seciniz —"), ("PESIN", "Pesin"), ("VADELI", "Vadeli"), ("KARTI", "Karti") };

    // Onay dialogu
    private bool showConfirmDialog = false;
    private string pendingDurum = "";

    // Dirty / kaydedilmemis degisiklik takibi
    private bool isDirty = false;
    private bool isLoaded = false;          // ilk yukleme bittikten sonra true; yukleme @oninput'leri dirty saymasin
    private bool showUnsavedDialog = false; // X tiklayinca veya Iptal'de dirty ise gosterilir
    private bool guardRegistered = false;

    // Custom dropdown state
    private string? openDropdown;
    private string dropdownSearchText = "";
    private void ToggleDropdown(string name)
    {
        openDropdown = openDropdown == name ? null : name;
        dropdownSearchText = "";
    }
    private void CloseDropdown(string name)
    {
        if (openDropdown == name) { openDropdown = null; dropdownSearchText = ""; }
    }

    // Lookup degerleri (dinamik dropdownlar)
    private List<string> teklifTipiValues  = new();
    private List<string> tipAdiValues      = new();
    private List<string> lastikTypeValues  = new();
    private List<string> lastikDrumValues  = new();
    private List<string> suspansiyonValues = new();
    private List<string> extensionValues   = new();
    private List<string> gooseneckValues   = new();

    // Lastik katalogu (Faz 2) — Marka/Model/Ebat/LI/Hiz; quote.Lastik string olarak kaydedilir.
    private List<LastikKatalogModel> lastikKatalog = new();
    private string lastikSearchText = string.Empty;
    private LastikKatalogModel newLastik = new();

    // Lookup manager UI
    private string? openLookupManager;
    private string newLookupValue = "";

    // Quick add
    private bool showQuickAdd;
    private string quickAddTitle = "";
    private string quickAddCountry = "TR";

    // Hizli Ilgili Kisi ekleme
    private bool showQuickAddContact;
    private CustomerContactModel quickContact = new();
    private bool savingQuickContact;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            customers = await CustomerSvc.GetCustomersAsync();
            salesReps = await CustomerSvc.GetSalesRepsAsync();
            try { resmiCariler = await ZirveSvc.GetResmiCarilerAsync(); } catch { }
            teklifTipiValues  = await LookupSvc.GetValuesAsync("TEKLIF_TIPI");
            tipAdiValues      = await LookupSvc.GetValuesAsync("TIP_ADI");
            lastikTypeValues  = await LookupSvc.GetValuesAsync("LASTIK_TYPE");
            lastikDrumValues  = await LookupSvc.GetValuesAsync("LASTIK_DRUM");
            suspansiyonValues = await LookupSvc.GetValuesAsync("SUSPANSIYON");
            extensionValues   = await LookupSvc.GetValuesAsync("EXTENSION");
            gooseneckValues   = await LookupSvc.GetValuesAsync("GOOSENECK");
            try { lastikKatalog = await LastikSvc.GetAllAsync(onlyActive: true); } catch { }
        }
        catch { }

        if (QuoteId > 0)
        {
            // Edit mode - mevcut teklifi yukle
            try
            {
                var existing = await QuoteSvc.GetQuoteByIdAsync(QuoteId);
                if (existing != null)
                {
                    quote = existing;
                    quoteItems = await QuoteSvc.GetQuoteItemsAsync(QuoteId);

                    // Musteri arama alanini doldur
                    var customer = customers.FirstOrDefault(c => c.Id == quote.MusteriId);
                    if (customer != null)
                        customerSearchText = $"{customer.CustomerCode} - {customer.Title}";

                    // Ilgili kisileri yukle
                    await OnCustomerChanged();
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Teklif yuklenemedi: {ex.Message}";
            }
        }
        else if (CopyFromQuoteId > 0)
        {
            // Copy mode - kaynak teklifi yukle ama yeni teklif olarak ac
            try
            {
                var source = await QuoteSvc.GetQuoteByIdAsync(CopyFromQuoteId);
                if (source != null)
                {
                    quote = source;
                    quote.Id = 0;
                    quote.TeklifNo = "";
                    quote.Durum = "Draft";
                    quote.RevizyonNo = 0;
                    quote.TalepTarihi = DateTime.Today;
                    quote.GecerlilikTarihi = AddBusinessDays(DateTime.Today, 15);

                    // Kalemleri de yukle (Id sifirla)
                    quoteItems = await QuoteSvc.GetQuoteItemsAsync(CopyFromQuoteId);
                    foreach (var item in quoteItems)
                    {
                        item.Id = 0;
                        item.TeklifId = 0;
                    }

                    // Musteri arama alanini doldur
                    var customer = customers.FirstOrDefault(c => c.Id == quote.MusteriId);
                    if (customer != null)
                        customerSearchText = $"{customer.CustomerCode} - {customer.Title}";

                    await OnCustomerChanged();
                    successMessage = "Kaynak teklif yuklendi. Degisiklikleri yapin ve kaydedin.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Kaynak teklif yuklenemedi: {ex.Message}";
            }
        }
        else
        {
            // Yeni teklif defaults
            quote.TalepTarihi = DateTime.Today;
            quote.GecerlilikTarihi = AddBusinessDays(DateTime.Today, 15);
        }

        // Yukleme tamamlandi: bundan sonraki @oninput / @onchange "dirty" sayilsin
        isLoaded = true;
        isDirty = false;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !guardRegistered)
        {
            // Pencerenin X butonuna basildiginda kaydedilmemis degisiklik varsa
            // pencereyi kapatmayi engelle ve dialog'u goster
            WindowSvc.RegisterCloseGuard<QuoteWizard>(
                shouldBlock: () => isDirty,
                onBlocked: async () =>
                {
                    await InvokeAsync(() =>
                    {
                        showUnsavedDialog = true;
                        StateHasChanged();
                    });
                });
            guardRegistered = true;
        }
    }

    public void Dispose()
    {
        if (guardRegistered)
        {
            WindowSvc.UnregisterCloseGuard<QuoteWizard>();
            guardRegistered = false;
        }
    }

    private void MarkDirty()
    {
        if (isLoaded) isDirty = true;
    }

    private void OnQuoteItemsChanged(List<QuoteItemModel> items)
    {
        quoteItems = items;
        MarkDirty();
    }

    private DateTime AddBusinessDays(DateTime start, int days)
    {
        var current = start;
        while (days > 0)
        {
            current = current.AddDays(1);
            if (current.DayOfWeek != DayOfWeek.Saturday && current.DayOfWeek != DayOfWeek.Sunday)
                days--;
        }
        return current;
    }

    // ── Unified customer search model ────────────
    private record CariSearchItem(
        string Kod,
        string Ad,
        bool IsResmi,
        int? MusteriId,       // null = unmatched resmi cari
        string? EslesmisBilgi // matched resmi cari: linked customer name
    )
    {
        public bool IsSelectable => MusteriId.HasValue && MusteriId > 0;
    }

    private List<CariSearchItem> GetCombinedSearch()
    {
        var q = customerSearchText.Trim().ToLowerInvariant();
        var result = new List<CariSearchItem>();

        // İç cariler
        var internalFiltered = string.IsNullOrWhiteSpace(q)
            ? customers
            : customers.Where(c =>
                (c.Title?.ToLowerInvariant().Contains(q) == true) ||
                (c.CustomerCode?.ToLowerInvariant().Contains(q) == true)).ToList();
        foreach (var c in internalFiltered)
            result.Add(new CariSearchItem(c.CustomerCode, c.Title, false, c.Id, null));

        // Resmi cariler (Zirve) — vergi no ile de arama yapılabilir
        var resmiFiltered = string.IsNullOrWhiteSpace(q)
            ? resmiCariler
            : resmiCariler.Where(r =>
                r.CariAdi.ToLowerInvariant().Contains(q) ||
                r.HesapKodu.ToLowerInvariant().Contains(q) ||
                (r.VergiNo?.ToLowerInvariant().Contains(q) == true)).ToList();
        foreach (var r in resmiFiltered)
            result.Add(new CariSearchItem(
                r.HesapKodu,
                r.CariAdi,
                IsResmi: true,
                MusteriId: r.EslesmisCariId,
                EslesmisBilgi: r.EslesmisCariAdi));

        return result.Take(60).ToList();
    }

    private async Task SelectCariItem(CariSearchItem item)
    {
        if (!item.IsSelectable) return;
        quote.MusteriId = item.MusteriId!.Value;
        customerSearchText = item.IsResmi
            ? $"{item.Kod} — {item.Ad}"
            : $"{item.Kod} - {item.Ad}";
        showCustomerDropdown = false;
        errorMessage = null; successMessage = null;
        await OnCustomerChanged();
    }

    // Eski metod — geriye dönük uyumluluk için korundu
    private async Task SelectCustomer(CustomerListItemModel c)
    {
        quote.MusteriId = c.Id;
        customerSearchText = $"{c.CustomerCode} - {c.Title}";
        showCustomerDropdown = false;
        errorMessage = null; successMessage = null;
        await OnCustomerChanged();
    }

    private void OpenCustomerDropdown() => showCustomerDropdown = true;

    private void CloseCustomerDropdown()
    {
        _ = Task.Delay(200).ContinueWith(_ => InvokeAsync(() => { showCustomerDropdown = false; StateHasChanged(); }));
    }

    private async Task OnCustomerChanged()
    {
        contacts.Clear();
        selectedContacts.Clear();

        if (quote.MusteriId > 0)
        {
            try
            {
                var customer = await CustomerSvc.GetCustomerByIdAsync(quote.MusteriId);
                if (customer != null)
                {
                    contacts = customer.Contacts.Where(c => c.IsActive).ToList();

                    // Default SalesRep musteri kartindan
                    if (customer.SalesRepId.HasValue && customer.SalesRepId > 0)
                        quote.SaticiId = customer.SalesRepId;

                    // Primary contact otomatik sec
                    var primary = contacts.FirstOrDefault(c => c.IsPrimary);
                    if (primary != null)
                    {
                        selectedContacts.Add(primary.Id);
                        quote.IlgiliKisiId = primary.Id;
                    }
                }
            }
            catch { }
        }
    }

    private void ToggleContact(int contactId, bool isChecked)
    {
        if (isChecked && !selectedContacts.Contains(contactId))
            selectedContacts.Add(contactId);
        else if (!isChecked)
            selectedContacts.Remove(contactId);

        quote.IlgiliKisiId = selectedContacts.FirstOrDefault();
    }

    private void CalculateNet()
    {
        quote.IndirimTutar = Math.Round(quote.ToplamTutar * quote.IndirimYuzde / 100, 2);
        quote.NetTutar = quote.ToplamTutar - quote.IndirimTutar;
    }

    /// <summary>Tum hesabi yeniden yapar: indirim/net + on odeme/bakiye.</summary>
    private void RecalcAll()
    {
        CalculateNet();
        RecalcOnOdeme();
    }

    /// <summary>Yuzdeden tutar hesaplama (indirim).</summary>
    private void OnIndirimYuzdeChanged()
    {
        quote.IndirimTutar = Math.Round(quote.ToplamTutar * quote.IndirimYuzde / 100, 2);
        quote.NetTutar = quote.ToplamTutar - quote.IndirimTutar;
        RecalcOnOdeme();
    }

    /// <summary>Tutardan yuzde hesaplama (indirim).</summary>
    private void OnIndirimTutarChanged()
    {
        if (quote.ToplamTutar > 0)
            quote.IndirimYuzde = Math.Round(quote.IndirimTutar / quote.ToplamTutar * 100, 4);
        else
            quote.IndirimYuzde = 0;
        quote.NetTutar = quote.ToplamTutar - quote.IndirimTutar;
        RecalcOnOdeme();
    }

    /// <summary>NetTutar bazli on odeme + bakiye hesabi (yuzdeden).</summary>
    private void OnOnOdemeYuzdeChanged()
    {
        quote.OnOdemeTutari = Math.Round(quote.NetTutar * quote.OnOdemeYuzdesi / 100, 2);
        quote.BakiyeTutari = quote.NetTutar - quote.OnOdemeTutari;
    }

    /// <summary>NetTutar bazli yuzde + bakiye hesabi (tutardan).</summary>
    private void OnOnOdemeTutarChanged()
    {
        if (quote.NetTutar > 0)
            quote.OnOdemeYuzdesi = Math.Round(quote.OnOdemeTutari / quote.NetTutar * 100, 4);
        else
            quote.OnOdemeYuzdesi = 0;
        quote.BakiyeTutari = quote.NetTutar - quote.OnOdemeTutari;
    }

    /// <summary>NetTutar degisince on odeme yuzdesini koruyup tutari + bakiyeyi hesapla.</summary>
    private void RecalcOnOdeme()
    {
        quote.OnOdemeTutari = Math.Round(quote.NetTutar * quote.OnOdemeYuzdesi / 100, 2);
        quote.BakiyeTutari = quote.NetTutar - quote.OnOdemeTutari;
    }

