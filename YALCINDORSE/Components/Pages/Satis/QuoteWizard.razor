    private void OpenAddContact()
    {
        if (quote.MusteriId <= 0) return;
        quickContact = new CustomerContactModel { CustomerId = quote.MusteriId, IsActive = true };
        showQuickAddContact = true;
    }

    private void CloseAddContact()
    {
        showQuickAddContact = false;
        quickContact = new CustomerContactModel();
    }

    private async Task SaveQuickContact()
    {
        if (savingQuickContact) return;
        if (quote.MusteriId <= 0 || string.IsNullOrWhiteSpace(quickContact.ContactName)) return;

        savingQuickContact = true;
        try
        {
            await CustomerSvc.AddContactAsync(quote.MusteriId, quickContact);

            // Ilgili kisiler listesini guncelle: yeni kisiyi push et (musteri reload etmeden)
            // Eger primary olarak isaretlendiyse, mevcutlerdeki primary'leri pasiflestir
            if (quickContact.IsPrimary)
                foreach (var c in contacts) c.IsPrimary = false;
            contacts.Add(quickContact);
            if (quickContact.Id > 0 && !selectedContacts.Contains(quickContact.Id))
                selectedContacts.Add(quickContact.Id);

            toastIsSuccess = true;
            toastMessage = "Ilgili kisi eklendi.";
            showToast = true;
            showQuickAddContact = false;
            quickContact = new CustomerContactModel();
            MarkDirty();
            StateHasChanged();
            await Task.Delay(1200);
            showToast = false;
        }
        catch (Exception ex)
        {
            toastIsSuccess = false;
            toastMessage = ex.Message;
            showToast = true;
            StateHasChanged();
            await Task.Delay(2000);
            showToast = false;
        }
        finally
        {
            savingQuickContact = false;
        }
    }
