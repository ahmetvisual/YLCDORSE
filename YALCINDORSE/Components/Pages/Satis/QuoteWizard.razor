    private bool showTeslimatPicker = false;
    private string teslimatPickerSearch = "";
    private List<ArabaslikDetayModel>? teslimatTemplateItems;
    private int? teslimatGrupId;  // TESLIMAT grubunun Id'si — yoksa ilk eklemede olusturulur

    // CRUD state
    private string newTeslimatText = "";
    private ArabaslikDetayModel? editingTeslimatItem;
    private int? confirmDeleteTeslimatId;

    private async Task ToggleTeslimatPicker()
    {
        showTeslimatPicker = !showTeslimatPicker;
        if (showTeslimatPicker && teslimatTemplateItems == null)
        {
            await LoadTeslimatTemplateAsync();
        }
    }

    private async Task LoadTeslimatTemplateAsync()
    {
        try
        {
            var gruplar = await ArabaslikSvc.GetGruplarAsync();
            var teslimatGrup = gruplar.FirstOrDefault(g =>
                string.Equals(g.GrupAdi, "TESLİMAT", StringComparison.OrdinalIgnoreCase) ||
                string.Equals(g.GrupAdi, "TESLIMAT", StringComparison.OrdinalIgnoreCase));
            if (teslimatGrup != null)
            {
                teslimatGrupId = teslimatGrup.Id;
                teslimatTemplateItems = await ArabaslikSvc.GetDetaylarAsync(teslimatGrup.Id);
            }
            else
            {
                teslimatGrupId = null;
                teslimatTemplateItems = new();
            }
        }
        catch { teslimatTemplateItems = new(); }
    }

    /// <summary>TESLIMAT grubu yoksa olustur, Id'sini doner.</summary>
    private async Task<int> EnsureTeslimatGrupAsync()
    {
        if (teslimatGrupId.HasValue && teslimatGrupId.Value > 0) return teslimatGrupId.Value;
        var grup = new ArabaslikGrupModel
        {
            GrupAdi = "TESLİMAT",
            TablTipi = 2,
            SortOrder = 110,
            IsActive = true,
        };
        await ArabaslikSvc.SaveGrupAsync(grup);
        teslimatGrupId = grup.Id;
        return grup.Id;
    }

    private async Task OnNewTeslimatKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddNewTeslimatAsync();
        else if (e.Key == "Escape") newTeslimatText = "";
    }

    private async Task AddNewTeslimatAsync()
    {
        if (string.IsNullOrWhiteSpace(newTeslimatText)) return;
        try
        {
            var grupId = await EnsureTeslimatGrupAsync();
            teslimatTemplateItems ??= new();
            var nextSort = (teslimatTemplateItems.Count > 0 ? teslimatTemplateItems.Max(x => x.SortOrder) : 0) + 10;
            var d = new ArabaslikDetayModel
            {
                GrupId = grupId,
                SatirMetni = newTeslimatText.Trim(),
                SortOrder = nextSort,
            };
            await ArabaslikSvc.AddDetayAsync(d);
            teslimatTemplateItems.Add(d);
            newTeslimatText = "";
        }
        catch { }
    }

    private void StartEditTeslimat(ArabaslikDetayModel d)
    {
        editingTeslimatItem = new ArabaslikDetayModel
        {
            Id = d.Id, GrupId = d.GrupId,
            SatirMetni = d.SatirMetni,
            SatirMetni_EN = d.SatirMetni_EN, SatirMetni_FR = d.SatirMetni_FR,
            SatirMetni_DE = d.SatirMetni_DE, SatirMetni_RO = d.SatirMetni_RO,
            SatirMetni_AR = d.SatirMetni_AR, SatirMetni_RU = d.SatirMetni_RU,
            Fiyat = d.Fiyat, ParaBirimi = d.ParaBirimi, SortOrder = d.SortOrder,
        };
    }

    private async Task SaveEditTeslimatAsync()
    {
        if (editingTeslimatItem == null || string.IsNullOrWhiteSpace(editingTeslimatItem.SatirMetni)) return;
        try
        {
            await ArabaslikSvc.UpdateDetayAsync(editingTeslimatItem);
            if (teslimatTemplateItems != null)
            {
                var idx = teslimatTemplateItems.FindIndex(x => x.Id == editingTeslimatItem.Id);
                if (idx >= 0) teslimatTemplateItems[idx] = editingTeslimatItem;
            }
        }
        catch { }
        editingTeslimatItem = null;
    }

    private async Task DeleteTeslimatAsync(int detayId)
    {
        try
        {
            await ArabaslikSvc.DeleteDetayAsync(detayId);
            teslimatTemplateItems?.RemoveAll(x => x.Id == detayId);
        }
        catch { }
        confirmDeleteTeslimatId = null;
    }

    private List<ArabaslikDetayModel> FilteredTeslimatItems
    {
        get
        {
            if (teslimatTemplateItems == null) return new();
            if (string.IsNullOrWhiteSpace(teslimatPickerSearch)) return teslimatTemplateItems;
            var q = teslimatPickerSearch.Trim();
            return teslimatTemplateItems.Where(d =>
                (d.SatirMetni ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (d.SatirMetni_EN ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }
    }

    private string GetDetayLocalizedText(ArabaslikDetayModel d) => quote.Dil switch
    {
        "EN" when !string.IsNullOrEmpty(d.SatirMetni_EN) => d.SatirMetni_EN,
        "DE" when !string.IsNullOrEmpty(d.SatirMetni_DE) => d.SatirMetni_DE,
        "FR" when !string.IsNullOrEmpty(d.SatirMetni_FR) => d.SatirMetni_FR,
        "RU" when !string.IsNullOrEmpty(d.SatirMetni_RU) => d.SatirMetni_RU,
        "RO" when !string.IsNullOrEmpty(d.SatirMetni_RO) => d.SatirMetni_RO,
        "AR" when !string.IsNullOrEmpty(d.SatirMetni_AR) => d.SatirMetni_AR,
        _ => d.SatirMetni ?? ""
    };

    private void AppendTeslimatLine(string line)
    {
        if (string.IsNullOrWhiteSpace(line)) return;
        var existing = string.IsNullOrEmpty(quote.TeslimatNotlari) ? "" : quote.TeslimatNotlari;
        var sep = string.IsNullOrEmpty(existing) || existing.EndsWith("\n") ? "" : "\n";
        quote.TeslimatNotlari = existing + sep + "• " + line.Trim();
        MarkDirty();
    }

    private void GoToStep(int step)
    {
        errorMessage = null;
        currentStep = step;
    }

    private void NextStep()
    {
        errorMessage = null; successMessage = null;
        if (currentStep == 1)
        {
            if (quote.MusteriId <= 0)
            {
                errorMessage = "Musteri secimi zorunludur.";
                return;
            }
        }
        if (currentStep < 4)
            currentStep++;
    }

    private void PrevStep()
    {
        if (currentStep > 1)
            currentStep--;
    }

    private void Cancel()
    {
        if (isDirty)
        {
            showUnsavedDialog = true;
            return;
        }
        DiscardAndClose();
    }

    private void DiscardAndClose()
    {
        // Guard'i devre disi birak, sonra kapat
        isDirty = false;
        showUnsavedDialog = false;
        WindowSvc.CloseWindow<QuoteWizard>();
        Nav.NavigateTo("/satis/teklif-listesi");
    }

