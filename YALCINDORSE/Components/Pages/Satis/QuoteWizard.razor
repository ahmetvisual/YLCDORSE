    private IEnumerable<LastikKatalogModel> FilteredLastikler()
    {
        if (string.IsNullOrWhiteSpace(lastikSearchText))
            return lastikKatalog.Take(60);
        var q = lastikSearchText.Trim().ToUpperInvariant();
        return lastikKatalog
            .Where(k =>
                (k.Marka      ?? "").ToUpperInvariant().Contains(q) ||
                (k.Model      ?? "").ToUpperInvariant().Contains(q) ||
                (k.Ebat       ?? "").ToUpperInvariant().Contains(q) ||
                (k.YukIndeksi ?? "").ToUpperInvariant().Contains(q))
            .Take(120);
    }

