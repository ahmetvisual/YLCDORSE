@using YALCINDORSE.Services
@inject ArabaslikService ArabaslikSvc

<div class="items-editor">
    <div class="items-toolbar">
        <button class="wizard-btn wizard-btn-primary" style="padding:5px 12px;font-size:0.78rem" @onclick="AddHeader">+ Yeni Urun Basligi</button>
        @if (Items.Any(i => i.KalemTipi == "HEADER"))
        {
            <button class="wizard-btn" style="padding:5px 12px;font-size:0.78rem" @onclick="AddItem">+ Kalem Ekle</button>
        }
        <div style="flex:1"></div>
        <button class="wizard-btn ab-import-btn" style="padding:5px 12px;font-size:0.78rem" @onclick="ToggleArabaslikPanel">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:3px;vertical-align:text-bottom;">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            Arabasliktan Ekle
        </button>
    </div>

    @* === ARABASLIK SECIM PANELI === *@
    @if (showArabaslikPanel)
    {
        <div class="ab-import-panel">
            <div class="ab-import-header">
                <div class="ab-import-search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;opacity:0.4;flex-shrink:0;">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" placeholder="Arabaslik grubu ara..." @bind="abSearchQuery" @bind:event="oninput" />
                </div>
                <button class="ab-import-close" @onclick="() => showArabaslikPanel = false" title="Kapat">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>

            <div class="ab-import-list">
                @if (isLoadingAb)
                {
                    <div class="ab-import-empty">Yukleniyor...</div>
                }
                else if (filteredGruplar == null || !filteredGruplar.Any())
                {
                    <div class="ab-import-empty">Arabaslik grubu bulunamadi.</div>
                }
                else
                {
                    @foreach (var g in filteredGruplar)
                    {
                        var isSelected = selectedAbIds.Contains(g.Id);
                        <div class="ab-import-item @(isSelected ? "selected" : "")" @onclick="() => ToggleAbSelection(g.Id)">
                            <div class="ab-import-check">
                                @if (isSelected)
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;color:#059669;"><path d="M20 6L9 17l-5-5"/></svg>
                                }
                                else
                                {
                                    <div class="ab-import-checkbox-empty"></div>
                                }
                            </div>
                            <div style="flex:1;min-width:0;">
                                <div class="ab-import-name">@g.GrupAdi</div>
                                @{ var enText = GetGrupLocalizedName(g); }
                                @if (!string.IsNullOrEmpty(enText) && enText != g.GrupAdi)
                                {
                                    <div class="ab-import-sub">@enText</div>
                                }
                            </div>
                            <span class="ab-import-badge">@(g.TablTipi == 1 ? "Tablo" : "Liste")</span>
                        </div>
                    }
                }
            </div>

            @if (selectedAbIds.Count > 0)
            {
                <div class="ab-import-footer">
                    <span class="ab-import-count">@selectedAbIds.Count grup secildi</span>
                    <button class="wizard-btn wizard-btn-primary" style="padding:5px 14px;font-size:0.76rem;" @onclick="ImportSelectedArabasliklar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:3px;">
                            <polyline points="22 2 13.5 15.5 8.5 10.5 2 22"/><polyline points="16 2 22 2 22 8"/>
                        </svg>
                        Kaleme Aktar
                    </button>
                </div>
            }
        </div>
    }

    <div class="items-list">
        @if (Items.Count == 0)
        {
            <div class="items-empty">
                Henuz kalem eklenmedi. "Yeni Urun Basligi" ile baslayın.
            </div>
        }

        @foreach (var item in GetOrderedItems())
        {
            var rowClass = item.KalemTipi switch
            {
                "HEADER"   => "item-row item-row-header",
                "SUB_ITEM" => "item-row item-row-subitem",
                "OPTION"   => "item-row item-row-option",
                "SPEC"     => "item-row item-row-spec",
                _          => "item-row"
            };

            <div class="@rowClass">
                <div class="item-sira">@GetSiraLabel(item)</div>

                <div class="item-desc">
                    <input type="text" value="@item.Aciklama"
                           @onchange="(e) => UpdateField(item, nameof(item.Aciklama), e.Value?.ToString())"
                           placeholder="@(item.KalemTipi == "HEADER" ? "Urun adi (orn: Deveboynu)" : item.KalemTipi == "SPEC" ? "Ozellik adi (orn: Yukleme platformu uzunlugu)" : item.KalemTipi == "OPTION" ? "Opsiyon aciklamasi" : "Kalem aciklamasi")" />
                </div>

                @if (item.KalemTipi == "SPEC")
                {
                    @* Iki kolon tablo satirlari: Ozellik Adi : Deger — Mkt/Brm/Fiyat yok *@
                    <div class="item-spec-val">
                        <span class="spec-colon">:</span>
                        <input type="text" value="@item.Birim"
                               @onchange="(e) => UpdateField(item, nameof(item.Birim), e.Value?.ToString())"
                               placeholder="9.500 mm" />
                    </div>
                    <div class="item-price"></div>
                    <div class="item-total"></div>
                }
                else if (item.KalemTipi != "HEADER")
                {
                    <div class="item-qty">
                        <input type="number" value="@item.Miktar"
                               @onchange="(e) => UpdateNumericField(item, nameof(item.Miktar), e.Value?.ToString())"
                               placeholder="Mkt" />
                    </div>
                    <div class="item-unit">
                        <input type="text" value="@item.Birim"
                               @onchange="(e) => UpdateField(item, nameof(item.Birim), e.Value?.ToString())"
                               placeholder="Brm" />
                    </div>
                    <div class="item-price">
                        <input type="number" value="@item.BirimFiyat"
                               @onchange="(e) => UpdatePriceField(item, e.Value?.ToString())"
                               placeholder="Fiyat" />
                    </div>
                    <div class="item-total">
                        <input type="text" value="@($"{item.Tutar:N2}")" disabled />
                    </div>
                }
                else
                {
                    <div class="item-qty"></div>
                    <div class="item-unit">
                        <input type="text" value="@item.UrunKodu"
                               @onchange="(e) => UpdateField(item, nameof(item.UrunKodu), e.Value?.ToString())"
                               placeholder="Urun Kodu" style="text-align:left" />
                    </div>
                    <div class="item-price"></div>
                    <div class="item-total"></div>
                }

                <div class="item-actions">
                    @if (item.KalemTipi == "HEADER")
                    {
                        <button class="item-action-btn" title="Kalem ekle" @onclick="() => AddItemUnder(item)">+</button>
                    }
                    @if (item.KalemTipi == "ITEM")
                    {
                        <button class="item-action-btn" title="Alt kalem ekle" @onclick="() => AddSubItem(item)">&#8627;</button>
                        <button class="item-action-btn" title="Opsiyon ekle" @onclick="() => AddOption(item)">&#9733;</button>
                    }
                    <button class="item-action-btn delete" title="Sil" @onclick="() => RemoveItem(item)">&#10005;</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<QuoteItemModel> Items { get; set; } = new();
    [Parameter] public EventCallback<List<QuoteItemModel>> ItemsChanged { get; set; }
    [Parameter] public string Dil { get; set; } = "TR";

    private int nextTempId = -1;

    // === Arabaslik Import State ===
    private bool showArabaslikPanel = false;
    private bool isLoadingAb = false;
    private string abSearchQuery = "";
    private List<ArabaslikGrupModel>? allGruplar;
    private HashSet<int> selectedAbIds = new();

    private List<QuoteItemModel> GetOrderedItems()
    {
        var result = new List<QuoteItemModel>();
        var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();

        foreach (var header in headers)
        {
            result.Add(header);
            // SPEC (iki kolon tablo) ve ITEM tipindeki satirlari dahil et
            var children = Items.Where(i => i.UstKalemId == header.Id &&
                                            (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"))
                               .OrderBy(i => i.SiraNo).ToList();
            foreach (var child in children)
            {
                result.Add(child);
                // Alt satirlar ve opsiyonlar yalnizca ITEM icin gosterilir
                if (child.KalemTipi == "ITEM")
                {
                    var subs = Items.Where(i => i.UstKalemId == child.Id)
                                   .OrderBy(i => i.SiraNo).ToList();
                    foreach (var sub in subs)
                    {
                        result.Add(sub);
                    }
                }
            }
        }

        // Basligi olmayan kalemler (eski veri)
        var orphans = Items.Where(i => !result.Contains(i)).OrderBy(i => i.SiraNo).ToList();
        result.AddRange(orphans);

        return result;
    }

    /// <summary>TablTipi=1 grubuna ait bir HEADER mi? (tum cocuklari SPEC ise evet)</summary>
    private bool IsSpecHeader(QuoteItemModel header) =>
        Items.Any(i => i.UstKalemId == header.Id && i.KalemTipi == "SPEC");

    private string GetSiraLabel(QuoteItemModel item)
    {
        if (item.KalemTipi == "SPEC") return "";  // TablTipi=1: satir numarasi yok

        if (item.KalemTipi == "HEADER")
        {
            if (IsSpecHeader(item)) return "";  // TablTipi=1 grubunun basliginda numara yok
            var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
            var idx = headers.IndexOf(item) + 1;
            return $"{idx}.0";
        }
        else if ((item.KalemTipi == "ITEM" || item.KalemTipi == "SPEC") && item.UstKalemId.HasValue)
        {
            var parent = Items.FirstOrDefault(i => i.Id == item.UstKalemId);
            if (parent != null)
            {
                var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
                var hIdx = headers.IndexOf(parent) + 1;
                var siblings = Items.Where(i => i.UstKalemId == parent.Id &&
                                                (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"))
                                   .OrderBy(i => i.SiraNo).ToList();
                var cIdx = siblings.IndexOf(item) + 1;
                return $"{hIdx}.{cIdx}";
            }
        }
        else if ((item.KalemTipi == "SUB_ITEM" || item.KalemTipi == "OPTION") && item.UstKalemId.HasValue)
        {
            var parent = Items.FirstOrDefault(i => i.Id == item.UstKalemId);
            if (parent?.UstKalemId.HasValue == true)
            {
                var grandParent = Items.FirstOrDefault(i => i.Id == parent.UstKalemId);
                if (grandParent != null)
                {
                    var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
                    var hIdx = headers.IndexOf(grandParent) + 1;
                    var parentSiblings = Items.Where(i => i.UstKalemId == grandParent.Id && i.KalemTipi == "ITEM").OrderBy(i => i.SiraNo).ToList();
                    var pIdx = parentSiblings.IndexOf(parent) + 1;
                    var mySiblings = Items.Where(i => i.UstKalemId == parent.Id).OrderBy(i => i.SiraNo).ToList();
                    var myIdx = mySiblings.IndexOf(item) + 1;
                    return $"{hIdx}.{pIdx}.{myIdx}";
                }
            }
        }
        return $"{item.SiraNo}";
    }

    private void AddHeader()
    {
        var maxSira = Items.Where(i => i.KalemTipi == "HEADER").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        Items.Add(new QuoteItemModel
        {
            Id = nextTempId--,
            KalemTipi = "HEADER",
            BaslikMi = true,
            SiraNo = maxSira + 10,
            Aciklama = ""
        });
        NotifyChanged();
    }

    private void AddItem()
    {
        var lastHeader = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).LastOrDefault();
        if (lastHeader != null)
            AddItemUnder(lastHeader);
    }

    private void AddItemUnder(QuoteItemModel header)
    {
        var maxSira = Items.Where(i => i.UstKalemId == header.Id && i.KalemTipi == "ITEM").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        Items.Add(new QuoteItemModel
        {
            Id = nextTempId--,
            KalemTipi = "ITEM",
            UstKalemId = header.Id,
            SiraNo = maxSira + 10,
            Aciklama = ""
        });
        NotifyChanged();
    }

    private void AddSubItem(QuoteItemModel parent)
    {
        var maxSira = Items.Where(i => i.UstKalemId == parent.Id && i.KalemTipi == "SUB_ITEM").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        Items.Add(new QuoteItemModel
        {
            Id = nextTempId--,
            KalemTipi = "SUB_ITEM",
            UstKalemId = parent.Id,
            SiraNo = maxSira + 10,
            Aciklama = ""
        });
        NotifyChanged();
    }

    private void AddOption(QuoteItemModel parent)
    {
        var maxSira = Items.Where(i => i.UstKalemId == parent.Id && i.KalemTipi == "OPTION").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        Items.Add(new QuoteItemModel
        {
            Id = nextTempId--,
            KalemTipi = "OPTION",
            OpsiyonMu = true,
            UstKalemId = parent.Id,
            SiraNo = maxSira + 10,
            Aciklama = ""
        });
        NotifyChanged();
    }

    private void RemoveItem(QuoteItemModel item)
    {
        // Cocuklari da sil
        var childIds = Items.Where(i => i.UstKalemId == item.Id).Select(i => i.Id).ToList();
        foreach (var childId in childIds)
        {
            var grandChildren = Items.Where(i => i.UstKalemId == childId).ToList();
            Items.RemoveAll(i => grandChildren.Contains(i));
        }
        Items.RemoveAll(i => childIds.Contains(i.Id));
        Items.Remove(item);
        NotifyChanged();
    }

    private void UpdateField(QuoteItemModel item, string field, string? value)
    {
        switch (field)
        {
            case nameof(item.Aciklama): item.Aciklama = value ?? ""; break;
            case nameof(item.UrunKodu): item.UrunKodu = value; break;
            case nameof(item.Birim): item.Birim = value; break;
        }
        NotifyChanged();
    }

    private void UpdateNumericField(QuoteItemModel item, string field, string? value)
    {
        if (decimal.TryParse(value, out var num))
        {
            item.Miktar = num;
            item.Tutar = (item.Miktar ?? 0) * (item.BirimFiyat ?? 0);
        }
        NotifyChanged();
    }

    private void UpdatePriceField(QuoteItemModel item, string? value)
    {
        if (decimal.TryParse(value, out var num))
        {
            item.BirimFiyat = num;
            item.Tutar = (item.Miktar ?? 0) * (item.BirimFiyat ?? 0);
        }
        NotifyChanged();
    }

    private void NotifyChanged()
    {
        ItemsChanged.InvokeAsync(Items);
    }

    // ═══ ARABASLIK IMPORT ═══════════════════════════════════

    private List<ArabaslikGrupModel> filteredGruplar =>
        allGruplar == null ? new() :
        string.IsNullOrWhiteSpace(abSearchQuery) ? allGruplar :
        allGruplar.Where(g =>
            g.GrupAdi.Contains(abSearchQuery, StringComparison.OrdinalIgnoreCase) ||
            g.GrupAdi_EN.Contains(abSearchQuery, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    private async Task ToggleArabaslikPanel()
    {
        showArabaslikPanel = !showArabaslikPanel;
        if (showArabaslikPanel && allGruplar == null)
        {
            isLoadingAb = true;
            StateHasChanged();
            try
            {
                allGruplar = await ArabaslikSvc.GetGruplarAsync();
            }
            catch { allGruplar = new(); }
            finally { isLoadingAb = false; }
        }
        selectedAbIds.Clear();
    }

    private void ToggleAbSelection(int id)
    {
        if (!selectedAbIds.Remove(id))
            selectedAbIds.Add(id);
    }

    private string GetGrupLocalizedName(ArabaslikGrupModel g) => Dil switch
    {
        "EN" => g.GrupAdi_EN,
        "DE" => g.GrupAdi_DE,
        "FR" => g.GrupAdi_FR,
        "RU" => g.GrupAdi_RU,
        "RO" => g.GrupAdi_RO,
        "AR" => g.GrupAdi_AR,
        _ => ""
    };

    private string GetDetayLocalizedText(ArabaslikDetayModel d) => Dil switch
    {
        "EN" when !string.IsNullOrEmpty(d.SatirMetni_EN) => d.SatirMetni_EN,
        "DE" when !string.IsNullOrEmpty(d.SatirMetni_DE) => d.SatirMetni_DE,
        "FR" when !string.IsNullOrEmpty(d.SatirMetni_FR) => d.SatirMetni_FR,
        "RU" when !string.IsNullOrEmpty(d.SatirMetni_RU) => d.SatirMetni_RU,
        "RO" when !string.IsNullOrEmpty(d.SatirMetni_RO) => d.SatirMetni_RO,
        "AR" when !string.IsNullOrEmpty(d.SatirMetni_AR) => d.SatirMetni_AR,
        _ => d.SatirMetni
    };

    private async Task ImportSelectedArabasliklar()
    {
        if (selectedAbIds.Count == 0) return;

        var maxSira = Items.Where(i => i.KalemTipi == "HEADER").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();

        foreach (var grupId in selectedAbIds.OrderBy(id => allGruplar?.FindIndex(g => g.Id == id) ?? 0))
        {
            var grup = allGruplar?.FirstOrDefault(g => g.Id == grupId);
            if (grup == null) continue;

            maxSira += 10;

            // Lokalize baslik
            var headerText = Dil != "TR" ? GetGrupLocalizedName(grup) : "";
            var displayName = !string.IsNullOrEmpty(headerText) ? headerText : grup.GrupAdi;

            // HEADER olustur
            var headerId = nextTempId--;
            Items.Add(new QuoteItemModel
            {
                Id = headerId,
                KalemTipi = "HEADER",
                BaslikMi = true,
                SiraNo = maxSira,
                Aciklama = displayName,
                UrunKodu = $"AB-{grup.Id}"
            });

            // Detaylari yukle ve kalem olarak ekle
            try
            {
                var detaylar = await ArabaslikSvc.GetDetaylarAsync(grupId);
                int childSira = 0;

                if (grup.TablTipi == 1)
                {
                    // Iki kolon tablo: her satir bir "Ozellik : Deger" cifti — fiyat yok
                    foreach (var d in detaylar)
                    {
                        childSira += 10;
                        var itemText = GetDetayLocalizedText(d);
                        Items.Add(new QuoteItemModel
                        {
                            Id = nextTempId--,
                            KalemTipi = "SPEC",
                            UstKalemId = headerId,
                            SiraNo = childSira,
                            Aciklama = itemText,   // ozellik adi (lokalize)
                            Birim = d.Deger        // evrensel deger ("9.500 mm" gibi)
                        });
                    }
                }
                else
                {
                    // Numarali liste (TablTipi=2): klasik fiyatli satirlar
                    foreach (var d in detaylar)
                    {
                        childSira += 10;
                        var itemText = GetDetayLocalizedText(d);
                        Items.Add(new QuoteItemModel
                        {
                            Id = nextTempId--,
                            KalemTipi = "ITEM",
                            UstKalemId = headerId,
                            SiraNo = childSira,
                            Aciklama = itemText,
                            BirimFiyat = d.Fiyat,
                            Miktar = d.Fiyat.HasValue ? 1 : null,
                            Tutar = d.Fiyat,
                            Birim = d.Fiyat.HasValue ? "AD" : null
                        });
                    }
                }
            }
            catch { /* detaylar yuklenemezse sadece baslik kalir */ }
        }

        NotifyChanged();
        showArabaslikPanel = false;
        selectedAbIds.Clear();
    }
}
