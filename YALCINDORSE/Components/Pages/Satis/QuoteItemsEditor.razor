@using YALCINDORSE.Services
@inject ArabaslikService ArabaslikSvc
@inject IJSRuntime JS
@implements IDisposable

<div class="items-editor v2 @(dragInProgress ? "drag-active" : "")">

    @* ════════════════════════════════════════════════════════════
       SOL PANEL — Teklife Eklenen Kalemler
       ════════════════════════════════════════════════════════════ *@
    <div class="pane pane-left">
        <div class="pane-header">
            <div class="pane-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                    <path d="M3 6h18M3 12h18M3 18h12"/>
                </svg>
                <span>Eklenen Kalemler</span>
                <span class="pane-count">@Items.Count</span>
            </div>
            <div class="pane-hint" title="Sürükle-bırak ile sırayı değiştirin">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:11px;height:11px;opacity:0.55">
                    <circle cx="9" cy="6" r="1.4"/><circle cx="15" cy="6" r="1.4"/>
                    <circle cx="9" cy="12" r="1.4"/><circle cx="15" cy="12" r="1.4"/>
                    <circle cx="9" cy="18" r="1.4"/><circle cx="15" cy="18" r="1.4"/>
                </svg>
                <span>Sürükle-bırak ile sırayı değiştirin</span>
            </div>
        </div>

        <div class="pane-body items-list @(dragOverLeftPane ? "drop-target" : "")"
             @ondragover:preventDefault="true"
             @ondragenter="OnDragEnterLeftPane"
             @ondragleave="OnDragLeaveLeftPane"
             @ondrop="OnDropOnLeftPane">

            @if (Items.Count == 0)
            {
                <div class="items-empty">
                    Sağdaki şablonlardan grup veya kalem sürükleyip buraya bırakın.
                </div>
            }

            @foreach (var item in GetOrderedItems())
            {
                var rowClass = item.KalemTipi switch
                {
                    "HEADER"   => "item-row item-row-header",
                    "SUB_ITEM" => "item-row item-row-subitem",
                    "OPTION"   => "item-row item-row-option",
                    "SPEC"     => "item-row item-row-spec",
                    _          => "item-row"
                };
                var isDropTarget = dragOverItemId == item.Id;
                var isDragging = draggingQuoteItemId == item.Id;

                <div class="@rowClass @(isDropTarget ? "drop-target-row" : "") @(isDragging ? "dragging" : "")"
                     data-item-id="@item.Id"
                     @ondragover:preventDefault="true"
                     @ondragenter="() => OnDragEnterItem(item)"
                     @ondragleave="() => OnDragLeaveItem(item)"
                     @ondrop:stopPropagation="true"
                     @ondrop="() => OnDropOnItem(item)">

                    <div class="item-drag-grip" title="Sürükleyerek sırayı değiştirin">
                        <svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px;pointer-events:none;">
                            <circle cx="9" cy="5" r="1.6"/><circle cx="15" cy="5" r="1.6"/>
                            <circle cx="9" cy="12" r="1.6"/><circle cx="15" cy="12" r="1.6"/>
                            <circle cx="9" cy="19" r="1.6"/><circle cx="15" cy="19" r="1.6"/>
                        </svg>
                    </div>

                    <div class="item-sira">@GetSiraLabel(item)</div>

                    <div class="item-desc">
                        <input type="text" value="@item.Aciklama"
                               @onchange="(e) => UpdateField(item, nameof(item.Aciklama), e.Value?.ToString())"
                               placeholder="@(item.KalemTipi == "HEADER" ? "Urun adi (orn: Deveboynu)" : item.KalemTipi == "SPEC" ? "Ozellik adi" : item.KalemTipi == "OPTION" ? "Opsiyon aciklamasi" : "Kalem aciklamasi")" />
                    </div>

                    @if (item.KalemTipi == "SPEC")
                    {
                        <div class="item-spec-val">
                            <span class="spec-colon">:</span>
                            <input type="text" value="@item.Birim"
                                   @onchange="(e) => UpdateField(item, nameof(item.Birim), e.Value?.ToString())"
                                   placeholder="Değer" />
                        </div>
                        <div class="item-price"></div>
                        <div class="item-total"></div>
                    }
                    else if (item.KalemTipi != "HEADER")
                    {
                        <div class="item-qty">
                            <input type="number" value="@item.Miktar"
                                   @onchange="(e) => UpdateNumericField(item, nameof(item.Miktar), e.Value?.ToString())"
                                   placeholder="Mkt" />
                        </div>
                        <div class="item-unit">
                            <input type="text" value="@item.Birim"
                                   @onchange="(e) => UpdateField(item, nameof(item.Birim), e.Value?.ToString())"
                                   placeholder="Brm" />
                        </div>
                        <div class="item-price">
                            <input type="number" value="@item.BirimFiyat"
                                   @onchange="(e) => UpdatePriceField(item, e.Value?.ToString())"
                                   placeholder="Fiyat" />
                        </div>
                        <div class="item-total">
                            <input type="text" value="@($"{item.Tutar:N2}")" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="item-qty"></div>
                        <div class="item-unit">
                            <input type="text" value="@item.UrunKodu"
                                   @onchange="(e) => UpdateField(item, nameof(item.UrunKodu), e.Value?.ToString())"
                                   placeholder="Urun Kodu" style="text-align:left" />
                        </div>
                        <div class="item-price"></div>
                        <div class="item-total"></div>
                    }

                    <div class="item-actions">
                        @if (item.KalemTipi == "HEADER")
                        {
                            <button class="item-action-btn" title="Kalem ekle" @onclick="() => AddItemUnder(item)">+</button>
                        }
                        @if (item.KalemTipi == "ITEM")
                        {
                            <button class="item-action-btn @(item.BaslikMi ? "item-bold-active" : "")"
                                    title="@(item.BaslikMi ? "Kalin (PDF'de bold)" : "Normal (PDF'de thin)")"
                                    @onclick="() => ToggleBold(item)"><b>B</b></button>
                        }
                        <button class="item-action-btn delete" title="Sil" @onclick="() => RemoveItem(item)">&#10005;</button>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ════════════════════════════════════════════════════════════
       SAĞ PANEL — Şablonlar / Tanımlar (Klasör Ağacı)
       ════════════════════════════════════════════════════════════ *@
    <div class="pane pane-right">
        <div class="pane-header">
            <div class="pane-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
                    <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
                </svg>
                <span>Şablonlar</span>
                @if (allGruplar != null)
                {
                    <span class="pane-count">@allGruplar.Count</span>
                }
            </div>
            <div class="pane-actions">
                <button class="pane-btn" @onclick="ToggleNewGroupForm" title="Yeni şablon grubu">+ Yeni</button>
                <button class="pane-btn" @onclick="RefreshGruplar" title="Yenile">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
                        <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                        <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="pane-search-wrap">
            <div class="pane-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;opacity:0.45;flex-shrink:0">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" placeholder="Grup veya kalem ara..." value="@abSearchQuery" @oninput="OnSearchInput" />
                @if (!string.IsNullOrEmpty(abSearchQuery))
                {
                    <button class="search-clear" @onclick="ClearSearch" title="Temizle">×</button>
                }
            </div>
        </div>

        @if (showNewGroupForm)
        {
            <div class="new-group-form">
                <input type="text" placeholder="Grup adı (örn: AKS GRUBU)"
                       @bind="newGroupName" @bind:event="oninput"
                       @onkeydown="OnNewGroupKeyDown" />
                <div class="new-group-row">
                    <label class="radio-inline">
                        <input type="radio" name="newGroupTip" value="1" checked="@(newGroupTablTipi == 1)"
                               @onchange="() => newGroupTablTipi = 1" /> Tablo
                    </label>
                    <label class="radio-inline">
                        <input type="radio" name="newGroupTip" value="2" checked="@(newGroupTablTipi == 2)"
                               @onchange="() => newGroupTablTipi = 2" /> Liste
                    </label>
                    <div style="flex:1"></div>
                    <button class="pane-btn ghost" @onclick="() => showNewGroupForm = false">İptal</button>
                    <button class="pane-btn primary" @onclick="SaveNewGroup" disabled="@string.IsNullOrWhiteSpace(newGroupName)">Kaydet</button>
                </div>
            </div>
        }

        <div class="pane-body groups-tree">
            @if (isLoadingAb)
            {
                <div class="items-empty">Yükleniyor...</div>
            }
            else if (allGruplar == null || !filteredGruplar.Any())
            {
                <div class="items-empty">
                    @(string.IsNullOrEmpty(abSearchQuery) ? "Henüz şablon yok. + Yeni ile başlayın." : "Eşleşen kayıt yok.")
                </div>
            }
            else
            {
                @foreach (var g in filteredGruplar)
                {
                    var isExpanded = IsExpandedView(g);
                    var details = isExpanded && groupDetailsCache.TryGetValue(g.Id, out var d) ? d : null;

                    <div class="group-node">
                        <div class="group-header @(isExpanded ? "expanded" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStartGroup(g)"
                             @ondragend="OnDragEnd">
                            <button class="chevron-btn" @onclick="() => ToggleGroup(g.Id)" title="Aç/Kapat">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                     style="width:11px;height:11px;transition:transform 0.15s;@(isExpanded ? "transform:rotate(90deg)" : "")">
                                    <polyline points="9 18 15 12 9 6"/>
                                </svg>
                            </button>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 style="width:13px;height:13px;color:#0c447c;flex-shrink:0">
                                <path d="@(isExpanded ? "M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z" : "M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z")"/>
                            </svg>
                            <span class="group-name">@g.GrupAdi</span>
                            @{ var localized = GetGrupLocalizedName(g); }
                            @if (!string.IsNullOrEmpty(localized) && localized != g.GrupAdi)
                            {
                                <span class="group-sub">@localized</span>
                            }
                            <span class="group-badge">@(g.TablTipi == 1 ? "Tablo" : "Liste")</span>
                            <button class="group-tool-btn" @onclick:stopPropagation="true" @onclick="() => StartEditGrup(g)" title="Grup adını düzenle (diller)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
                                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/>
                                </svg>
                            </button>
                            <button class="group-tool-btn delete" @onclick:stopPropagation="true" @onclick="() => confirmDeleteGrupId = g.Id" title="Grubu sil">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
                                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 01-2 2H9a2 2 0 01-2-2L5 6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                </svg>
                            </button>
                            <button class="group-add-btn" @onclick:stopPropagation="true" @onclick="() => AddGroupAsHeader(g)" title="Tüm grubu teklife ekle">+</button>
                        </div>

                        @if (isExpanded)
                        {
                            <div class="group-details">
                                @if (details == null)
                                {
                                    <div class="detail-loading">Yükleniyor...</div>
                                }
                                else if (!details.Any())
                                {
                                    <div class="detail-empty">Bu grupta kayıt yok.</div>
                                }
                                else
                                {
                                    @if (details.Count >= 6)
                                    {
                                        var gq = groupQueries.TryGetValue(g.Id, out var qv) ? qv : "";
                                        <div class="group-detail-search">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 style="width:11px;height:11px;opacity:0.45;flex-shrink:0">
                                                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                            </svg>
                                            <input type="text" placeholder="Bu grupta ara..."
                                                   value="@gq"
                                                   @oninput="(e) => SetGroupQuery(g.Id, e.Value?.ToString() ?? string.Empty)" />
                                            @if (!string.IsNullOrEmpty(gq))
                                            {
                                                <button class="search-clear" @onclick="() => SetGroupQuery(g.Id, string.Empty)" title="Temizle">×</button>
                                            }
                                        </div>
                                    }
                                    var visibleDetails = FilterGroupDetails(g.Id, details);
                                    @if (!visibleDetails.Any())
                                    {
                                        <div class="detail-empty">Eşleşen kayıt yok.</div>
                                    }
                                    @foreach (var dt in visibleDetails)
                                    {
                                        <div class="detail-node"
                                             draggable="true"
                                             @ondragstart="() => OnDragStartDetay(g, dt)"
                                             @ondragend="OnDragEnd">
                                            <span class="detail-bullet">›</span>
                                            <span class="detail-text">@GetDetayLocalizedText(dt)</span>
                                            @if (g.TablTipi == 1)
                                            {
                                                <input type="text" class="detail-value-edit"
                                                       value="@dt.Deger" draggable="false"
                                                       @onchange="(e) => UpdateDetayDeger(dt, e.Value?.ToString())"
                                                       @onclick:stopPropagation="true"
                                                       placeholder="Değer" />
                                            }
                                            else
                                            {
                                                <input type="number" class="detail-price-edit"
                                                       value="@(dt.Fiyat?.ToString("0.##", InvCulture))" draggable="false"
                                                       step="0.01"
                                                       @onchange="(e) => UpdateDetayFiyat(dt, e.Value?.ToString())"
                                                       @onclick:stopPropagation="true"
                                                       placeholder="Fiyat" />
                                                <span class="detail-price-cur">@CurrencySymbol</span>
                                            }
                                            <button class="detail-tool-btn" @onclick:stopPropagation="true" @onclick="() => StartEditDetay(g, dt)" title="Düzenle (diller)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:10px;height:10px;">
                                                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"/>
                                                </svg>
                                            </button>
                                            <button class="detail-tool-btn delete" @onclick:stopPropagation="true" @onclick="() => confirmDeleteDetayId = dt.Id" title="Sil">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:10px;height:10px;">
                                                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 01-2 2H9a2 2 0 01-2-2L5 6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                                </svg>
                                            </button>
                                            <button class="detail-add-btn" @onclick:stopPropagation="true" @onclick="() => AddDetayAsItem(g, dt)" title="Bu kalemi teklife ekle">+</button>
                                        </div>
                                    }
                                }

                                @* Inline yeni kalem ekleme formu *@
                                <div class="add-kalem-row">
                                    <span class="add-kalem-bullet">+</span>
                                    <input type="text" placeholder="Yeni kalem yaz ve Enter'a bas..."
                                           value="@(newKalemText.TryGetValue(g.Id, out var nkt) ? nkt : "")"
                                           @oninput="(e) => OnNewKalemInput(g.Id, e.Value?.ToString())"
                                           @onkeydown="(e) => OnNewKalemKey(e, g)" />
                                    <button class="kalem-add-confirm" title="Ekle"
                                            disabled="@(!newKalemText.TryGetValue(g.Id, out var v2) || string.IsNullOrWhiteSpace(v2))"
                                            @onclick="() => AddNewKalemAsync(g)">+</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* Grup düzenleme popup (multi-lang) *@
    @if (showGrupEdit && editingGrup != null)
    {
        <div class="modal-overlay" @onclick="CancelGrupEdit">
            <div class="quick-modal-content" style="max-width:520px" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Grup Düzenle</h4>
                    <button class="btn-close" @onclick="CancelGrupEdit">&#10005;</button>
                </div>
                <div class="modal-body" style="padding:14px 16px;display:flex;flex-direction:column;gap:8px">
                    <div class="lang-grid">
                        <label>TR <input type="text" @bind="editingGrup.GrupAdi" /></label>
                        <label>EN <input type="text" @bind="editingGrup.GrupAdi_EN" /></label>
                        <label>DE <input type="text" @bind="editingGrup.GrupAdi_DE" /></label>
                        <label>FR <input type="text" @bind="editingGrup.GrupAdi_FR" /></label>
                        <label>RO <input type="text" @bind="editingGrup.GrupAdi_RO" /></label>
                        <label>RU <input type="text" @bind="editingGrup.GrupAdi_RU" /></label>
                        <label>AR <input type="text" @bind="editingGrup.GrupAdi_AR" dir="rtl" /></label>
                    </div>
                    <div style="display:flex;gap:14px;align-items:center;font-size:0.82rem;margin-top:4px">
                        <span style="font-weight:600">Tip:</span>
                        <label class="radio-inline"><input type="radio" name="editGrupTip" checked="@(editingGrup.TablTipi == 1)" @onchange="() => editingGrup.TablTipi = 1" /> Tablo</label>
                        <label class="radio-inline"><input type="radio" name="editGrupTip" checked="@(editingGrup.TablTipi == 2)" @onchange="() => editingGrup.TablTipi = 2" /> Liste</label>
                    </div>
                </div>
                <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                    <button class="wizard-btn" @onclick="CancelGrupEdit">İptal</button>
                    <button class="wizard-btn wizard-btn-primary" @onclick="SaveGrupEditAsync" disabled="@string.IsNullOrWhiteSpace(editingGrup.GrupAdi)">Kaydet</button>
                </div>
            </div>
        </div>
    }

    @* Detay düzenleme popup (multi-lang + fiyat) *@
    @if (showDetayEdit && editingDetay != null && editingDetayGrup != null)
    {
        <div class="modal-overlay" @onclick="CancelDetayEdit">
            <div class="quick-modal-content" style="max-width:560px" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Kalem Düzenle</h4>
                    <button class="btn-close" @onclick="CancelDetayEdit">&#10005;</button>
                </div>
                <div class="modal-body" style="padding:14px 16px;display:flex;flex-direction:column;gap:8px">
                    <div class="lang-grid wide">
                        <label>TR <input type="text" @bind="editingDetay.SatirMetni" /></label>
                        <label>EN <input type="text" @bind="editingDetay.SatirMetni_EN" /></label>
                        <label>DE <input type="text" @bind="editingDetay.SatirMetni_DE" /></label>
                        <label>FR <input type="text" @bind="editingDetay.SatirMetni_FR" /></label>
                        <label>RO <input type="text" @bind="editingDetay.SatirMetni_RO" /></label>
                        <label>RU <input type="text" @bind="editingDetay.SatirMetni_RU" /></label>
                        <label>AR <input type="text" @bind="editingDetay.SatirMetni_AR" dir="rtl" /></label>
                    </div>
                    <div style="display:flex;gap:14px;align-items:center;font-size:0.82rem;margin-top:4px">
                        @if (editingDetayGrup.TablTipi == 1)
                        {
                            <label style="display:flex;align-items:center;gap:6px;flex:1">
                                <span style="font-weight:600">Değer:</span>
                                <input type="text" @bind="detayDegerBuffer" placeholder="örn: 9.500 mm" style="flex:1" />
                            </label>
                        }
                        else
                        {
                            <label style="display:flex;align-items:center;gap:6px">
                                <span style="font-weight:600">Fiyat:</span>
                                <input type="number" step="0.01" @bind="detayFiyatBuffer" style="width:120px" />
                                <span>@CurrencySymbol</span>
                            </label>
                        }
                    </div>
                </div>
                <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                    <button class="wizard-btn" @onclick="CancelDetayEdit">İptal</button>
                    <button class="wizard-btn wizard-btn-primary" @onclick="SaveDetayEditAsync" disabled="@string.IsNullOrWhiteSpace(editingDetay.SatirMetni)">Kaydet</button>
                </div>
            </div>
        </div>
    }

    @* Grup silme onay *@
    @if (confirmDeleteGrupId.HasValue)
    {
        var dgrup = allGruplar?.FirstOrDefault(x => x.Id == confirmDeleteGrupId.Value);
        if (dgrup != null)
        {
            <div class="modal-overlay" @onclick="() => confirmDeleteGrupId = null">
                <div class="quick-modal-content" style="max-width:420px" @onclick:stopPropagation="true">
                    <div class="modal-header"><h4>Grubu Sil</h4><button class="btn-close" @onclick="() => confirmDeleteGrupId = null">&#10005;</button></div>
                    <div class="modal-body" style="padding:16px"><p><b>@dgrup.GrupAdi</b> grubu ve içindeki tüm kalemler silinecek. Emin misiniz?</p></div>
                    <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                        <button class="wizard-btn" @onclick="() => confirmDeleteGrupId = null">Vazgeç</button>
                        <button class="wizard-btn" style="background:#fee2e2;color:#991b1b;border-color:#fecaca" @onclick="() => DeleteGrupAsync(dgrup.Id)">Sil</button>
                    </div>
                </div>
            </div>
        }
    }

    @* Detay silme onay *@
    @if (confirmDeleteDetayId.HasValue)
    {
        <div class="modal-overlay" @onclick="() => confirmDeleteDetayId = null">
            <div class="quick-modal-content" style="max-width:380px" @onclick:stopPropagation="true">
                <div class="modal-header"><h4>Kalemi Sil</h4><button class="btn-close" @onclick="() => confirmDeleteDetayId = null">&#10005;</button></div>
                <div class="modal-body" style="padding:16px"><p>Bu kalem şablondan silinecek. Emin misiniz?</p></div>
                <div style="display:flex;justify-content:flex-end;gap:8px;padding:10px 16px;border-top:1px solid var(--yl-border)">
                    <button class="wizard-btn" @onclick="() => confirmDeleteDetayId = null">Vazgeç</button>
                    <button class="wizard-btn" style="background:#fee2e2;color:#991b1b;border-color:#fecaca" @onclick="() => DeleteDetayAsync(confirmDeleteDetayId.Value)">Sil</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public List<QuoteItemModel> Items { get; set; } = new();
    [Parameter] public EventCallback<List<QuoteItemModel>> ItemsChanged { get; set; }
    [Parameter] public string Dil { get; set; } = "TR";
    [Parameter] public string ParaBirimi { get; set; } = "EUR";

