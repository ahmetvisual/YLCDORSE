    protected override async Task OnInitializedAsync()
    {
        await LoadGruplarAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !jsHookInstalled)
        {
            try
            {
                dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("YLDragReorder.setRef", dotNetRef);
                jsHookInstalled = true;
            }
            catch { /* JS yuklenmemisse drag-reorder calismaz, diger seyler etkilenmesin */ }
        }
    }

    public void Dispose()
    {
        if (jsHookInstalled)
        {
            try { _ = JS.InvokeVoidAsync("YLDragReorder.clearRef"); } catch { }
            jsHookInstalled = false;
        }
        dotNetRef?.Dispose();
    }

    /// <summary>JS pointer-drag bittiginde cagirilir: kaynak ve hedef satir id'leri ile reorder yapar.
    /// insertBefore=true ise src hedefin ustune, false ise altina yerlestirilir.</summary>
    [JSInvokable]
    public void OnPointerReorder(int srcId, int targetId, bool insertBefore)
    {
        if (srcId == targetId) return;
        var src = Items.FirstOrDefault(i => i.Id == srcId);
        var target = Items.FirstOrDefault(i => i.Id == targetId);
        if (src == null || target == null) return;

        ReorderQuoteItems(src, target, insertBefore);
        StateHasChanged();
    }

    private async Task LoadGruplarAsync()
    {
        isLoadingAb = true;
        try { allGruplar = await ArabaslikSvc.GetGruplarAsync(); }
        catch { allGruplar = new(); }
        finally { isLoadingAb = false; }
    }

    private async Task RefreshGruplar()
    {
        groupDetailsCache.Clear();
        await LoadGruplarAsync();
    }

    // ─── ORDER HELPERS (mevcut mantık korunur) ──────────────────

    private List<QuoteItemModel> GetOrderedItems()
    {
        var result = new List<QuoteItemModel>();
        var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();

        foreach (var header in headers)
        {
            result.Add(header);
            var children = Items.Where(i => i.UstKalemId == header.Id &&
                                            (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"))
                               .OrderBy(i => i.SiraNo).ToList();
            foreach (var child in children)
            {
                result.Add(child);
                if (child.KalemTipi == "ITEM")
                {
                    var subs = Items.Where(i => i.UstKalemId == child.Id)
                                   .OrderBy(i => i.SiraNo).ToList();
                    foreach (var sub in subs) result.Add(sub);
                }
            }
        }

        var orphans = Items.Where(i => !result.Contains(i)).OrderBy(i => i.SiraNo).ToList();
        result.AddRange(orphans);
        return result;
    }

    private bool IsSpecHeader(QuoteItemModel header) =>
        Items.Any(i => i.UstKalemId == header.Id && i.KalemTipi == "SPEC");

    private string GetSiraLabel(QuoteItemModel item)
    {
        if (item.KalemTipi == "SPEC") return "";

        if (item.KalemTipi == "HEADER")
        {
            if (IsSpecHeader(item)) return "";
            var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
            var idx = headers.IndexOf(item) + 1;
            return $"{idx}.0";
        }
        else if ((item.KalemTipi == "ITEM" || item.KalemTipi == "SPEC") && item.UstKalemId.HasValue)
        {
            var parent = Items.FirstOrDefault(i => i.Id == item.UstKalemId);
            if (parent != null)
            {
                var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
                var hIdx = headers.IndexOf(parent) + 1;
                var siblings = Items.Where(i => i.UstKalemId == parent.Id &&
                                                (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"))
                                   .OrderBy(i => i.SiraNo).ToList();
                var cIdx = siblings.IndexOf(item) + 1;
                return $"{hIdx}.{cIdx}";
            }
        }
        else if ((item.KalemTipi == "SUB_ITEM" || item.KalemTipi == "OPTION") && item.UstKalemId.HasValue)
        {
            var parent = Items.FirstOrDefault(i => i.Id == item.UstKalemId);
            if (parent?.UstKalemId.HasValue == true)
            {
                var grandParent = Items.FirstOrDefault(i => i.Id == parent.UstKalemId);
                if (grandParent != null)
                {
                    var headers = Items.Where(i => i.KalemTipi == "HEADER").OrderBy(i => i.SiraNo).ToList();
                    var hIdx = headers.IndexOf(grandParent) + 1;
                    var parentSiblings = Items.Where(i => i.UstKalemId == grandParent.Id && i.KalemTipi == "ITEM").OrderBy(i => i.SiraNo).ToList();
                    var pIdx = parentSiblings.IndexOf(parent) + 1;
                    var mySiblings = Items.Where(i => i.UstKalemId == parent.Id).OrderBy(i => i.SiraNo).ToList();
                    var myIdx = mySiblings.IndexOf(item) + 1;
                    return $"{hIdx}.{pIdx}.{myIdx}";
                }
            }
        }
        return $"{item.SiraNo}";
    }

    // ─── ITEM CRUD ───────────────────────────────────────────

    private void AddItemUnder(QuoteItemModel header)
    {
        var maxSira = Items.Where(i => i.UstKalemId == header.Id && i.KalemTipi == "ITEM").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        Items.Add(new QuoteItemModel
        {
            Id = nextTempId--,
            KalemTipi = "ITEM",
            UstKalemId = header.Id,
            SiraNo = maxSira + 10,
            Aciklama = ""
        });
        NotifyChanged();
    }

    private void ToggleBold(QuoteItemModel item)
    {
        item.BaslikMi = !item.BaslikMi;
        NotifyChanged();
    }

    private void RemoveItem(QuoteItemModel item)
    {
        var childIds = Items.Where(i => i.UstKalemId == item.Id).Select(i => i.Id).ToList();
        foreach (var childId in childIds)
        {
            var grandChildren = Items.Where(i => i.UstKalemId == childId).ToList();
            Items.RemoveAll(i => grandChildren.Contains(i));
        }
        Items.RemoveAll(i => childIds.Contains(i.Id));
        Items.Remove(item);
        NotifyChanged();
    }

    private void UpdateField(QuoteItemModel item, string field, string? value)
    {
        switch (field)
        {
            case nameof(item.Aciklama): item.Aciklama = value ?? ""; break;
            case nameof(item.UrunKodu): item.UrunKodu = value; break;
            case nameof(item.Birim): item.Birim = value; break;
        }
        NotifyChanged();
    }

    private void UpdateNumericField(QuoteItemModel item, string field, string? value)
    {
        if (decimal.TryParse(value, out var num))
        {
            item.Miktar = num;
            item.Tutar = (item.Miktar ?? 0) * (item.BirimFiyat ?? 0);
        }
        NotifyChanged();
    }

    private void UpdatePriceField(QuoteItemModel item, string? value)
    {
        if (decimal.TryParse(value, out var num))
        {
            item.BirimFiyat = num;
            item.Tutar = (item.Miktar ?? 0) * (item.BirimFiyat ?? 0);
        }
        NotifyChanged();
    }

    private void NotifyChanged() => ItemsChanged.InvokeAsync(Items);

    // ─── ŞABLON FİLTRE & LOKALİZASYON ──────────────────────────

    private List<ArabaslikGrupModel> filteredGruplar
    {
        get
        {
            if (allGruplar == null) return new();
            // Tablo tipindekiler (TablTipi=1) her zaman uste, sonra Liste (TablTipi=2)
            var ordered = allGruplar
                .OrderBy(g => g.TablTipi)
                .ThenBy(g => g.SortOrder)
                .ThenBy(g => g.GrupAdi);
            if (string.IsNullOrWhiteSpace(abSearchQuery)) return ordered.ToList();
            var q = abSearchQuery.Trim();
            return ordered.Where(g =>
                g.GrupAdi.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (g.GrupAdi_EN ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (groupDetailsCache.TryGetValue(g.Id, out var dl) &&
                    dl.Any(d => (d.SatirMetni ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                                (d.SatirMetni_EN ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)))
            ).ToList();
        }
    }

    private string GetGrupLocalizedName(ArabaslikGrupModel g) => Dil switch
    {
        "EN" => g.GrupAdi_EN,
        "DE" => g.GrupAdi_DE,
        "FR" => g.GrupAdi_FR,
        "RU" => g.GrupAdi_RU,
        "RO" => g.GrupAdi_RO,
        "AR" => g.GrupAdi_AR,
        _ => ""
    };

    private string GetDetayLocalizedText(ArabaslikDetayModel d) => Dil switch
    {
        "EN" when !string.IsNullOrEmpty(d.SatirMetni_EN) => d.SatirMetni_EN,
        "DE" when !string.IsNullOrEmpty(d.SatirMetni_DE) => d.SatirMetni_DE,
        "FR" when !string.IsNullOrEmpty(d.SatirMetni_FR) => d.SatirMetni_FR,
        "RU" when !string.IsNullOrEmpty(d.SatirMetni_RU) => d.SatirMetni_RU,
        "RO" when !string.IsNullOrEmpty(d.SatirMetni_RO) => d.SatirMetni_RO,
        "AR" when !string.IsNullOrEmpty(d.SatirMetni_AR) => d.SatirMetni_AR,
        _ => d.SatirMetni
    };

    // ─── KLASÖR / EXPAND ────────────────────────────────────

    /// <summary>Görünüm açısından genişletilmiş mi? Manuel expand + arama eşleşmesi otomatik açar.</summary>
    private bool IsExpandedView(ArabaslikGrupModel g)
    {
        if (expandedGroupIds.Contains(g.Id)) return true;
        if (string.IsNullOrWhiteSpace(abSearchQuery)) return false;
        var q = abSearchQuery.Trim();
        return g.GrupAdi.Contains(q, StringComparison.OrdinalIgnoreCase) ||
               (g.GrupAdi_EN ?? "").Contains(q, StringComparison.OrdinalIgnoreCase);
    }

    private async Task ToggleGroup(int grupId)
    {
        if (expandedGroupIds.Contains(grupId))
        {
            expandedGroupIds.Remove(grupId);
        }
        else
        {
            expandedGroupIds.Add(grupId);
            await EnsureDetailsLoadedAsync(grupId);
        }
    }

    private async Task EnsureDetailsLoadedAsync(int grupId)
    {
        if (groupDetailsCache.ContainsKey(grupId)) return;
        try { groupDetailsCache[grupId] = await ArabaslikSvc.GetDetaylarAsync(grupId); }
        catch { groupDetailsCache[grupId] = new(); }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        abSearchQuery = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(abSearchQuery) || allGruplar == null) return;

        // Eşleşen grupların detaylarını arka planda yükle: arama metni başlık altındaki
        // satırlarda da görünebilsin
        var q = abSearchQuery.Trim();
        var matching = allGruplar.Where(g =>
            g.GrupAdi.Contains(q, StringComparison.OrdinalIgnoreCase) ||
            (g.GrupAdi_EN ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
        ).ToList();
        foreach (var g in matching) await EnsureDetailsLoadedAsync(g.Id);
    }

    private void ClearSearch() => abSearchQuery = string.Empty;

    // ─── GRUP-BAZLI DETAY ARAMA ─────────────────────────────

    private void SetGroupQuery(int grupId, string q)
    {
        if (string.IsNullOrWhiteSpace(q)) groupQueries.Remove(grupId);
        else groupQueries[grupId] = q;
    }

    private List<ArabaslikDetayModel> FilterGroupDetails(int grupId, List<ArabaslikDetayModel> details)
    {
        if (!groupQueries.TryGetValue(grupId, out var q) || string.IsNullOrWhiteSpace(q))
            return details;
        var qq = q.Trim();
        return details.Where(d =>
            (d.SatirMetni ?? "").Contains(qq, StringComparison.OrdinalIgnoreCase) ||
            (d.SatirMetni_EN ?? "").Contains(qq, StringComparison.OrdinalIgnoreCase) ||
            (d.Deger ?? "").Contains(qq, StringComparison.OrdinalIgnoreCase)
        ).ToList();
    }

    // ─── ŞABLON DETAY INLINE EDIT (Fiyat / Deger) ────────────

    private async Task UpdateDetayFiyat(ArabaslikDetayModel d, string? raw)
    {
        decimal? newPrice = null;
        if (!string.IsNullOrWhiteSpace(raw) && decimal.TryParse(raw, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v))
            newPrice = v;
        else if (!string.IsNullOrWhiteSpace(raw) && decimal.TryParse(raw, out var v2))
            newPrice = v2;

        d.Fiyat = newPrice;
        try { await ArabaslikSvc.UpdateDetayFiyatAsync(d.Id, newPrice); }
        catch { /* sessiz: kullanici yenilediginde mevcut deger geri yuklenir */ }
    }

    private async Task UpdateDetayDeger(ArabaslikDetayModel d, string? raw)
    {
        d.Deger = raw ?? "";
        try { await ArabaslikSvc.UpdateDetayDegerAsync(d.Id, d.Deger); }
        catch { }
    }

    // ─── EKLE: Grup veya Tek Kalem ──────────────────────────

    private async Task AddGroupAsHeader(ArabaslikGrupModel g)
    {
        if (!groupDetailsCache.TryGetValue(g.Id, out var detaylar))
        {
            try { detaylar = await ArabaslikSvc.GetDetaylarAsync(g.Id); groupDetailsCache[g.Id] = detaylar; }
            catch { detaylar = new(); }
        }
        ImportGroupInternal(g, detaylar);
        NotifyChanged();
    }

    private void ImportGroupInternal(ArabaslikGrupModel g, List<ArabaslikDetayModel> detaylar)
    {
        var maxSira = Items.Where(i => i.KalemTipi == "HEADER").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        var headerText = Dil != "TR" ? GetGrupLocalizedName(g) : "";
        var displayName = !string.IsNullOrEmpty(headerText) ? headerText : g.GrupAdi;

        var headerId = nextTempId--;
        Items.Add(new QuoteItemModel
        {
            Id = headerId,
            KalemTipi = "HEADER",
            BaslikMi = true,
            SiraNo = maxSira + 10,
            Aciklama = displayName
        });

        int childSira = 0;
        foreach (var d in detaylar)
        {
            childSira += 10;
            var itemText = GetDetayLocalizedText(d);
            if (g.TablTipi == 1)
            {
                Items.Add(new QuoteItemModel
                {
                    Id = nextTempId--,
                    KalemTipi = "SPEC",
                    UstKalemId = headerId,
                    SiraNo = childSira,
                    Aciklama = itemText,
                    Birim = d.Deger
                });
            }
            else
            {
                Items.Add(new QuoteItemModel
                {
                    Id = nextTempId--,
                    KalemTipi = "ITEM",
                    UstKalemId = headerId,
                    SiraNo = childSira,
                    Aciklama = itemText,
                    BirimFiyat = d.Fiyat,
                    Miktar = d.Fiyat.HasValue ? 1 : null,
                    Tutar = d.Fiyat,
                    Birim = d.Fiyat.HasValue ? "AD" : null
                });
            }
        }
    }

    /// <summary>Tek bir detay satırını kalem olarak ekler. parentHeader verilmezse uygun başlık seçilir/oluşturulur.</summary>
    private void AddDetayAsItem(ArabaslikGrupModel g, ArabaslikDetayModel d, QuoteItemModel? parentHeader = null)
    {
        // Hedef başlığı bul: verilen, son uygun olan veya yeni oluşturulan
        QuoteItemModel? header = parentHeader;
        if (header == null)
        {
            // Aynı grup adında zaten bir HEADER varsa onu kullan, yoksa yeni oluştur
            var displayName = Dil != "TR" && !string.IsNullOrEmpty(GetGrupLocalizedName(g)) ? GetGrupLocalizedName(g) : g.GrupAdi;
            header = Items.FirstOrDefault(i => i.KalemTipi == "HEADER" &&
                                              string.Equals(i.Aciklama, displayName, StringComparison.OrdinalIgnoreCase));
            if (header == null)
            {
                var maxSira = Items.Where(i => i.KalemTipi == "HEADER").Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
                header = new QuoteItemModel
                {
                    Id = nextTempId--,
                    KalemTipi = "HEADER",
                    BaslikMi = true,
                    SiraNo = maxSira + 10,
                    Aciklama = displayName
                };
                Items.Add(header);
            }
        }

        var childSira = Items.Where(i => i.UstKalemId == header.Id &&
                                         (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"))
                             .Select(i => i.SiraNo).DefaultIfEmpty(0).Max();
        var itemText = GetDetayLocalizedText(d);

        if (g.TablTipi == 1)
        {
            Items.Add(new QuoteItemModel
            {
                Id = nextTempId--,
                KalemTipi = "SPEC",
                UstKalemId = header.Id,
                SiraNo = childSira + 10,
                Aciklama = itemText,
                Birim = d.Deger
            });
        }
        else
        {
            Items.Add(new QuoteItemModel
            {
                Id = nextTempId--,
                KalemTipi = "ITEM",
                UstKalemId = header.Id,
                SiraNo = childSira + 10,
                Aciklama = itemText,
                BirimFiyat = d.Fiyat,
                Miktar = d.Fiyat.HasValue ? 1 : null,
                Tutar = d.Fiyat,
                Birim = d.Fiyat.HasValue ? "AD" : null
            });
        }
        NotifyChanged();
    }

    // ─── DRAG & DROP ───────────────────────────────────────

    private void OnDragStartGroup(ArabaslikGrupModel g)
    {
        dragType = "group";
        dragGroup = g;
        dragInProgress = true;
    }

    private void OnDragStartDetay(ArabaslikGrupModel g, ArabaslikDetayModel d)
    {
        dragType = "detay";
        dragGroup = g;
        dragDetay = d;
        dragInProgress = true;
    }

    private void OnDragStartQuoteItem(QuoteItemModel item)
    {
        dragType = "quote-item";
        dragQuoteItem = item;
        draggingQuoteItemId = item.Id;
        dragInProgress = true;
    }

    private void OnDragEnd()
    {
        dragType = null;
        dragGroup = null;
        dragDetay = null;
        dragQuoteItem = null;
        draggingQuoteItemId = null;
        dragOverItemId = null;
        dragOverLeftPane = false;
        dragInProgress = false;
    }

    private void OnDragEnterLeftPane()
    {
        if (dragType == "group" || dragType == "detay") dragOverLeftPane = true;
    }

    private void OnDragLeaveLeftPane()
    {
        dragOverLeftPane = false;
    }

    private void OnDragEnterItem(QuoteItemModel item)
    {
        dragOverItemId = item.Id;
    }

    private void OnDragLeaveItem(QuoteItemModel item)
    {
        if (dragOverItemId == item.Id) dragOverItemId = null;
    }

    private async Task OnDropOnLeftPane()
    {
        // Belirli bir hedef satıra düşmediyse: panele genel ekleme
        if (dragType == "group" && dragGroup != null)
        {
            await AddGroupAsHeader(dragGroup);
        }
        else if (dragType == "detay" && dragGroup != null && dragDetay != null)
        {
            AddDetayAsItem(dragGroup, dragDetay);
        }
        OnDragEnd();
    }

    private async Task OnDropOnItem(QuoteItemModel target)
    {
        if (dragType == "group" && dragGroup != null)
        {
            await AddGroupAsHeader(dragGroup);
        }
        else if (dragType == "detay" && dragGroup != null && dragDetay != null)
        {
            // HEADER üzerine düştüyse: bu başlığın altına ekle
            // ITEM/SPEC üzerine düştüyse: o satırın başlığına ekle
            QuoteItemModel? header = null;
            if (target.KalemTipi == "HEADER") header = target;
            else if (target.UstKalemId.HasValue)
            {
                header = Items.FirstOrDefault(i => i.Id == target.UstKalemId && i.KalemTipi == "HEADER");
                if (header == null && target.UstKalemId.HasValue)
                {
                    var p = Items.FirstOrDefault(i => i.Id == target.UstKalemId);
                    if (p?.UstKalemId.HasValue == true)
                        header = Items.FirstOrDefault(i => i.Id == p.UstKalemId && i.KalemTipi == "HEADER");
                }
            }
            AddDetayAsItem(dragGroup, dragDetay, header);
        }
        else if (dragType == "quote-item" && dragQuoteItem != null && dragQuoteItem.Id != target.Id)
        {
            ReorderQuoteItems(dragQuoteItem, target);
        }
        OnDragEnd();
        await Task.CompletedTask;
    }

    /// <summary>Aynı seviye/kardeş kalemler arasında sürükle-bırak ile yeniden sıralama.
    /// insertBefore=true ise src dest'in ustune, false ise altina yerlestirilir.</summary>
    private void ReorderQuoteItems(QuoteItemModel src, QuoteItemModel dest, bool insertBefore = true)
    {
        // Sadece aynı UstKalemId altında ve uyumlu tipte ise (HEADER<->HEADER, ITEM/SPEC<->ITEM/SPEC, SUB_ITEM/OPTION<->SUB_ITEM/OPTION)
        bool sameLevel = src.UstKalemId == dest.UstKalemId;
        bool compatibleHeaders = src.KalemTipi == "HEADER" && dest.KalemTipi == "HEADER";
        bool compatibleChildren =
            (src.KalemTipi == "ITEM" || src.KalemTipi == "SPEC") &&
            (dest.KalemTipi == "ITEM" || dest.KalemTipi == "SPEC");
        bool compatibleSubs =
            (src.KalemTipi == "SUB_ITEM" || src.KalemTipi == "OPTION") &&
            (dest.KalemTipi == "SUB_ITEM" || dest.KalemTipi == "OPTION");

        if (!sameLevel || !(compatibleHeaders || compatibleChildren || compatibleSubs)) return;

        // Aynı kardeş listesini al ve src'yi dest'in önüne taşı
        IEnumerable<QuoteItemModel> siblingSrc;
        if (compatibleHeaders)
        {
            siblingSrc = Items.Where(i => i.KalemTipi == "HEADER");
        }
        else if (compatibleChildren)
        {
            siblingSrc = Items.Where(i => i.UstKalemId == src.UstKalemId &&
                                          (i.KalemTipi == "ITEM" || i.KalemTipi == "SPEC"));
        }
        else
        {
            siblingSrc = Items.Where(i => i.UstKalemId == src.UstKalemId &&
                                          (i.KalemTipi == "SUB_ITEM" || i.KalemTipi == "OPTION"));
        }

        var siblings = siblingSrc.OrderBy(i => i.SiraNo).ToList();
        siblings.Remove(src);
        var destIdx = siblings.IndexOf(dest);
        if (destIdx < 0) return;
        siblings.Insert(insertBefore ? destIdx : destIdx + 1, src);

        // SiraNo'ları yeniden ata
        for (int i = 0; i < siblings.Count; i++)
            siblings[i].SiraNo = (i + 1) * 10;

        NotifyChanged();
    }

    // ─── YENİ ŞABLON GRUBU (INLINE) ─────────────────────────

    private void ToggleNewGroupForm()
    {
        showNewGroupForm = !showNewGroupForm;
        if (showNewGroupForm) { newGroupName = ""; newGroupTablTipi = 1; }
    }

    private async Task OnNewGroupKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newGroupName)) await SaveNewGroup();
        else if (e.Key == "Escape") showNewGroupForm = false;
    }

    private async Task SaveNewGroup()
    {
        if (string.IsNullOrWhiteSpace(newGroupName)) return;
        try
        {
            var maxSort = (allGruplar?.Select(x => x.SortOrder).DefaultIfEmpty(0).Max() ?? 0) + 10;
            var newGrup = new ArabaslikGrupModel
            {
                GrupAdi = newGroupName.Trim(),
                GrupAdi_EN = "",
                GrupAdi_FR = "",
                GrupAdi_DE = "",
                GrupAdi_RO = "",
                GrupAdi_AR = "",
                GrupAdi_RU = "",
                TablTipi = newGroupTablTipi,
                SortOrder = maxSort,
                IsActive = true
            };
            await ArabaslikSvc.SaveGrupWithDetaylarAsync(newGrup, new List<ArabaslikDetayModel>());
            showNewGroupForm = false;
            await LoadGruplarAsync();
            // Yeni grubu otomatik genişlet
            if (newGrup.Id > 0)
            {
                expandedGroupIds.Add(newGrup.Id);
                groupDetailsCache[newGrup.Id] = new();
            }
        }
        catch { /* sessiz: form açık kalır */ }
    }

    // ─── GRUP DUZENLE / SIL ─────────────────────────────────

    private void StartEditGrup(ArabaslikGrupModel g)
    {
        editingGrup = new ArabaslikGrupModel
        {
            Id = g.Id, GrupAdi = g.GrupAdi,
            GrupAdi_EN = g.GrupAdi_EN, GrupAdi_FR = g.GrupAdi_FR,
            GrupAdi_DE = g.GrupAdi_DE, GrupAdi_RO = g.GrupAdi_RO,
            GrupAdi_AR = g.GrupAdi_AR, GrupAdi_RU = g.GrupAdi_RU,
            TablTipi = g.TablTipi, SortOrder = g.SortOrder,
            IsActive = g.IsActive, CreatedDate = g.CreatedDate, CreatedBy = g.CreatedBy,
        };
        showGrupEdit = true;
    }

    private void CancelGrupEdit()
    {
        showGrupEdit = false;
        editingGrup = null;
    }

    private async Task SaveGrupEditAsync()
    {
        if (editingGrup == null || string.IsNullOrWhiteSpace(editingGrup.GrupAdi)) return;
        try
        {
            await ArabaslikSvc.SaveGrupAsync(editingGrup);
            // Local cache guncelle
            var idx = allGruplar?.FindIndex(g => g.Id == editingGrup.Id) ?? -1;
            if (idx >= 0 && allGruplar != null) allGruplar[idx] = editingGrup;
        }
        catch { }
        showGrupEdit = false;
        editingGrup = null;
    }

    private async Task DeleteGrupAsync(int grupId)
    {
        try
        {
            await ArabaslikSvc.DeleteGrupAsync(grupId);
            allGruplar?.RemoveAll(g => g.Id == grupId);
            expandedGroupIds.Remove(grupId);
            groupDetailsCache.Remove(grupId);
            groupQueries.Remove(grupId);
            newKalemText.Remove(grupId);
        }
        catch { }
        confirmDeleteGrupId = null;
    }

    // ─── DETAY DUZENLE / SIL / EKLE ─────────────────────────

    private string detayDegerBuffer = "";
    private decimal? detayFiyatBuffer;

    private void StartEditDetay(ArabaslikGrupModel g, ArabaslikDetayModel d)
    {
        editingDetayGrup = g;
        editingDetay = new ArabaslikDetayModel
        {
            Id = d.Id, GrupId = d.GrupId,
            SatirMetni = d.SatirMetni,
            SatirMetni_EN = d.SatirMetni_EN, SatirMetni_FR = d.SatirMetni_FR,
            SatirMetni_DE = d.SatirMetni_DE, SatirMetni_RO = d.SatirMetni_RO,
            SatirMetni_AR = d.SatirMetni_AR, SatirMetni_RU = d.SatirMetni_RU,
            Fiyat = d.Fiyat, ParaBirimi = d.ParaBirimi, SortOrder = d.SortOrder,
        };
        detayDegerBuffer = d.Deger;
        detayFiyatBuffer = d.Fiyat;
        showDetayEdit = true;
    }

    private void CancelDetayEdit()
    {
        showDetayEdit = false;
        editingDetay = null;
        editingDetayGrup = null;
    }

    private async Task SaveDetayEditAsync()
    {
        if (editingDetay == null || editingDetayGrup == null || string.IsNullOrWhiteSpace(editingDetay.SatirMetni)) return;
        try
        {
            // TablTipi'ye gore Fiyat veya Deger uygula
            if (editingDetayGrup.TablTipi == 1)
                editingDetay.Deger = detayDegerBuffer ?? "";
            else
                editingDetay.Fiyat = detayFiyatBuffer;

            await ArabaslikSvc.UpdateDetayAsync(editingDetay);
            // Cache'i guncelle
            if (groupDetailsCache.TryGetValue(editingDetayGrup.Id, out var details))
            {
                var idx = details.FindIndex(x => x.Id == editingDetay.Id);
                if (idx >= 0) details[idx] = editingDetay;
            }
        }
        catch { }
        showDetayEdit = false;
        editingDetay = null;
        editingDetayGrup = null;
    }

    private async Task DeleteDetayAsync(int detayId)
    {
        try
        {
            await ArabaslikSvc.DeleteDetayAsync(detayId);
            foreach (var kvp in groupDetailsCache.ToList())
                kvp.Value.RemoveAll(x => x.Id == detayId);
        }
        catch { }
        confirmDeleteDetayId = null;
    }

    private void OnNewKalemInput(int grupId, string? value)
    {
        newKalemText[grupId] = value ?? "";
    }

    private async Task OnNewKalemKey(KeyboardEventArgs e, ArabaslikGrupModel g)
    {
        if (e.Key == "Enter") await AddNewKalemAsync(g);
        else if (e.Key == "Escape") newKalemText[g.Id] = "";
    }

    private async Task AddNewKalemAsync(ArabaslikGrupModel g)
    {
        if (!newKalemText.TryGetValue(g.Id, out var txt) || string.IsNullOrWhiteSpace(txt)) return;
        var details = groupDetailsCache.TryGetValue(g.Id, out var dl) ? dl : null;
        if (details == null)
        {
            try { details = await ArabaslikSvc.GetDetaylarAsync(g.Id); groupDetailsCache[g.Id] = details; }
            catch { details = new(); groupDetailsCache[g.Id] = details; }
        }
        var nextSort = (details.Count > 0 ? details.Max(x => x.SortOrder) : 0) + 10;
        var d = new ArabaslikDetayModel { GrupId = g.Id, SatirMetni = txt.Trim(), SortOrder = nextSort };
        try
        {
            await ArabaslikSvc.AddDetayAsync(d);
            details.Add(d);
            newKalemText[g.Id] = "";
            // Eklendigi grup expanded olsun
            expandedGroupIds.Add(g.Id);
        }
        catch { }
    }
}
