    // Inline yeni kalem ekleme: grup id -> text buffer
    private Dictionary<int, string> newKalemText = new();

    // Drag & drop state
    private string? dragType;            // "group" | "detay" | "quote-item"
    private ArabaslikGrupModel? dragGroup;
    private ArabaslikDetayModel? dragDetay;
    private QuoteItemModel? dragQuoteItem;
