    private string CurrencySymbol => (ParaBirimi ?? "").ToUpperInvariant() switch
    {
        "EUR" => "€",
        "USD" => "$",
        "TRY" or "TL" => "₺",
        "GBP" => "£",
        "RUB" => "₽",
        _     => ParaBirimi ?? ""
    };

    private static readonly System.Globalization.CultureInfo InvCulture = System.Globalization.CultureInfo.InvariantCulture;

    private int nextTempId = -1;

    // Şablon (sağ panel) state
