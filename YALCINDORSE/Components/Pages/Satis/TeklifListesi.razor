    // ── Hazır Teklif ──────────────────────────────────────────────────

    private async Task LoadHazirTeklifInfoAsync()
    {
        if (quotes == null || !quotes.Any()) return;
        try
        {
            var ids = quotes.Select(q => q.Id);
            hazirTeklifInfo = await AttachSvc.GetHazirTeklifBulkAsync(ids);
        }
        catch { /* sessiz kal */ }
        StateHasChanged();
    }

    private async Task HazirTeklifClickAsync(int quoteId)
    {
        // Dosya varsa → DB'den baytlari cek, temp'e yaz, ac
        if (hazirTeklifInfo.TryGetValue(quoteId, out var info) && info != null)
        {
            isUploading = true;
            StateHasChanged();
            try
            {
                var (bytes, fileName) = await AttachSvc.GetHazirTeklifContentAsync(quoteId);
                if (bytes == null || bytes.Length == 0)
                {
                    await ShowToastError("Dosya icerigi bulunamadi.");
                    return;
                }
                // Temp klasore yaz
                var tempDir = Path.Combine(Path.GetTempPath(), "YLTeklif");
                Directory.CreateDirectory(tempDir);
                var tempPath = Path.Combine(tempDir, fileName);
                await File.WriteAllBytesAsync(tempPath, bytes);
                await Launcher.OpenAsync(new OpenFileRequest { File = new ReadOnlyFile(tempPath) });
            }
            catch (Exception ex)
            {
                await ShowToastError($"Dosya acilamadi: {ex.Message}");
            }
            finally
            {
                isUploading = false;
                StateHasChanged();
            }
            return;
        }

        // Dosya yoksa → FilePicker ile sec, DB'ye kaydet (BYTEA)
        try
        {
            var pickOpts = new PickOptions
            {
                PickerTitle = "Hazir Teklif Sec (.pdf, .doc, .docx)",
                FileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.WinUI,       new[] { ".pdf", ".doc", ".docx" } },
                    { DevicePlatform.iOS,         new[] { "com.adobe.pdf", "org.openxmlformats.wordprocessingml.document" } },
                    { DevicePlatform.Android,     new[] { "application/pdf", "application/msword",
                                                          "application/vnd.openxmlformats-officedocument.wordprocessingml.document" } },
                    { DevicePlatform.MacCatalyst, new[] { ".pdf", ".doc", ".docx" } }
                })
            };

            var picked = await FilePicker.PickAsync(pickOpts);
            if (picked == null) return;

            isUploading = true;
            StateHasChanged();

            // DB'ye BYTEA olarak kaydet (herhangi bir makineden erisim icin)
            using var stream = await picked.OpenReadAsync();
            await AttachSvc.SaveHazirTeklifToDbAsync(quoteId, stream, picked.FileName);

            // Dictionary guncelle
            var updated = await AttachSvc.GetHazirTeklifBulkAsync(new[] { quoteId });
            hazirTeklifInfo[quoteId] = updated.GetValueOrDefault(quoteId);

            await ShowToastSuccess($"Hazir teklif kaydedildi: {picked.FileName}");
        }
        catch (Exception ex)
        {
            await ShowToastError($"Dosya yuklenemedi: {ex.Message}");
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteHazirTeklifAsync(int quoteId)
    {
        try
        {
            await AttachSvc.DeleteHazirTeklifAsync(quoteId);
            hazirTeklifInfo[quoteId] = null;
            StateHasChanged();
