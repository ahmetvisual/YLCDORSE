    private async Task ChangeStatusAsync(int quoteId, string newStatus)
    {
        isTransitioning = true;
        StateHasChanged();
        try
        {
            await QuoteService.TransitionStatusAsync(quoteId, newStatus);
            await LoadQuotesAsync();
            selectedQuoteId = quoteId;
            detailTab = "rev";
            expandedRevisions = await QuoteService.GetRevisionsAsync(quoteId);
            isTransitioning = false;
            await ShowToastSuccess($"Durum guncellendi: {GetStatusName(newStatus)}");
        }
        catch (Exception ex)
        {
            isTransitioning = false;
            await ShowToastError($"Durum degisikligi hatasi: {ex.Message}");
        }
    }

    private async Task ShowToastSuccess(string msg)
    {
        toastIsSuccess = true; toastMessage = msg; showToast = true;
        StateHasChanged();
        await Task.Delay(2000);
        showToast = false;
        StateHasChanged();
    }

    private async Task ShowToastError(string msg)
    {
        toastIsSuccess = false; toastMessage = msg; showToast = true;
        StateHasChanged();
        await Task.Delay(2500);
        showToast = false;
        StateHasChanged();
    }

    private record StatusTransition(string Label, string NewStatus, string CssClass);

    private List<StatusTransition> GetAvailableTransitions(string currentStatus) => currentStatus switch
    {
        "Draft"          => new() { new("Gonder", "Sent", "btn-ts-sent") },
        "Sent"           => new() { new("Onaya Sun", "WaitingApproval", "btn-ts-waiting"), new("Siparis", "ORDER", "btn-ts-order") },
        "WaitingApproval"=> new() { new("Onayla", "Approved", "btn-ts-approved"), new("Reddet", "Rejected", "btn-ts-rejected") },
        "Approved"       => new() { new("Siparis", "ORDER", "btn-ts-order") },
        "OPEN"           => new() { new("Siparis", "ORDER", "btn-ts-order"), new("Kapat", "CLOSED", "btn-ts-closed") },
        "ORDER"          => new() { new("Kapat", "CLOSED", "btn-ts-closed") },
        _                => new()
    };

    private string GetStatusName(string code) => code switch {
        "Draft"           => "Taslak",
        "Sent"            => "Gonderildi",
        "WaitingApproval" => "Onay Bek.",
        "Approved"        => "Onaylandi",
        "Rejected"        => "Reddedildi",
        "OPEN"            => "Acik",
        "ORDER"           => "Siparis",
        "CLOSED"          => "Kapali",
        _                 => code
    };

    private string GetStatusChipClass(string status) => status switch {
        "Draft"           => "chip-draft",    // mavi-gri
        "Sent"            => "chip-sent",     // acik mavi
        "WaitingApproval" => "chip-waiting",
        "Approved"        => "chip-approved",
        "Rejected"        => "chip-rejected",
        "OPEN"            => "chip-open",     // mor
        "ORDER"           => "chip-order",    // yesil
        "CLOSED"          => "chip-closed",   // sicak gri (taslaktan farkli!)
        _                 => ""
    };

    private string GetStandingChipClass(string s) => s switch {
        "HOT"  => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _      => ""
    };

