@page "/satis/teklif-listesi"
@using YALCINDORSE.Services
@using YALCINDORSE.Components.Pages.CRM
@inject QuoteService QuoteService
@inject TouchService TouchSvc
@inject NavigationManager Nav
@inject DesktopWindowService WindowService
@inject QuoteDocumentService DocSvc
@inject QuoteAttachmentService AttachSvc

<div class="qt-shell">

    <!-- ===== STATUS SEKMELERI + AKSIYONLAR ===== -->
    <div class="qt-status-tabs">
        <button class="qt-stab @(selectedDurumTab == "ALL"      ? "qt-stab-active" : "")" @onclick='() => SetDurumTab("ALL")'>Tumu</button>
        <button class="qt-stab @(selectedDurumTab == "AWAIT"    ? "qt-stab-active" : "")" @onclick='() => SetDurumTab("AWAIT")'>Cevap Beklenenler</button>
        <button class="qt-stab @(selectedDurumTab == "APPROVED" ? "qt-stab-active" : "")" @onclick='() => SetDurumTab("APPROVED")'>Onaylananlar</button>
        <button class="qt-stab @(selectedDurumTab == "REJECTED" ? "qt-stab-active" : "")" @onclick='() => SetDurumTab("REJECTED")'>Reddedilenler</button>
        <div class="qt-stab-spacer"></div>
        <div class="qt-stab-actions">
            <button class="btn-secondary" @onclick="ReloadAsync" disabled="@isLoading">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" style="@(isLoading ? "animation:spin 1s linear infinite" : "")">
                    <polyline points="23 4 23 10 17 10"/>
                    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                </svg>
                Yenile
            </button>
            <button class="btn-add" @onclick="GoToNewQuote">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                <span>Teklif Olustur</span>
            </button>
        </div>
    </div>

    <!-- ===== FILTER BAR ===== -->
    <div class="qt-filter-bar">
        <div class="crm-search-box qt-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" class="form-input" placeholder="Teklif No, Musteri, Satici ara..."
                   value="@searchQuery" @oninput="OnSearchInput" />
        </div>

        <div class="qt-filter-chips">
            @foreach (var f in puanFilters)
            {
                <button class="touch-chip-btn @(selectedPuan == f.Key ? f.Value : "")"
                        @onclick="() => SetPuanFilter(f.Key)">
                    @(f.Key switch { "ALL" => "Tumu", "DRAFT" => "Taslak", _ => f.Key })
                </button>
            }
        </div>
    </div>

    <!-- ===== ICERIK ===== -->
    @if (isLoading)
    {
        <div class="quote-loading-state">
            <div class="spinner" style="border-top-color: var(--yl-primary); margin: 0 auto 12px;"></div>
            Yukleniyor...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <div class="qt-layout">

            <!-- ========== SOL: TEKLIF LISTESI ========== -->
            <div class="qt-list-panel @(selectedQuoteId > 0 ? "qt-with-detail" : "")">
                <div class="quote-grid-container">
                    <div class="quote-table-wrapper">
                        <table class="quote-grid qt-merged-grid">
                            <thead>
                                <tr>
                                    <th>Musteri</th>
                                    <th>Teklif No</th>
                                    <th>Duzenleme Tarihi</th>
                                    <th class="qt-hide-sm">Durum</th>
                                    <th class="qt-hide-sm">Puan</th>
                                    <th style="text-align:center; width:56px;">Touch</th>
                                    <th class="qt-hide-md">Sonraki Temas</th>
                                    <th class="qt-hide-md qt-th-sort">
                                        Teklif Toplami
                                        <svg viewBox="0 0 10 16" fill="none" stroke="currentColor" stroke-width="1.8"
                                             width="9" height="9" style="margin-left:3px; vertical-align:middle; opacity:0.4;">
                                            <path d="M5 1 L1 6 M5 1 L9 6" stroke-linecap="round"/>
                                            <path d="M5 15 L1 10 M5 15 L9 10" stroke-linecap="round"/>
                                        </svg>
                                    </th>
                                    <th style="width:90px;">Isl.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (quotes == null || !quotes.Any())
                                {
                                    <tr>
                                        <td colspan="9" class="quote-empty-state">Goruntulenecek kayit bulunamadi.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var quote in quotes)
                                    {
                                        var touchInfo = quoteTouchInfo.GetValueOrDefault(quote.Id);
                                        var isSelected = selectedQuoteId == quote.Id;
                                        <tr class="@(isSelected ? "qt-selected" : "")"
                                            @onclick="() => SelectQuoteAsync(quote.Id)">
                                            <!-- 1. Musteri -->
                                            <td>
                                                <div class="quote-customer">@quote.Musteri</div>
                                                @if (!string.IsNullOrEmpty(quote.Ilgili))
                                                {
                                                    <div class="quote-contact">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                             style="width:10px;height:10px;margin-right:2px;vertical-align:middle;">
                                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                                            <circle cx="12" cy="7" r="4"/>
                                                        </svg>
                                                        @quote.Ilgili
                                                    </div>
                                                }
                                            </td>
                                            <!-- 2. Teklif No -->
                                            <td>
                                                <div class="quote-no">@quote.TeklifNo</div>
                                                @if (quote.Rev > 0)
                                                {
                                                    <div class="quote-rev">Rev @quote.Rev</div>
                                                }
                                            </td>
                                            <!-- 3. Duzenleme Tarihi -->
                                            <td class="quote-date-cell">
                                                <div>@quote.TalepTarihi.ToString("dd.MM.yyyy")</div>
                                                <div class="quote-date-rel">@GetRelativeTime(quote.TalepTarihi)</div>
                                            </td>
                                            <!-- 4. Durum -->
                                            <td class="qt-hide-sm">
                                                <span class="yl-chip @GetStatusChipClass(quote.Durum)">
                                                    @GetStatusName(quote.Durum)
                                                </span>
                                            </td>
                                            <!-- 5. Puan -->
                                            <td class="qt-hide-sm">
                                                <span class="yl-chip @GetStandingChipClass(quote.Puan)">@quote.Puan</span>
                                            </td>
                                            <!-- 6. Touch -->
                                            <td style="text-align:center; font-weight:700; color:var(--yl-accent);">
                                                @(touchInfo?.TouchCount ?? 0)
                                            </td>
                                            <!-- 7. Sonraki Temas -->
                                            <td class="qt-hide-md" style="font-size:0.72rem;">
                                                @if (touchInfo?.NextTouchDate != null)
                                                {
                                                    var isOverdue = touchInfo.NextTouchDate < DateTime.Today;
                                                    var isToday = touchInfo.NextTouchDate?.Date == DateTime.Today;
                                                    @if (isOverdue) { <span class="overdue-dot"></span> }
                                                    else if (isToday) { <span class="today-dot"></span> }
                                                    <span style="@(isOverdue ? "color:#A32D2D;font-weight:700" : isToday ? "color:#854F0B;font-weight:700" : "")">
                                                        @touchInfo.NextTouchDate?.ToString("dd.MM.yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="color:var(--yl-text-light);">—</span>
                                                }
                                            </td>
                                            <!-- 8. Teklif Toplami -->
                                            <td class="qt-hide-md quote-amount-cell">
                                                <span class="quote-amount">@quote.NetTutar.ToString("N2")</span>
                                                <span class="quote-currency">@quote.Para</span>
                                            </td>
                                            <!-- 9. ISL. -->
                                            <td @onclick:stopPropagation="true">
                                                <div class="quote-row-actions">
                                                    <button class="btn-expand" title="Duzenle" @onclick="() => EditQuote(quote.Id)">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px">
                                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                        </svg>
                                                    </button>
                                                    <button class="btn-expand" title="Kopyala" @onclick="() => CopyQuote(quote.Id)">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px">
                                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                                                        </svg>
                                                    </button>
                                                    <button class="btn-expand" title="Belge Olustur" @onclick="() => GenerateDocumentAsync(quote.Id)"
                                                            disabled="@isGenerating">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px">
                                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                                            <polyline points="14 2 14 8 20 8"/>
                                                            <line x1="12" y1="18" x2="12" y2="12"/>
                                                            <polyline points="9 15 12 18 15 15"/>
                                                        </svg>
                                                    </button>
                                                    @{
                                                        QuoteAttachmentModel? _rowHti = null;
                                                        hazirTeklifInfo.TryGetValue(quote.Id, out _rowHti);
                                                        bool hazirVar = _rowHti != null;
                                                        string _rowDosya = _rowHti?.DosyaAdi ?? "";
                                                    }
                                                    <button class="btn-expand"
                                                            style="@(hazirVar ? "color:#D97706;border-color:#D97706;background:rgba(217,119,6,0.08);" : "color:#9CA3AF;border-color:#D1D5DB;")"
                                                            title="@(hazirVar ? $"Hazir Teklif: {_rowDosya}" : "Hazir Teklif Ekle")"
                                                            @onclick="() => HazirTeklifClickAsync(quote.Id)"
                                                            disabled="@isUploading">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px">
                                                            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                                                        </svg>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="quote-grid-footer">
                        <span>Toplam @(quotes?.Count ?? 0) kayit gosteriliyor.</span>
                        @if (isTouchLoading)
                        {
                            <span style="color:var(--yl-text-light); font-size:0.75rem; margin-left:12px;">
                                Temas bilgileri yukleniyor...
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- ========== SAG: DETAY PANELI ========== -->
            @if (selectedQuoteId > 0)
            {
                var sel = quotes?.FirstOrDefault(q => q.Id == selectedQuoteId);
                <div class="qt-detail-panel">

                    <!-- Panel Basligi -->
                    <div class="qt-detail-header">
                        <div>
                            <div class="crm-detail-code">@sel?.TeklifNo</div>
                            <div style="font-weight:700; font-size:0.92rem; color:var(--yl-primary);">@sel?.Musteri</div>
                        </div>
                        <div style="display:flex; align-items:center; gap:6px;">
                            @if (sel != null)
                            {
                                <span class="yl-chip @GetStatusChipClass(sel.Durum)">@GetStatusName(sel.Durum)</span>
                                <span class="yl-chip @GetStandingChipClass(sel.Puan)">@sel.Puan</span>
                            }
                            <button class="btn-expand" title="Kapat" @onclick="CloseDetail">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px;">
                                    <line x1="18" y1="6" x2="6" y2="18"/>
                                    <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Tab Basliklar -->
                    <div class="qt-detail-tabs">
                        <button class="qt-detail-tab @(detailTab == "rev" ? "active" : "")"
                                @onclick='() => detailTab = "rev"'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                            Revizyonlar
                        </button>
                        <button class="qt-detail-tab @(detailTab == "touch" ? "active" : "")"
                                @onclick='() => detailTab = "touch"'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.39 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.5a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                            </svg>
                            Temas Gecmisi
                        </button>
                    </div>

                    <!-- Tab Icerigi -->
                    <div class="qt-detail-body">
                        @if (detailTab == "rev")
                        {
                            <!-- Durum Gecis Butonlari -->
                            @if (sel != null)
                            {
                                var transitions = GetAvailableTransitions(sel.Durum);
                                @if (transitions.Any())
                                {
                                    <div class="qt-transitions">
                                        @foreach (var tr in transitions)
                                        {
                                            <button class="btn-transition @tr.CssClass"
                                                    @onclick="() => ChangeStatusAsync(sel.Id, tr.NewStatus)"
                                                    disabled="@isTransitioning">
                                                @tr.Label
                                            </button>
                                        }
                                        <button class="btn-transition btn-revize" @onclick="() => EditQuote(sel.Id)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 style="width:11px;height:11px;margin-right:3px;vertical-align:text-bottom;">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                            Revize Et
                                        </button>
                                    </div>
                                }
                            }

                            <!-- Belge + Hazir Teklif Butonu -->
                            @if (sel != null)
                            {
                                /* Hazir teklif modeli - out var yerine dogrudan al */
                                QuoteAttachmentModel? selHazirModel = null;
                                hazirTeklifInfo.TryGetValue(sel.Id, out selHazirModel);
                                bool selHazir = selHazirModel != null;
                                string selDosyaAdi = selHazirModel?.DosyaAdi ?? "";
                                <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;align-items:center;">
                                    <button class="btn-transition" style="background:#f0f5ff;color:#185FA5;border-color:rgba(24,95,165,0.25);"
                                            @onclick="() => GenerateDocumentAsync(sel.Id)"
                                            disabled="@isGenerating">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             style="width:11px;height:11px;margin-right:3px;vertical-align:text-bottom;">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                            <polyline points="14 2 14 8 20 8"/>
                                            <line x1="12" y1="18" x2="12" y2="12"/>
                                            <polyline points="9 15 12 18 15 15"/>
                                        </svg>
                                        @(isGenerating ? "Hazirlaniyor..." : "Belge Indir")
                                    </button>
                                    <button class="btn-transition"
                                            style="@(selHazir ? "background:#FEF3C7;color:#D97706;border-color:rgba(217,119,6,0.3);" : "background:#F9FAFB;color:#6B7280;border-color:#D1D5DB;")"
                                            @onclick="() => HazirTeklifClickAsync(sel.Id)"
                                            disabled="@isUploading"
                                            title="@(selHazir ? selDosyaAdi : "Word/PDF teklif yukle")">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                             style="width:11px;height:11px;margin-right:3px;vertical-align:text-bottom;">
                                            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                                        </svg>
                                        @(isUploading ? "Yukleniyor..." : (selHazir ? "Hazir Teklif Ac" : "Hazir Teklif Ekle"))
                                    </button>
                                    @if (selHazir)
                                    {
                                        <button class="btn-transition"
                                                style="background:#FEF2F2;color:#B91C1C;border-color:rgba(185,28,28,0.25);padding:3px 8px;min-width:0;"
                                                title="Hazir teklifi sil"
                                                @onclick="() => DeleteHazirTeklifAsync(sel.Id)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 style="width:12px;height:12px;vertical-align:text-bottom;">
                                                <polyline points="3 6 5 6 21 6"/>
                                                <path d="M19 6l-1 14H6L5 6"/>
                                                <path d="M10 11v6M14 11v6"/>
                                                <path d="M9 6V4h6v2"/>
                                            </svg>
                                        </button>
                                    }
                                </div>
                                @if (selHazir)
                                {
                                    <div style="font-size:0.72rem;color:#D97706;margin-bottom:8px;display:flex;align-items:center;gap:4px;padding:4px 8px;background:#FFFBEB;border-radius:4px;border:1px solid rgba(217,119,6,0.2);">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;flex-shrink:0;">
                                            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                                        </svg>
                                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;" title="@selDosyaAdi">@selDosyaAdi</span>
                                    </div>
                                }
                            }

                            <!-- Revizyon Tablosu -->
                            @if (isDetailsLoading)
                            {
                                <div class="quote-detail-loading">Revizyonlar yukleniyor...</div>
                            }
                            else if (expandedRevisions == null || !expandedRevisions.Any())
                            {
                                <div class="quote-detail-loading">Henuz revizyon kaydi yok.</div>
                            }
                            else
                            {
                                <table class="detail-table">
                                    <thead>
                                        <tr>
                                            <th style="width:45px;text-align:center;">Rev</th>
                                            <th style="width:120px;">Tarih</th>
                                            <th>Degisiklik Detayi</th>
                                            <th style="width:90px;">Yapan</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var rev in expandedRevisions)
                                        {
                                            <tr>
                                                <td class="rev-number-cell">@rev.RevizyonNo</td>
                                                <td class="rev-meta-cell">@rev.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td class="rev-detail-cell">@rev.DegisiklikDetayi</td>
                                                <td class="rev-meta-cell">@rev.Yapan</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        }
                        else
                        {
                            <TouchDetailPanel TeklifId="selectedQuoteId"
                                              OnClose="CloseDetail"
                                              OnDataChanged="OnDetailChanged" />
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@* === TOAST === *@
@if (showToast)
{
    <div class="toast-overlay">
        <div class="toast-card">
            @if (toastIsSuccess)
            {
                <div class="toast-icon-success">
                    <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" opacity="0.15" fill="#059669" stroke="none"/>
                        <path class="check-path" d="M7 13l3 3 7-7"/>
                    </svg>
                </div>
                <div class="toast-title success">Basarili!</div>
            }
            else
            {
                <div class="toast-icon-error">
                    <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                </div>
                <div class="toast-title error">Hata!</div>
            }
            <div class="toast-message">@toastMessage</div>
        </div>
    </div>
}

@code {
    // Yukleme & hata
    private bool isLoading = true;
    private bool isDetailsLoading = false;
    private bool isTouchLoading = false;
    private bool isGenerating = false;
    private bool isUploading = false;
    private string? errorMessage;
    private bool showToast, toastIsSuccess;
    private string toastMessage = "";

    // Veri
    private List<QuoteListItemModel>? quotes;
    private List<QuoteRevisionModel>? expandedRevisions;
    private Dictionary<int, QuoteTouchSummary> quoteTouchInfo = new();
    private Dictionary<int, QuoteAttachmentModel?> hazirTeklifInfo = new();
    private bool isTransitioning = false;

    // Secim & tab
    private int selectedQuoteId;
    private string detailTab = "rev";

    // Filtreler
    private string searchQuery = "";
    private string selectedPuan = "ALL";
    private string selectedDurumTab = "ALL"; // ALL | AWAIT | APPROVED | REJECTED

    private readonly Dictionary<string, string> puanFilters = new()
    {
        { "ALL",   "active-all"   },
        { "HOT",   "active-hot"   },
        { "WARM",  "active-warm"  },
        { "COLD",  "active-cold"  },
        { "DRAFT", "active-draft" },
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadQuotesAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadQuotesAsync();
        if (selectedQuoteId > 0 && detailTab == "rev")
        {
            isDetailsLoading = true;
            StateHasChanged();
            try { expandedRevisions = await QuoteService.GetRevisionsAsync(selectedQuoteId); }
            catch { }
            finally { isDetailsLoading = false; }
        }
    }

    private async Task LoadQuotesAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // Durum sekme filtresi → birden fazla durum degeri
            IReadOnlyList<string>? durumList = selectedDurumTab switch
            {
                "AWAIT"    => new[] { "Sent", "WaitingApproval", "OPEN" },
                "APPROVED" => new[] { "Approved", "ORDER" },
                "REJECTED" => new[] { "Rejected", "CLOSED" },
                _          => null  // ALL — durum filtresi yok
            };

            var durumFilter = "";
            var puanParam = "";

            if (durumList == null)
            {
                // "Tumu" sekmesi: puan chip'leri eski mantikla calisir
                if (selectedPuan == "DRAFT")
                    durumFilter = "Draft";
                else if (selectedPuan != "ALL")
                    puanParam = selectedPuan;
            }
            else
            {
                // Sekme aktif: DRAFT chip yok sayilir, HOT/WARM/COLD ek filtre olarak gelir
                if (selectedPuan != "ALL" && selectedPuan != "DRAFT")
                    puanParam = selectedPuan;
            }

            quotes = await QuoteService.GetQuotesAsync(searchQuery, durumFilter, null, puanParam, durumList);

            isLoading = false;
            StateHasChanged();

            // Touch ve hazir teklif bilgilerini arka planda yukle
            await Task.WhenAll(LoadTouchInfoAsync(), LoadHazirTeklifInfoAsync());
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
        }
    }

    private async Task LoadTouchInfoAsync()
    {
        if (quotes == null || !quotes.Any()) return;

        isTouchLoading = true;
        quoteTouchInfo.Clear();
        StateHasChanged();

        foreach (var q in quotes)
        {
            try
            {
                var touches = await TouchSvc.GetTouchesForQuoteAsync(q.Id);
                var last = touches.LastOrDefault();
                quoteTouchInfo[q.Id] = new QuoteTouchSummary
                {
                    TouchCount    = touches.Count,
                    LastTouchDate = last?.TemasTarihi,
                    NextTouchDate = last?.SonrakiTemasTarihi,
                    HasManagement = touches.Any(t => t.YonetimDahilMi)
                };
            }
            catch
            {
                quoteTouchInfo[q.Id] = new QuoteTouchSummary();
            }
        }

        isTouchLoading = false;
        StateHasChanged();
    }

    private async Task SelectQuoteAsync(int quoteId)
    {
