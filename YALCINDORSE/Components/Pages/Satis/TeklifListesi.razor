@page "/satis/teklif-listesi"
@using YALCINDORSE.Services
@inject QuoteService QuoteService
@inject NavigationManager Nav
@inject DesktopWindowService WindowService

<div class="crm-workspace-panel" style="flex: 1; padding:12px 14px; box-sizing: border-box; height: 100vh; display: flex; flex-direction: column; overflow: hidden;">
    <div class="crm-header" style="margin-bottom: 8px;">
        <div>
            <h3 style="margin: 0; display: flex; align-items: center; gap: 8px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 20px; height: 20px; color: var(--yl-primary);">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                Teklif Listesi
            </h3>
            <p class="crm-header-subtitle">Teklif basliklarini ve detay kalemlerini (Master-Detail) goruntuleyebilirsiniz.</p>
        </div>
        <div class="crm-header-actions">
            <button class="btn-primary-action" @onclick="GoToNewQuote">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; margin-right:4px; vertical-align:text-bottom;">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Teklif Olustur
            </button>
            <button class="btn-secondary" @onclick="ReloadAsync">Yenile</button>
        </div>
    </div>

    <!-- Filters -->
    <div style="display: flex; gap: 8px; margin-bottom: 10px; flex-wrap:wrap;">
        <div class="crm-search-box" style="flex: 1; max-width: 300px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" class="form-control" placeholder="Teklif No, Musteri, Satici ara..." @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
        </div>
        <select class="form-select" style="max-width: 150px; border-radius:6px; border-color:var(--yl-border); font-size:0.82rem;" @onchange="OnStatusChanged">
            <option value="">Tumu (Durum)</option>
            <option value="Draft">Taslak</option>
            <option value="Sent">Gonderildi</option>
            <option value="WaitingApproval">Onay Bekliyor</option>
            <option value="Approved">Onaylandi</option>
            <option value="Rejected">Reddedildi</option>
            <option value="OPEN">Acik</option>
            <option value="ORDER">Siparis</option>
            <option value="CLOSED">Kapali</option>
        </select>
        <select class="form-select" style="max-width: 130px; border-radius:6px; border-color:var(--yl-border); font-size:0.82rem;" @onchange="OnPuanChanged">
            <option value="">Tumu (Puan)</option>
            <option value="HOT">HOT</option>
            <option value="WARM">WARM</option>
            <option value="COLD">COLD</option>
        </select>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 40px; color: var(--yl-text-light);">
            <div class="spinner" style="border-top-color: var(--yl-primary); margin: 0 auto 12px;"></div>
            Yukleniyor...
        </div>
    }
    else if (errorMessage != null)
    {
        <div style="padding: 16px; background: #fff1f0; border: 1px solid #ffa39e; border-radius: 8px; color: #cf1322; margin-bottom: 16px;">
            Hata: @errorMessage
        </div>
    }
    else
    {
        <div class="quote-grid-container">
            <div class="quote-table-wrapper">
                <table class="quote-grid">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>Tarih</th>
                            <th>Teklif No</th>
                            <th>Musteri & Ilgili</th>
                            <th>Satici</th>
                            <th>Durum</th>
                            <th>Net Tutar / Para</th>
                            <th>Puan</th>
                            <th style="width: 80px;">Isl.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (quotes == null || !quotes.Any())
                        {
                            <tr><td colspan="9" style="text-align:center; padding: 24px;">Goruntulenecek kayit bulunamadi.</td></tr>
                        }
                        else
                        {
                            @foreach (var quote in quotes)
                            {
                                bool isExpanded = expandedQuoteId == quote.Id;

                                <tr class="@(isExpanded ? "expanded-master" : "")">
                                    <td style="text-align: center;">
                                        <button class="btn-expand" @onclick="() => ToggleRowAsync(quote.Id)">
                                            @if (isExpanded) {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
                                            } else {
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                                            }
                                        </button>
                                    </td>
                                    <td>@quote.TalepTarihi.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <div style="font-weight: 600; color: var(--yl-accent);">@quote.TeklifNo</div>
                                        <div style="font-size: 0.7rem; color: var(--yl-text-light);">Rev @quote.Rev</div>
                                    </td>
                                    <td>
                                        <div style="font-weight: 500;">@quote.Musteri</div>
                                        @if (!string.IsNullOrEmpty(quote.Ilgili))
                                        {
                                            <div style="font-size: 0.75rem; color: var(--yl-text-light);">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px; height:12px; margin-right:4px; vertical-align:middle;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                @quote.Ilgili
                                            </div>
                                        }
                                    </td>
                                    <td>@quote.Satici</td>
                                    <td>
                                        <span class="yl-chip @GetStatusChipClass(quote.Durum)">
                                            @GetStatusName(quote.Durum)
                                        </span>
                                    </td>
                                    <td style="text-align: right;">
                                        <div style="font-weight: 600;">@quote.NetTutar.ToString("N2") @quote.Para</div>
                                    </td>
                                    <td>
                                        <span class="yl-chip @GetStandingChipClass(quote.Puan)">
                                            @quote.Puan
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:6px;align-items:center;">
                                            <button class="btn-expand" title="Duzenle" @onclick="() => EditQuote(quote.Id)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="btn-expand" title="Kopyala" @onclick="() => CopyQuote(quote.Id)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                            </button>
                                            <button class="btn-expand" title="PDF Ciktisi" style="color: var(--yl-danger);">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                @if (isExpanded)
                                {
                                    <tr>
                                        <td colspan="9" style="padding: 0;">
                                            <div class="quote-detail-wrapper">
                                                @if (isDetailsLoading)
                                                {
                                                    <div style="padding: 10px; color: var(--yl-text-light); font-size: 0.8rem;">Revizyonlar yukleniyor...</div>
                                                }
                                                else
                                                {
                                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 12px; border-bottom:1px solid var(--yl-border);">
                                                        <span style="font-weight:600; font-size:0.82rem; color:var(--yl-primary);">
                                                            Revizyonlar - @quote.TeklifNo
                                                        </span>
                                                        <div style="display:flex; gap:6px;">
                                                            @{ var transitions = GetAvailableTransitions(quote.Durum); }
                                                            @foreach (var tr in transitions)
                                                            {
                                                                <button class="btn-transition @tr.CssClass" @onclick="() => ChangeStatusAsync(quote.Id, tr.NewStatus)" disabled="@isTransitioning">
                                                                    @tr.Label
                                                                </button>
                                                            }
                                                            <button class="btn-transition btn-revize" @onclick="() => RevizeAsync(quote.Id)" disabled="@isTransitioning" title="Yeni revizyon olustur">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;margin-right:3px;vertical-align:text-bottom;"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                                                                Revize Et
                                                            </button>
                                                        </div>
                                                    </div>

                                                    @if (expandedRevisions == null || !expandedRevisions.Any())
                                                    {
                                                        <div style="padding: 10px; color: var(--yl-text-light); font-size: 0.8rem;">Revizyon kaydi bulunamadi.</div>
                                                    }
                                                    else
                                                    {
                                                        <table class="detail-table">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width:55px; text-align:center;">Rev</th>
                                                                    <th>Tarih</th>
                                                                    <th>Durum</th>
                                                                    <th>Net Tutar</th>
                                                                    <th>Puan</th>
                                                                    <th>Olusturma</th>
                                                                    <th style="width:70px;">Isl.</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var rev in expandedRevisions)
                                                                {
                                                                    <tr class="@(rev.Id == quote.Id ? "active-rev-row" : "")">
                                                                        <td style="text-align:center; font-weight:600;">@rev.Rev</td>
                                                                        <td>@rev.TalepTarihi.ToString("dd.MM.yyyy")</td>
                                                                        <td>
                                                                            <span class="yl-chip @GetStatusChipClass(rev.Durum)" style="font-size:0.7rem;">
                                                                                @GetStatusName(rev.Durum)
                                                                            </span>
                                                                        </td>
                                                                        <td style="text-align:right;">@rev.NetTutar.ToString("N2") @rev.Para</td>
                                                                        <td>
                                                                            <span class="yl-chip @GetStandingChipClass(rev.Puan)" style="font-size:0.7rem;">@rev.Puan</span>
                                                                        </td>
                                                                        <td style="font-size:0.75rem; color:var(--yl-text-light);">@rev.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                                                        <td>
                                                                            <div style="display:flex;gap:4px;align-items:center;">
                                                                                <button class="btn-expand" title="Duzenle" @onclick="() => EditQuote(rev.Id)">
                                                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:13px;height:13px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                                                </button>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            <div style="padding: 12px 14px; border-top: 1px solid var(--yl-border); font-size: 0.8rem; color: var(--yl-text-light); background: #fbfcfe; display: flex; justify-content: space-between;">
                <span>Toplam @(quotes?.Count ?? 0) kayit gosteriliyor.</span>
                <span>YALCINDORSE ERP v2.0 MAUI</span>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isDetailsLoading = false;
    private string? errorMessage;

    private List<QuoteListItemModel>? quotes;
    private List<QuoteListItemModel>? expandedRevisions;
    private bool isTransitioning = false;

    private string searchQuery = "";
    private string selectedStatus = "";
    private string selectedPuan = "";

    private int expandedQuoteId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuotesAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadQuotesAsync();
    }

    private async Task LoadQuotesAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            quotes = await QuoteService.GetQuotesAsync(searchQuery, selectedStatus, null, selectedPuan);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadQuotesAsync();
        }
    }

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "";
        await LoadQuotesAsync();
    }

    private async Task ToggleRowAsync(int quoteId)
    {
        if (expandedQuoteId == quoteId)
        {
            expandedQuoteId = 0;
        }
        else
        {
            expandedQuoteId = quoteId;
            isDetailsLoading = true;
            expandedRevisions = null;
            StateHasChanged();

            try
            {
                var quote = quotes?.FirstOrDefault(q => q.Id == quoteId);
                if (quote != null && !string.IsNullOrEmpty(quote.TeklifNo))
                {
                    expandedRevisions = await QuoteService.GetRevisionsByTeklifNoAsync(quote.TeklifNo);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Error] Loading Revisions: {ex.Message}");
            }
            finally
            {
                isDetailsLoading = false;
            }
        }
    }

    private async Task OnPuanChanged(ChangeEventArgs e)
    {
        selectedPuan = e.Value?.ToString() ?? "";
        await LoadQuotesAsync();
    }

    private void GoToNewQuote()
    {
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.QuoteWizard>("Teklif Olustur", 860, 700))
            Nav.NavigateTo("/satis/teklif-olustur");
    }

    private void EditQuote(int quoteId)
    {
        var parameters = new Dictionary<string, object> { { "QuoteId", quoteId } };
        WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.QuoteWizard>("Teklif Duzenle", 860, 700, parameters);
    }

    private async Task CopyQuote(int quoteId)
    {
        try
        {
            var newId = await QuoteService.CopyQuoteAsync(quoteId);
            await LoadQuotesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kopyalama hatasi: {ex.Message}";
        }
    }

    private async Task ChangeStatusAsync(int quoteId, string newStatus)
    {
        isTransitioning = true;
        StateHasChanged();
        try
        {
            await QuoteService.TransitionStatusAsync(quoteId, newStatus);
            await LoadQuotesAsync();
            // Revizyonlari yenile
            var quote = quotes?.FirstOrDefault(q => q.Id == quoteId);
            if (quote != null && !string.IsNullOrEmpty(quote.TeklifNo))
            {
                expandedRevisions = await QuoteService.GetRevisionsByTeklifNoAsync(quote.TeklifNo);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Durum degisikligi hatasi: {ex.Message}";
        }
        finally
        {
            isTransitioning = false;
        }
    }

    private async Task RevizeAsync(int quoteId)
    {
        isTransitioning = true;
        StateHasChanged();
        try
        {
            var newId = await QuoteService.CreateRevisionAsync(quoteId);
            await LoadQuotesAsync();
            // Yeni revizyonu expand et
            expandedQuoteId = newId;
            var newQuote = quotes?.FirstOrDefault(q => q.Id == newId);
            if (newQuote != null && !string.IsNullOrEmpty(newQuote.TeklifNo))
            {
                expandedRevisions = await QuoteService.GetRevisionsByTeklifNoAsync(newQuote.TeklifNo);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Revize hatasi: {ex.Message}";
        }
        finally
        {
            isTransitioning = false;
        }
    }

    private record StatusTransition(string Label, string NewStatus, string CssClass);

    private List<StatusTransition> GetAvailableTransitions(string currentStatus)
    {
        return currentStatus switch
        {
            "Draft" => new() { new("Gonder", "Sent", "btn-ts-sent") },
            "Sent" => new() { new("Onaya Sun", "WaitingApproval", "btn-ts-waiting"), new("Siparis", "ORDER", "btn-ts-order") },
            "WaitingApproval" => new() { new("Onayla", "Approved", "btn-ts-approved"), new("Reddet", "Rejected", "btn-ts-rejected") },
            "Approved" => new() { new("Siparis", "ORDER", "btn-ts-order") },
            "OPEN" => new() { new("Siparis", "ORDER", "btn-ts-order"), new("Kapat", "CLOSED", "btn-ts-closed") },
            "ORDER" => new() { new("Kapat", "CLOSED", "btn-ts-closed") },
            _ => new()
        };
    }

    // --- Helpers
    private string GetStatusName(string code) => code switch {
        "Draft" => "Taslak",
        "Sent" => "Gonderildi",
        "WaitingApproval" => "Onay Bek.",
        "Approved" => "Onaylandi",
        "Rejected" => "Reddedildi",
        "OPEN" => "Acik",
        "ORDER" => "Siparis",
        "CLOSED" => "Kapali",
        _ => code
    };

    private string GetStatusChipClass(string status) => status switch {
        "Draft" => "chip-draft",
        "Sent" => "chip-sent",
        "WaitingApproval" => "chip-waiting",
        "Approved" => "chip-approved",
        "Rejected" => "chip-rejected",
        "OPEN" => "chip-sent",
        "ORDER" => "chip-approved",
        "CLOSED" => "chip-draft",
        _ => ""
    };

    private string GetStandingChipClass(string standing) => standing switch {
        "HOT" => "chip-hot",
        "WARM" => "chip-warm",
        "COLD" => "chip-cold",
        _ => ""
    };
}
