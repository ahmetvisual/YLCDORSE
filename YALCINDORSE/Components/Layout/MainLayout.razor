@inherits LayoutComponentBase
@using YALCINDORSE.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject ThemeService Theme
@inject DesktopWindowService WindowService

<div class="app-container">
    <!-- Sidebar -->
    <aside class="app-sidebar @(sidebarCollapsed ? "sidebar-collapsed" : "") @(mobileMenuOpen ? "sidebar-mobile-open" : "")">
        <!-- Logo -->
        <div class="sidebar-header">
            <img src="images/menusimge.png" alt="Yalcin Dorse" class="sidebar-logo" />
            <span class="sidebar-brand-text">YALCIN TRAILER</span>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <!-- SATIS Group -->
            <div class="sidebar-group @(expandedGroup == "satis" ? "expanded" : "")">
                <button class="sidebar-group-header" @onclick='() => ToggleGroup("satis")' @onclick:stopPropagation="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="sidebar-group-icon">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                    <span class="sidebar-group-label">SATIS</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sidebar-chevron">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                    <span class="sidebar-tooltip">SATIS</span>
                </button>
                <!-- Expanded inline items -->
                <div class="sidebar-group-items">
                    <button class="sidebar-item" @onclick="OpenTeklifOlustur">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="12" y1="18" x2="12" y2="12"/>
                            <line x1="9" y1="15" x2="15" y2="15"/>
                        </svg>
                        <span>Teklif Olustur</span>
                    </button>
                    <button class="sidebar-item" @onclick="OpenTeklifListesi">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10 9 9 9 8 9"/>
                        </svg>
                        <span>Teklif Listesi</span>
                    </button>
                    <button class="sidebar-item" @onclick="OpenArabaslikTanimi">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                        </svg>
                        <span>Teklif Kalemleri</span>
                    </button>
                </div>
                <!-- Collapsed flyout menu -->
                @if (sidebarCollapsed && flyoutMenu == "satis")
                {
                    <div class="sidebar-flyout show">
                        <div class="sidebar-flyout-title">SATIS</div>
                        <button class="sidebar-flyout-item" @onclick="OpenTeklifOlustur">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                            Teklif Olustur
                        </button>
                        <button class="sidebar-flyout-item" @onclick="OpenTeklifListesi">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                            Teklif Listesi
                        </button>
                        <button class="sidebar-flyout-item" @onclick="OpenArabaslikTanimi">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                            Teklif Kalemleri
                        </button>
                    </div>
                }
            </div>

            <!-- CRM Group -->
            <div class="sidebar-group @(expandedGroup == "crm" ? "expanded" : "")">
                <button class="sidebar-group-header" @onclick='() => ToggleGroup("crm")' @onclick:stopPropagation="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="sidebar-group-icon">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <span class="sidebar-group-label">CRM</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sidebar-chevron">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                    <span class="sidebar-tooltip">CRM</span>
                </button>
                <!-- Expanded inline items -->
                <div class="sidebar-group-items">
                    <button class="sidebar-item" @onclick="OpenCustomerCards">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2" /><line x1="7" y1="8" x2="17" y2="8" /><line x1="7" y1="12" x2="17" y2="12" /><line x1="7" y1="16" x2="13" y2="16" /></svg>
                        <span>Cari Kartlar</span>
                    </button>
                </div>
                <!-- Collapsed flyout menu -->
                @if (sidebarCollapsed && flyoutMenu == "crm")
                {
                    <div class="sidebar-flyout show">
                        <div class="sidebar-flyout-title">CRM</div>
                        <button class="sidebar-flyout-item" @onclick="OpenCustomerCards">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2" /><line x1="7" y1="8" x2="17" y2="8" /><line x1="7" y1="12" x2="17" y2="12" /><line x1="7" y1="16" x2="13" y2="16" /></svg>
                            Cari Kartlar
                        </button>
                    </div>
                }
            </div>

            <!-- Yonetim (yalnızca admin) -->
            @if (Auth.IsAdmin)
            {
                <button class="sidebar-item" @onclick="GoToUserManagement">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    <span>Yonetim</span>
                    <span class="sidebar-tooltip">Yonetim</span>
                </button>
            }
        </nav>

        <!-- Sidebar Footer -->
        <div class="sidebar-footer">
            <!-- Theme Toggle -->
            <button class="sidebar-theme-toggle" @onclick="ToggleTheme" @onclick:stopPropagation="true">
                @if (Theme.IsDark)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                }
                <span class="sidebar-theme-label">Koyu Tema</span>
                <div class="mini-toggle @(Theme.IsDark ? "on" : "")">
                    <div class="mini-toggle-dot"></div>
                </div>
                <span class="sidebar-tooltip">Koyu Tema</span>
            </button>

            <!-- Collapse Toggle -->
            <button class="sidebar-toggle-btn" @onclick="ToggleSidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="11 17 6 12 11 7"/>
                    <polyline points="18 17 13 12 18 7"/>
                </svg>
                <span>Menuyu Sakla</span>
                <span class="sidebar-tooltip">Menuyu Goster</span>
            </button>

            <!-- Logout -->
            <button class="sidebar-item" @onclick="DoLogout" style="color:rgba(255,100,100,0.7);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span>Cikis Yap</span>
                <span class="sidebar-tooltip">Cikis Yap</span>
            </button>
        </div>
    </aside>

    <!-- Mobile Overlay -->
    @if (mobileMenuOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseMobileMenu"></div>
    }

    <!-- Content Area -->
    <div class="app-content-wrapper" @onclick="CloseAllMenus">
        <!-- Header -->
        <div class="app-header">
            <!-- Mobile Hamburger -->
            <button class="mobile-hamburger" @onclick="ToggleMobileMenu" @onclick:stopPropagation="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <div class="header-spacer"></div>

            <!-- User Profile Dropdown -->
            <div class="header-profile" @onclick="ToggleProfileMenu" @onclick:stopPropagation="true">
                <div class="profile-avatar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <span class="profile-name">@Auth.FullName</span>
                <svg class="profile-chevron @(showProfileMenu ? "rotated" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>

                @if (showProfileMenu)
                {
                    <div class="profile-dropdown">
                        <div class="profile-dropdown-header">
                            <div class="profile-dropdown-avatar">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                            </div>
                            <div>
                                <div class="profile-dropdown-name">@Auth.FullName</div>
                                <div class="profile-dropdown-role">
                                    @Auth.CurrentUser
                                    @if (Auth.IsAdmin) { <span style="margin-left:4px;font-size:0.62rem;background:#1e3a6e;color:#fff;padding:1px 5px;">ADMIN</span> }
                                </div>
                            </div>
                        </div>
                        <div class="profile-dropdown-divider"></div>
                        <button class="profile-dropdown-item" @onclick="OpenPasswordChange" @onclick:stopPropagation="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <span>Sifre Degistir</span>
                        </button>
                        <div class="profile-dropdown-divider"></div>
                        <button class="profile-dropdown-item logout" @onclick="DoLogout">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/>
                                <line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            <span>Cikis Yap</span>
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Page Content -->
        <div class="main-content">
            <div class="page-content">
                @Body
            </div>
        </div>
    </div>
</div>

@* ═══ ŞİFRE DEĞİŞTİR MODAL ═══ *@
@if (showPasswordModal)
{
    <div class="rc-modal-overlay" @onclick="ClosePasswordModal">
        <div class="rc-modal" style="min-width:360px;max-width:420px;" @onclick:stopPropagation="true">
            <div class="rc-modal-header">Sifre Degistir</div>
            <div class="rc-modal-body">
                <div style="display:flex;flex-direction:column;gap:12px;">
                    <div class="rc-form-field">
                        <label>Mevcut Sifre</label>
                        <input type="password" class="rc-form-input" @bind="_pwCurrent" placeholder="Mevcut sifreniz" autocomplete="current-password" />
                    </div>
                    <div class="rc-form-field">
                        <label>Yeni Sifre</label>
                        <input type="password" class="rc-form-input" @bind="_pwNew" placeholder="Yeni sifre" autocomplete="new-password" />
                    </div>
                    <div class="rc-form-field">
                        <label>Yeni Sifre (Tekrar)</label>
                        <input type="password" class="rc-form-input" @bind="_pwConfirm" placeholder="Yeni sifre tekrar" autocomplete="new-password" />
                    </div>
                </div>
                @if (_pwMessage != null)
                {
                    <div class="rc-toast @(_pwSuccess ? "is-ok" : "is-err")" style="margin-top:10px;">
                        @_pwMessage
                    </div>
                }
            </div>
            <div class="rc-modal-footer">
                <button class="rc-btn rc-btn-ghost" @onclick="ClosePasswordModal">Iptal</button>
                <button class="rc-btn rc-btn-primary" @onclick="SavePasswordAsync" disabled="@_pwSaving">
                    @(_pwSaving ? "Kaydediliyor..." : "Kaydet")
                </button>
            </div>
        </div>
    </div>
}

@inject UserService UserSvc

@code {
    private bool sidebarCollapsed = true;
    private bool mobileMenuOpen = false;
    private string? expandedGroup = null;
    private string? flyoutMenu = null;
    private bool showProfileMenu = false;

    // Şifre değiştir modal
    private bool    showPasswordModal = false;
    private string  _pwCurrent = "";
    private string  _pwNew     = "";
    private string  _pwConfirm = "";
    private bool    _pwSaving  = false;
    private string? _pwMessage = null;
    private bool    _pwSuccess = false;

    private void OpenPasswordChange()
    {
        _pwCurrent = ""; _pwNew = ""; _pwConfirm = "";
        _pwMessage = null; _pwSaving = false;
        showProfileMenu   = false;
        showPasswordModal = true;
    }

    private void ClosePasswordModal()
    {
        showPasswordModal = false;
        _pwMessage = null;
    }

    private async Task SavePasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_pwCurrent))
        { _pwMessage = "Mevcut sifre bos olamaz"; _pwSuccess = false; return; }
        if (string.IsNullOrWhiteSpace(_pwNew) || _pwNew.Length < 4)
        { _pwMessage = "Yeni sifre en az 4 karakter olmalidir"; _pwSuccess = false; return; }
        if (_pwNew != _pwConfirm)
        { _pwMessage = "Yeni sifreler eslesmedi"; _pwSuccess = false; return; }

        _pwSaving = true; _pwMessage = null;
        var (ok, msg) = await Auth.ChangePasswordAsync(_pwCurrent, _pwNew);
        _pwSuccess = ok; _pwMessage = msg; _pwSaving = false;

        if (ok)
        {
            StateHasChanged();
            await Task.Delay(1500);
            ClosePasswordModal();
        }
    }

    private void ToggleGroup(string group)
    {
        if (sidebarCollapsed)
        {
            // Collapsed modda flyout ac/kapat
            flyoutMenu = flyoutMenu == group ? null : group;
            return;
        }
        expandedGroup = expandedGroup == group ? null : group;
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
        if (sidebarCollapsed)
        {
            expandedGroup = null;
            flyoutMenu = null;
        }
    }

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
        if (mobileMenuOpen)
            sidebarCollapsed = false;
    }

    private void CloseMobileMenu()
    {
        mobileMenuOpen = false;
    }

    private void CloseAllMenus()
    {
        showProfileMenu = false;
        flyoutMenu = null;
    }

    private void ToggleProfileMenu() => showProfileMenu = !showProfileMenu;

    private void OpenCustomerCards()
    {
        mobileMenuOpen = false;
        flyoutMenu = null;
        if (!WindowService.OpenCustomerCardsWindow())
            Nav.NavigateTo("/crm/cari-kartlar");
    }

    private void OpenTeklifOlustur()
    {
        mobileMenuOpen = false;
        flyoutMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.QuoteWizard>("Teklif Olustur", 860, 870))
            Nav.NavigateTo("/satis/teklif-olustur");
    }

    private void OpenTeklifListesi()
    {
        mobileMenuOpen = false;
        flyoutMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.TeklifListesi>("Teklif Listesi", 1300, 800))
            Nav.NavigateTo("/satis/teklif-listesi");
    }

    private void OpenArabaslikTanimi()
    {
        mobileMenuOpen = false;
        flyoutMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.ArabaslikTanimi>("Teklif Kalemleri", 1200, 750))
            Nav.NavigateTo("/satis/arabaslik-tanimi");
    }

    private void GoToUserManagement()
    {
        mobileMenuOpen = false;
        showProfileMenu = false;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Yonetim.KullaniciYonetimi>("Kullanıcı Yönetimi", 1000, 700))
            Nav.NavigateTo("/yonetim/kullanicilar");
    }

    private void ToggleTheme()
    {
        Theme.Toggle();
    }

    private void DoLogout()
    {
        showProfileMenu = false;
        mobileMenuOpen = false;
        Auth.Logout();
    }
}
