@inherits LayoutComponentBase
@using YALCINDORSE.Services
@inject AuthService Auth
@inject NavigationManager Nav
@inject ThemeService Theme
@inject DesktopWindowService WindowService

<div class="app-container">
    <!-- Header Bar -->
    <div class="app-header">
        <img src="images/logo.svg" alt="Yalcin Trailer" class="header-logo" />
        <div class="header-spacer"></div>

        <!-- User Profile Dropdown -->
        <div class="header-profile" @onclick="ToggleProfileMenu" @onclick:stopPropagation="true">
            <div class="profile-avatar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <span class="profile-name">@Auth.FullName</span>
            <svg class="profile-chevron @(showProfileMenu ? "rotated" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"/>
            </svg>

            @if (showProfileMenu)
            {
                <div class="profile-dropdown">
                    <div class="profile-dropdown-header">
                        <div class="profile-dropdown-avatar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div>
                            <div class="profile-dropdown-name">@Auth.FullName</div>
                            <div class="profile-dropdown-role">@Auth.CurrentUser</div>
                        </div>
                    </div>
                    <div class="profile-dropdown-divider"></div>
                    <button class="profile-dropdown-item" @onclick="GoToUserManagement">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span>Kullanici Yonetimi</span>
                    </button>
                    <div class="profile-dropdown-divider"></div>
                    <div class="profile-dropdown-item theme-toggle-item" @onclick="ToggleTheme" @onclick:stopPropagation="true">
                        @if (Theme.IsDark)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        }
                        <span>Koyu Tema</span>
                        <div class="mini-toggle @(Theme.IsDark ? "on" : "")">
                            <div class="mini-toggle-dot"></div>
                        </div>
                    </div>
                    <div class="profile-dropdown-divider"></div>
                    <button class="profile-dropdown-item logout" @onclick="DoLogout">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        <span>Cikis Yap</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Toolbar -->
    <div class="app-toolbar" @onclick:stopPropagation="true">
        <div class="toolbar-menu">
            <button class="toolbar-btn @(activeMenu == "satis" ? "active" : "")" @onclick='() => ToggleMenu("satis")'>
                SATIS
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>

            @if (activeMenu == "satis")
            {
                <div class="toolbar-dropdown">
                    <button type="button" class="toolbar-dropdown-item" @onclick="OpenYeniTeklif">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="12" y1="18" x2="12" y2="12"/>
                            <line x1="9" y1="15" x2="15" y2="15"/>
                        </svg>
                        <span>Yeni Teklif</span>
                    </button>
                    <button type="button" class="toolbar-dropdown-item" @onclick="OpenTeklifListesi">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10 9 9 9 8 9"/>
                        </svg>
                        <span>Teklif Listesi</span>
                    </button>
                </div>
            }
        </div>

        <div class="toolbar-menu">
            <button class="toolbar-btn @(activeMenu == "crm" ? "active" : "")" @onclick='() => ToggleMenu("crm")'>
                CRM
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>

            @if (activeMenu == "crm")
            {
                <div class="toolbar-dropdown">
                    <button type="button" class="toolbar-dropdown-item" @onclick="OpenCustomerCards">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="3" y="4" width="18" height="16" rx="2" />
                            <line x1="7" y1="8" x2="17" y2="8" />
                            <line x1="7" y1="12" x2="17" y2="12" />
                            <line x1="7" y1="16" x2="13" y2="16" />
                        </svg>
                        <span>Cari Kartlar</span>
                    </button>
                    <button type="button" class="toolbar-dropdown-item" @onclick="OpenTouchCRM">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        <span>Touch CRM</span>
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Page Content -->
    <div class="main-content" @onclick="CloseAllMenus">
        <div class="page-content">
            @Body
        </div>
    </div>
</div>

@code {
    private string? activeMenu = null;
    private bool showProfileMenu = false;

    private void ToggleMenu(string menu)
    {
        activeMenu = activeMenu == menu ? null : menu;
        showProfileMenu = false;
    }

    private void CloseMenu()
    {
        activeMenu = null;
    }

    private void OpenCustomerCards()
    {
        activeMenu = null;

        if (!WindowService.OpenCustomerCardsWindow())
            Nav.NavigateTo("/crm/cari-kartlar");
    }

    private void OpenYeniTeklif()
    {
        activeMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.YeniTeklif>("Yeni Teklif", 1200, 800))
            Nav.NavigateTo("/satis/yeni-teklif");
    }

    private void OpenTeklifListesi()
    {
        activeMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Satis.TeklifListesi>("Teklif Listesi", 1300, 800))
            Nav.NavigateTo("/satis/teklif-listesi");
    }

    private void OpenTouchCRM()
    {
        activeMenu = null;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.CRM.TouchCRM>("Touch CRM", 1400, 900))
            Nav.NavigateTo("/crm/touch-crm");
    }

    private void CloseAllMenus()
    {
        activeMenu = null;
        showProfileMenu = false;
    }

    private void ToggleProfileMenu() => showProfileMenu = !showProfileMenu;

    private void GoToUserManagement()
    {
        showProfileMenu = false;
        if (!WindowService.OpenWindow<YALCINDORSE.Components.Pages.Yonetim.KullaniciYonetimi>("Kullanıcı Yönetimi", 1000, 700))
            Nav.NavigateTo("/yonetim/kullanicilar");
    }

    private void ToggleTheme()
    {
        Theme.Toggle();
    }

    private void DoLogout()
    {
        showProfileMenu = false;
        Auth.Logout();
    }
}
